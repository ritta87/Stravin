<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title></title>

  <!-- Bootstrap CSS -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


  <style>
    body {
      background-color: #f5f5f5;
      font-family: 'Segoe UI', sans-serif;
      color: #333;
    }

    a { text-decoration: none; }

    /* HEADER */
    header {
      background-color: #198754;
      padding: 15px 0;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
      position: sticky;
      top: 0;
      z-index: 1000;
    }
    header .brand { font-weight:700; font-size:1.7rem; color:#fff; }
    header nav a { color:#fff; font-weight:500; margin-left:25px; transition:color 0.2s;}
    header nav a:hover { color:#e0e0e0; }

    /* BACK LINK */
    .back-link { display:inline-block; margin-bottom:20px; font-weight:500; color:#198754; }
    .back-link:hover { text-decoration:underline; }
.disabled-variant{
  opacity:0.5;
  pointer-events:none;
}
    /* PRODUCT CARD */
    .product-card {
      background-color:#fff;
      border-radius:12px;
      box-shadow:0 12px 25px rgba(0,0,0,0.08);
      padding:30px;
      display:flex;
      flex-wrap:wrap;
      gap:30px;
    }

    .product-img-wrapper { flex:1 1 350px; text-align:center; }
    .product-img { max-width:100%; max-height:400px; object-fit:contain; border-radius:10px; background:#f1f1f1; padding:15px; }

    .product-info { flex:1 1 400px; display:flex; flex-direction:column; justify-content:flex-start; }
    .product-info h2 { font-size:2rem; font-weight:700; margin-bottom:15px; }
    .price { font-size:1.8rem; font-weight:700; color:#198754; margin-bottom:20px; }
    .description { font-size:1rem; color:#555; margin-bottom:25px; }

    /* VARIANTS */
    .variant-item { display:flex; align-items:center; gap:8px; padding:4px 8px; border-radius:6px; }
    .variant-item.active { border:2px solid #198754; background:#e9f7ef; }
    .variant-btn.active {
      background: black;
      color: white;
      border-color: black;
  }

    /* THUMBNAILS */
    .thumbnail-img { width:65px; height:65px; object-fit:cover; border-radius:50%; cursor:pointer; border:2px solid transparent; transition:all 0.25s ease; background:#f1f1f1; }
    .thumbnail-img:hover { transform:scale(1.05); }
    .active-thumb { border-color:#198754; box-shadow:0 0 0 2px rgba(25,135,84,0.25); }

    /* BUTTONS */
    .btn-add { padding:12px 30px; font-size:1.1rem; font-weight:600; }
.cart-item{
  border-bottom:1px solid #eee;
  padding-bottom:15px;
}

.cart-image img{
  border-radius:6px;
}

.qty-control button{
  width:30px;
  height:30px;
}

    .wishlist-section {
      padding: 50px 0;
    }

    .wishlist-title {
      font-weight: 700;
      margin-bottom: 30px;
      text-align: center;
    }

    .wishlist-card {
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 4px 14px rgba(0,0,0,0.08);
      overflow: hidden;
      transition: 0.3s ease;
      height: 100%;
    }

    .wishlist-card:hover {
      transform: translateY(-4px);
    }

   .wishlist-img-box {
  min-width: 200px;
  width: 200px;
  height: 200px;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 12px;
  background: #f8f8f8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wishlist-img-box img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
    .wishlist-body {
      padding: 18px;
    }

    .wishlist-product-name {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 10px;
      min-height: 48px;
    }

    .wishlist-price {
      font-size: 18px;
      font-weight: 700;
      color: #198754;
      margin-bottom: 12px;
    }

    .stock-text {
      font-size: 14px;
      margin-top: 6px;
      margin-bottom: 12px;
    }

    .btn-group-custom {
      display: flex;
      gap: 10px;
      margin-top: 10px;
    }

    .btn-group-custom button {
      flex: 1;
      border-radius: 10px;
    }

    .empty-wishlist {
      background: white;
      padding: 60px 20px;
      border-radius: 16px;
      box-shadow: 0 4px 14px rgba(0,0,0,0.08);
      text-align: center;
    }

    .empty-wishlist i {
      font-size: 55px;
      color: #dc3545;
      margin-bottom: 15px;
    }

    /* FOOTER */
    footer { background-color:#343a40; color:#fff; padding:30px 0; margin-top:50px; }
    footer a { color:#fff; margin:0 10px; transition:color 0.2s; }
    footer a:hover { color:#198754; text-decoration:none; }
.quantity-wrapper{
display:flex;
align-items:center;
border:1px solid #ddd;
width:130px;
border-radius:6px;
overflow:hidden;
}

.qty-btn{
background:#f8f8f8;
border:none;
width:40px;
height:40px;
font-size:18px;
cursor:pointer;
transition:0.2s;
}

.qty-btn:hover{
background:#eaeaea;
}

#qtyInput{
width:50px;
height:40px;
border:none;
text-align:center;
font-size:16px;
outline:none;
}
 .cart-link{
  position: relative;
  display: inline-block;
}
.cart-icon{
  font-size: 22px;
  color: #000;   /* black icon */
}
.cart-count{
  position:absolute;
  top:-6px;
  right:-8px;
  background:#000;
  color:#fff;
  font-size:10px;
  padding:2px 6px;
  border-radius:10px;
  font-weight:600;
}/* USER BUTTON */
.user-btn{
background:#222;
color:#fff;
border:none;
padding:6px 12px;
border-radius:6px;
font-size:14px;
cursor:pointer;
}

.user-btn:hover{
background:#000;
}
.dropdown-menu{
  display: none;
  position: absolute;
  background: #fff;
  border-radius: 10px;
  padding: 10px 0;
  min-width: 180px;
  border: none;
  box-shadow: 0 4px 15px rgba(0,0,0,0.1);
}

.dropdown-menu li{
  list-style: none;
}

.dropdown-item{
  display:block;
  padding:10px 18px;
  font-size:14px;
  color:#333;
  text-decoration:none;
  transition: all 0.2s ease;
}

.dropdown-item:hover{
  background:#f5f5f5;
  color:#000;
}

.dropdown:hover .dropdown-menu{
  display:block;
}
@media(max-width:768px) {
      .product-card { flex-direction:column; padding:20px; }
      .product-img-wrapper, .product-info { flex:1 1 100%; }
      header nav a { margin-left:15px; font-size:0.95rem; }
    }
  </style>
</head>

<header class="d-flex justify-content-between align-items-center px-4">
  <div class="brand">Stravin</div>
 <nav class="nav-bar">
    <div class="nav-left">

      <a href="/">Home</a>
      <a href="/shop">Shop</a>
    <a href="/cart" class="cart-link">
     <i class="bi bi-cart3 cart-icon"></i>
     <span id="cartCount" class="cart-count">0</span>
      </a>

      <% if (isLoggedIn) { %>

        <div class="dropdown">
          <button class="dropdown-toggle">
            Hi, <%= user.name %>
          </button>

          <ul class="dropdown-menu">
            <li>
              <a href="/logout" class="dropdown-item">Logout</a>
            </li>
          </ul>
        </div>

      <% } else { %>
    <a href="/login">Login</a>
<% } %>
</div></nav>
<script>
  //cart count
async function loadCartCount(){
  try{
    const res = await fetch('/cart/count')
    const data = await res.json()
    const cartEl = document.getElementById('cartCount')
    if(cartEl){
      cartEl.innerText = data.count
    }
  }catch(err){
    console.log("Error fetching cart count",err)
  }
}
document.addEventListener("DOMContentLoaded", loadCartCount)
</script>
</header>

<body>
  <div class="container wishlist-section">
    <h2 class="wishlist-title">My Wishlist</h2>

    <% if (wishlistItems && wishlistItems.length > 0) { %>
      <div class="row g-4">
        <% wishlistItems.forEach(item => { %>
          <div class="col-md-6 col-lg-4">
            <div class="wishlist-card">
              <div class="wishlist-img-box">

 <div class="wishlist-img-box">
  <img
    id="productImage-<%= item.product._id %>"
    src="<%= item.product.images && item.product.images.length > 0 ? item.product.images[0] : '/images/no-image.png' %>"
    alt="<%= item.product.productname %>">
</div>
 </div>
<div class="wishlist-body">
   <h5 class="wishlist-product-name"><%= item.product.productname %></h5>

<div class="price-box">
  <span class="fw-bold" id="finalPrice-<%= item.product._id %>">
    ₹<%= (item.product.offerPrice || item.product.price || 0).toFixed(2) %>
  </span>

  <% if (item.product.offerPercentage > 0) { %>
    <small
      class="text-muted text-decoration-line-through ms-2"
      id="oldPrice-<%= item.product._id %>">
      ₹<%= (item.product.price || 0).toFixed(2) %>
    </small>
  <% } else { %>
<small class="text-muted ms-2" id="oldPrice-<%= item.product._id %>"></small>  <% } %>
</div>
     
  <select class="form-select"
  id="variant-<%= item.product._id %>"
  onchange="updateVariantInfo('<%= item.product._id %>', '<%= item.product.price || 0 %>', '<%= item.product.offerPercentage || 0 %>')">
  <option value="">Select Variant</option>
  <% item.variants.forEach(variant => { %>
    <option
      value="<%= variant._id %>"
      data-price="<%= variant.additionalPrice || 0 %>"
      data-stock="<%= variant.stockQuantity || 0 %>"
      data-image="<%= variant.images && variant.images.length > 0 ? variant.images[0] : '' %>">
      <%= variant.color %>
    </option>
  <% }) %>
</select>

<div class="stock-text text-muted" id="stock-<%= item.product._id %>"></div>
    <div class="btn-group-custom">
    <button class="btn btn-dark" onclick="moveToCart('<%= item.product._id %>')">
     Move to Cart</button>
    <button class="btn btn-outline-danger"
     onclick="removeWishlistItem('<%= item.product._id %>')"> Remove</button>
 </div>
    </div>
        </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-wishlist">
        <i class="bi bi-heart-fill"></i>
        <h4>Your wishlist is empty</h4>
        <p class="text-muted">Add your favorite products to wishlist and move them to cart later.
        </p>
        <a href="/" class="btn btn-dark mt-3">Continue Shopping</a>
      </div>
    <% } %>
  </div>
<script>
  function updateVariantInfo(productId, basePrice, offerPercentage) {
    basePrice = Number(basePrice) || 0;
    offerPercentage = Number(offerPercentage) || 0;

    const select = document.getElementById(`variant-${productId}`);
    const selectedOption = select.options[select.selectedIndex];

    const extraPrice = Number(selectedOption.dataset.price) || 0;
    const stock = Number(selectedOption.dataset.stock) || 0;
    const image = selectedOption.dataset.image || "";

    const finalPriceEl = document.getElementById(`finalPrice-${productId}`);
    const oldPriceEl = document.getElementById(`oldPrice-${productId}`);
    const stockEl = document.getElementById(`stock-${productId}`);
    const imageEl = document.getElementById(`productImage-${productId}`);

    let actualPrice = basePrice + extraPrice;
    let finalPrice = actualPrice;

    if (offerPercentage > 0) {
      finalPrice = actualPrice - (actualPrice * offerPercentage / 100);
    }

    if (finalPriceEl) finalPriceEl.textContent = `₹${finalPrice.toFixed(2)}`;
    if (oldPriceEl) oldPriceEl.textContent = offerPercentage > 0 ? `₹${actualPrice.toFixed(2)}` : "";
    if (stockEl) stockEl.textContent = stock > 0 ? `In Stock: ${stock}` : "Out of Stock";
    if (image && imageEl) imageEl.src = image;
  }

//move to cart js 
 
  async function moveToCart(productId) {
    const variantSelect = document.getElementById(`variant-${productId}`);
    const variantId = variantSelect.value;

    console.log("productId:", productId);
    console.log("variantId:", variantId);

    if (!variantId) {
      Swal.fire("Warning", "Please select a variant", "warning");
      return;
    }

    try {
      const res = await fetch('/wishlist/moveToCart', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId, variantId })
      });

      console.log("response status:", res.status);

      const data = await res.json();
      console.log("response data:", data);

      if (data.success) {
        Swal.fire("Success", data.message, "success").then(() => {
          location.reload();
        });
      } else {
        Swal.fire("Error", data.message, "error");
      }
    } catch (error) {
      console.error("moveToCart frontend error:", error);
      Swal.fire("Error", "Something went wrong", "error");
    }
  }
//remove btn

async function removeWishlistItem(productId) {
  try {
    const res = await fetch('/wishlist/remove', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({productId})
    })

    const data = await res.json();

    if (data.success) {
      Swal.fire("Removed", data.message,"success").then(() => {
        location.reload();
      });
    } else {
      Swal.fire("Error",data.message,"error");
    }
  } catch (error) {
   
    Swal.fire("Error","Something went wrong","error");
  }
}

</script>
</body>
</html>