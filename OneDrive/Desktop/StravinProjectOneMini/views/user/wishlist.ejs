<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<link rel="stylesheet" href="/css/navbar.css">
<link rel="stylesheet" href="/css/pages/footer.css">

<script src="/js/navbar.js"></script>

  <style>
 .wishlist-section {
  padding: 40px 20px;
}

.wishlist-title {
  font-weight: 700;
  margin-bottom: 30px;
  text-align: center;
  color: #333;
}

.wishlist-card {
  background: #fff;
  border-radius: 16px;
  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
  overflow: hidden;
  transition: 0.3s ease;
  height: 100%;
}

.wishlist-card:hover {
  transform: translateY(-4px);
}

.wishlist-img-box {
  width: 100%;
  height: 220px;
  background: #f8f8f8;
  border-radius: 12px 12px 0 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 12px;
}

.wishlist-img-box img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.wishlist-body {
  padding: 18px;
}

.wishlist-product-name {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 10px;
  min-height: 48px;
  color: #222;
}

.wishlist-price {
  font-size: 18px;
  font-weight: 700;
  color: #198754;
  margin-bottom: 12px;
}

.stock-text {
  font-size: 14px;
  margin-top: 6px;
  margin-bottom: 12px;
}

.btn-group-custom {
  display: flex;
  gap: 10px;
  margin-top: 10px;
}

.btn-group-custom button {
  flex: 1;
  border-radius: 10px;
}

.empty-wishlist {
  background: #fff;
  padding: 60px 20px;
  border-radius: 16px;
  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
  text-align: center;
  margin: 0 20px;
}

.empty-wishlist i {
  font-size: 55px;
  color: #dc3545;
  margin-bottom: 15px;
}

@media (max-width: 768px) {
  .wishlist-section {
    padding: 30px 15px;
  }

  .wishlist-img-box {
    height: 180px;
  }

  .wishlist-body {
    padding: 15px;
  }

  .wishlist-product-name {
    font-size: 16px;
    min-height: auto;
  }

  .wishlist-price {
    font-size: 16px;
  }

  .btn-group-custom {
    flex-direction: column;
  }
}
  </style>
 <%- include('../partials/navbar') %>
  <%- include('../partials/breadcrumbs') %>
</head>
<body>
  <div class="container wishlist-section" style="max-width: 1200px;">
    <h2 class="wishlist-title">My Wishlist</h2>

    <% if (wishlistItems && wishlistItems.length > 0) { %>
      <div class="row g-4">
        <% wishlistItems.forEach(item => { %>
          <div class="col-md-6 col-lg-4">
            <div class="wishlist-card">
              <div class="wishlist-img-box">

 <div class="wishlist-img-box">
  <img
    id="productImage-<%= item.product._id %>"
    src="<%= item.product.images && item.product.images.length > 0 ? item.product.images[0] : '/images/no-image.png' %>"
    alt="<%= item.product.productname %>">
</div>
 </div>
<div class="wishlist-body">
   <h5 class="wishlist-product-name"><%= item.product.productname %></h5>

<div class="price-box">
  <span class="fw-bold" id="finalPrice-<%= item.product._id %>">
    ₹<%= (item.product.offerPrice || item.product.price || 0).toFixed(2) %>
  </span>

  <% if (item.product.offerPercentage > 0) { %>
    <small
      class="text-muted text-decoration-line-through ms-2"
      id="oldPrice-<%= item.product._id %>">
      ₹<%= (item.product.price || 0).toFixed(2) %>
    </small>
  <% } else { %>
<small class="text-muted ms-2" id="oldPrice-<%= item.product._id %>"></small>  <% } %>
</div>
     
  <select class="form-select"
  id="variant-<%= item.product._id %>"
  onchange="updateVariantInfo('<%= item.product._id %>', '<%= item.product.price || 0 %>', '<%= item.product.offerPercentage || 0 %>')">
  <option value="">Select Variant</option>
  <% item.variants.forEach(variant => { %>
    <option
      value="<%= variant._id %>"
      data-price="<%= variant.additionalPrice || 0 %>"
      data-stock="<%= variant.stockQuantity || 0 %>"
      data-image="<%= variant.images && variant.images.length > 0 ? variant.images[0] : '' %>">
      <%= variant.color %>
    </option>
  <% }) %>
</select>

<div class="stock-text text-muted" id="stock-<%= item.product._id %>"></div>
    <div class="btn-group-custom">
    <button class="btn btn-dark" onclick="moveToCart('<%= item.product._id %>')">
     Move to Cart</button>
    <button class="btn btn-outline-danger"
     onclick="removeWishlistItem('<%= item.product._id %>')"> Remove</button>
 </div>
    </div>
        </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-wishlist">
        <i class="bi bi-heart-fill"></i>
        <h4>Your wishlist is empty</h4>
        <p class="text-muted">Add your favorite products to wishlist and move them to cart later.
        </p>
        <a href="/" class="btn btn-dark mt-3">Continue Shopping</a>
      </div>
    <% } %>
  </div>

  <%-include('../partials/footer')%>
<script>
  function updateVariantInfo(productId, basePrice, offerPercentage) {
    basePrice = Number(basePrice) || 0;
    offerPercentage = Number(offerPercentage) || 0;

    const select = document.getElementById(`variant-${productId}`);
    const selectedOption = select.options[select.selectedIndex];

    const extraPrice = Number(selectedOption.dataset.price) || 0;
    const stock = Number(selectedOption.dataset.stock) || 0;
    const image = selectedOption.dataset.image || "";

    const finalPriceEl = document.getElementById(`finalPrice-${productId}`);
    const oldPriceEl = document.getElementById(`oldPrice-${productId}`);
    const stockEl = document.getElementById(`stock-${productId}`);
    const imageEl = document.getElementById(`productImage-${productId}`);

    let actualPrice = basePrice + extraPrice;
    let finalPrice = actualPrice;

    if (offerPercentage > 0) {
      finalPrice = actualPrice - (actualPrice * offerPercentage / 100);
    }

    if (finalPriceEl) finalPriceEl.textContent = `₹${finalPrice.toFixed(2)}`;
    if (oldPriceEl) oldPriceEl.textContent = offerPercentage > 0 ? `₹${actualPrice.toFixed(2)}` : "";
    if (stockEl) stockEl.textContent = stock > 0 ? `In Stock: ${stock}` : "Out of Stock";
    if (image && imageEl) imageEl.src = image;
  }

//move to cart js 
 
  async function moveToCart(productId) {
    const variantSelect = document.getElementById(`variant-${productId}`);
    const variantId = variantSelect.value;

    console.log("productId:", productId);
    console.log("variantId:", variantId);

    if (!variantId) {
      Swal.fire("Warning", "Please select a variant", "warning");
      return;
    }

    try {
      const res = await fetch('/wishlist/moveToCart', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId, variantId })
      });

      console.log("response status:", res.status);

      const data = await res.json();
      console.log("response data:", data);

      if (data.success) {
        Swal.fire("Success", data.message, "success").then(() => {
          location.reload();
        });
      } else {
        Swal.fire("Error", data.message, "error");
      }
    } catch (error) {
      console.error("moveToCart frontend error:", error);
      Swal.fire("Error", "Something went wrong", "error");
    }
  }
//remove btn

async function removeWishlistItem(productId) {
  try {
    const res = await fetch('/wishlist/remove', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({productId})
    })

    const data = await res.json();

    if (data.success) {
      Swal.fire("Removed", data.message,"success").then(() => {
        location.reload();
      });
    } else {
      Swal.fire("Error",data.message,"error");
    }
  } catch (error) {
   
    Swal.fire("Error","Something went wrong","error");
  }
}

</script>
</body>
</html>