<!DOCTYPE html>
<html lang="en">
  <head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<link rel="stylesheet" href="/css/navbar.css">
<link rel="stylesheet" href="/css/pages/footer.css">

<style>
/* ===== CONTAINER ===== */
.order-details-container {
  max-width: 1050px;
  margin: 35px auto;
  padding: 22px;
  background: #fff;
  border-radius: 14px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.05);
}

/* ===== ITEM ROW ===== */
.item-row {
  display: flex;
  align-items: center;
  gap: 18px;
  padding: 18px 0;
  border-bottom: 1px solid #f1f1f1;
  transition: 0.2s ease;
}

.item-row:hover {
  background: #fafafa;
  border-radius: 8px;
  padding-left: 8px;
}

.item-row:last-child {
  border-bottom: none;
}

/* ===== PRODUCT IMAGE ===== */
.variant-img {
  width: 65px;
  height: 65px;
  object-fit: cover;
  border-radius: 8px;
  border: 1px solid #eee;
}

/* ===== ITEM DETAILS ===== */
.item-details {
  flex: 1;
}

.item-details h6 {
  font-size: 15px;
  font-weight: 600;
  margin-bottom: 5px;
  color: #222;
}

.item-details p {
  font-size: 13px;
  color: #666;
  margin: 2px 0;
}

/* ===== ACTION AREA ===== */
.action-area {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-top: 10px;
}

/* ===== BUTTON BASE ===== */
.btn,
.invoice-btn,
.return-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 500;
  padding: 7px 14px;
  border-radius: 6px;
  text-decoration: none;
  cursor: pointer;
  border: none;
  transition: all 0.2s ease;
}

/* ===== BUTTON HOVER FEEL ===== */
.btn:hover,
.invoice-btn:hover,
.return-btn:hover {
  transform: translateY(-1px);
}

/* ===== PRIMARY ===== */
.btn-primary {
  background: #0d6efd;
  color: #fff;
}

.btn-primary:hover {
  background: #0b5ed7;
}

/* ===== OUTLINE PRIMARY ===== */
.btn-outline-primary {
  border: 1px solid #0d6efd;
  color: #0d6efd;
  background: transparent;
}

.btn-outline-primary:hover {
  background: #0d6efd;
  color: #fff;
}

/* ===== SECONDARY ===== */
.btn-outline-secondary {
  border: 1px solid #ced4da;
  color: #555;
  background: transparent;
}

.btn-outline-secondary:hover {
  background: #f1f3f5;
}

/* ===== RETURN BUTTON ===== */
.return-btn {
  background: #fff3cd;
  color: #856404;
}

.return-btn:hover {
  background: #ffe69c;
}

/* ===== INVOICE BUTTON ===== */
.invoice-btn {
  background: #e9f7ef;
  color: #198754;
}

.invoice-btn:hover {
  background: #d1e7dd;
}

/* ===== ICON ===== */
.btn i,
.invoice-btn i {
  font-size: 13px;
}

/* ===== STATUS (clean text style) ===== */
.badge {
  background: none !important;
  padding: 0 !important;
  font-size: 14px;
  font-weight: 500;
}

/* subtle colors */
.bg-success { color: #198754 !important; }
.bg-danger { color: #dc3545 !important; }
.bg-secondary { color: #6c757d !important; }
.bg-warning { color: #fd7e14 !important; }
.bg-info { color: #0d6efd !important; }
.bg-primary { color: #444 !important; }

.text-dark { color: #fd7e14 !important; }

/* ===== RESPONSIVE ===== */
@media (max-width: 768px) {
  .item-row {
    flex-direction: column;
    align-items: flex-start;
  }

  .variant-img {
    width: 100%;
    max-width: 130px;
    height: auto;
  }

  .action-area {
    width: 100%;
  }
}

</style>
<%- include('../partials/navbar') %>
<%-include ('../partials/breadcrumbs')%>
<body>

<div class="container mt-4">

  <h3>Order Details - <%= order.orderId %></h3>

  <p>
    <strong>Ordered On:</strong> 
    <%= new Date(order.createdAt).toLocaleString() %>
  </p>

  <p><strong>Order Total:</strong> ₹<%= order.totalAmount-order.discount %></p>
  <p><strong>Payment Method:</strong> <%= order.paymentMethod %></p>
  <p><strong>Payment Status:</strong> <%= order.paymentStatus %></p>

  <p><strong>Shipping Address:</strong></p>
  <p>
    <%= order.address.name %> -- Mobile : <%= order.address.mobile %><br>
    <%= order.address.house %>, <%= order.address.address %>, <%= order.address.area %><br>
    <%= order.address.city %> - <%= order.address.pincode %>, <%= order.address.state %><br>
    <% if(order.address.landmark) { %>
      Landmark: <%= order.address.landmark %>
    <% } %>
  </p>

  <hr>

  
<div class="row mt-4">

  <!-- ITEMS -->
  <div class="col-md-8">
    <h5>Items:</h5>

    <% order.items.forEach(item => { %>
      <div class="card p-3 mb-3 shadow-sm">
        <div class="row align-items-center">

          <!-- Image -->
          <div class="col-md-2">
            <img 
              src="<%= item.variant?.images?.[0] || '/images/default.png' %>" 
              style="width:90px; height:90px; object-fit:cover; border-radius:8px;"
            />
          </div>

          <!-- Info -->
          <div class="col-md-10">
            <h6>
              <%= item.product?.productname || 'Product' %> 
              -- <%= item.variant?.color || '' %>
            </h6>

            <p>Quantity: <%= item.quantity %></p>
            <p>Price: ₹<%= item.price %></p>

            <!-- item level status -->
            <p><strong>Status:</strong>
              <span class="badge 
                <%= item.itemStatus === 'Delivered' ? 'bg-success' :
                    item.itemStatus === 'Cancelled' ? 'bg-danger' :
                    item.itemStatus === 'Returned' ? 'bg-secondary' :
                    item.itemStatus === 'Out for Delivery' ? 'bg-warning text-dark' :
                    item.itemStatus === 'Shipped' ? 'bg-info text-dark' :
                    'bg-primary' %>">
                <%= item.itemStatus %>
              </span>
            </p>
<% if (item.return?.isRequested) { %>
  <div style="margin-top:6px; font-size:13px; padding:6px; border-radius:6px; background:#fff3cd;">
    <p>Return Requested: <strong><%= item.return.reason %></strong></p>
    <p>Status: <%= item.return.status %></p>
    <% if(item.return.status !== 'Pending' && item.return.approvalDate){ %>
      <p>Processed on: <%= new Date(item.return.approvalDate).toLocaleString() %></p>
    <% } %>
    <% if(item.refundDetails){ %>
      <p style="color:green;">✅ Refunded ₹<%= item.refundDetails.amount %> to Wallet</p>
    <% } %>
  </div>
<% } %>

            
<!--return and cancel-->
            <div class="mt-2">
              <button 
                class="btn btn-sm btn-danger"
                onclick="cancelItem('<%= order.orderId %>', '<%= item._id %>')"
                <%= (item.itemStatus === 'Delivered' || item.itemStatus === 'Cancelled' || item.itemStatus === 'Returned') ? 'disabled' : '' %>>
                Cancel
              </button>

              <button 
                class="btn btn-sm btn-secondary"
                onclick="returnItem('<%= order.orderId %>', '<%= item._id %>')"
                <%= (order.paymentMethod === 'COD' || item.itemStatus !== 'Delivered') ? 'disabled' : '' %>>
                Return
              </button>
            </div>


    <% if (item.isRefunded && item.refundDetails) { %>
    <div style="margin-top:8px; padding:6px; background:#e6ffe6; border-radius:6px;">
      <p style="color:green; font-size:13px; margin:0;">
        ✅ Refunded ₹<%= item.refundDetails.amount %> to wallet
      </p>
      <p style="font-size:12px; margin:0;">
        On: <%= new Date(item.refundDetails.date).toLocaleString() %>
      </p>
    </div>
  <% } %>
            <% if (order.paymentMethod === 'COD' && item.itemStatus === 'Delivered') { %>
              <p style="color:red; font-size:12px; margin-top:5px;">
                Return not available for Cash on Delivery orders
              </p>
            <% } %>

            
            <% if (item.statusHistory && item.statusHistory.length > 0) { %>
              <ul style="font-size: 13px; padding-left: 15px;">
                <% item.statusHistory.forEach(s => { %>
                  <li>
                    <%= s.status %> - 
                    <%= new Date(s.date).toLocaleString() %>
                  </li>
                <% }) %>
              </ul>
            <% } %>

          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- price details-->
  <div class="col-md-4">
    <div class="card p-3 shadow-sm">

      <h5>Price Details</h5>

      <p>Subtotal: ₹<%= order.subTotal || 0 %></p>
      <p>Tax (5%): ₹<%= order.tax || 0 %></p>
      <p>Shipping: ₹<%= order.shipping || 0 %></p>

      <% if(order.discount > 0) { %>
        <p>Coupon (<%= order.coupon?.code || '' %>): -₹<%= order.discount %></p>
      <% } %>

      <% if(order.walletUsed > 0) { %>
        <p>Wallet Used: -₹<%= order.walletUsed %></p>
      <% } %>

      <hr>

      <!-- order status -->
      <p><strong>Order Status:</strong>
        <span class="badge 
          <%= order.status === 'Delivered' ? 'bg-success' :
              order.status === 'Cancelled' ? 'bg-danger' :
              order.status === 'Returned' ? 'bg-secondary' :
              order.status === 'Out for Delivery' ? 'bg-warning text-dark' :
              order.status === 'Shipped' ? 'bg-info text-dark' :
              'bg-primary' %>">
          <%= order.status %>
        </span>
      </p>

      <% if (order.statusHistory && order.statusHistory.length > 0) { %>
        <ul style="font-size: 14px; padding-left: 15px;">
          <% order.statusHistory.forEach(s => { %>
            <li>
              <%= s.status %> - 
              <%= new Date(s.date).toLocaleString() %>
            </li>
          <% }) %>
        </ul>
      <% } %>

      <h5><strong>Total Paid: ₹<%= order.totalAmount-order.discount %></strong></h5>

    </div>
  </div>

</div>
<%-include('../partials/footer')%>
<script>
async function returnItem(orderId, itemId) {
  const { value: reason } = await Swal.fire({
    title: 'Reason for Return',
    input: 'textarea',
    inputPlaceholder: 'Enter reason...',
    showCancelButton: true,
    confirmButtonText: 'Submit',
    preConfirm: (reason) => {
      if(!reason || reason.trim() === "") Swal.showValidationMessage("Reason is required");
      return reason;
    }
  });

  if(!reason) return;

  try {
    const res = await fetch(`/return/${orderId}/${itemId}`, {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({reason})
    });

    const data = await res.json();

    if(data.success){
      Swal.fire('Success', data.message, 'success').then(() => location.reload());
    } else {
      Swal.fire('Error', data.message || 'Something went wrong', 'error');
    }

  } catch (err) {
    console.error(err);
    Swal.fire('Error', 'Server error', 'error');
  }
}
//cancel item..
async function cancelItem(orderId, itemId) {
  const confirm = await Swal.fire({
    title: "Cancel Item?",
    text: "Are you sure you want to cancel this item?",
    icon: "warning",
    showCancelButton: true,
    confirmButtonText: "Yes, Cancel",
    cancelButtonText: "No"
  })

  if (!confirm.isConfirmed) return;

  try {
    const res = await fetch(`/cancel/${orderId}/item/${itemId}`, {
      method: "POST",
      headers: {"Content-Type": "application/json"}
    })

    const data = await res.json();

    if (data.success) {
      Swal.fire("Cancelled!", data.message,"success")
        .then(() => location.reload());
    } else {
      Swal.fire("Error",data.message,"error");
    }

  } catch (err) {
    console.error(err);
    Swal.fire("Error","Something went wrong","error");
  }
}
</script>

</body>
</html>