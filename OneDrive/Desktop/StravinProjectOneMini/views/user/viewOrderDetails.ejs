<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


<style>
  /* ===== HEADER ===== */
header {
  background: #198754;
  padding: 14px 30px;
  position: sticky;
  top: 0;
  z-index: 1000;
}

/* ===== BRAND ===== */
.brand {
  font-size: 22px;
  font-weight: bold;
  color: #fff;
}
.invoice-btn {
  display: inline-block;
  margin-top: 15px;
  padding: 10px 18px;
  background: #343a40;   /* dark professional */
  color: #fff;
  border-radius: 8px;
  text-decoration: none;
  font-size: 14px;
  transition: all 0.3s ease;
}

/* hover effect */
.invoice-btn:hover {
  background: #212529;
  transform: translateY(-1px);
}
/* ===== NAV ===== */
.nav-bar {
  display: flex;
  align-items: center;
  gap: 25px;
}

.nav-bar a {
  color: #fff;
  text-decoration: none;
  font-weight: 500;
  transition: 0.2s;
}

.nav-bar a:hover {
  opacity: 0.8;
}

/* ===== RIGHT SECTION ===== */
.nav-left {
  display: flex;
  align-items: center;
  gap: 20px;
}

/* ===== ICONS ===== */
.cart-link,
.wishlist-nav {
  position: relative;
  display: inline-flex;
  align-items: center;
}

.cart-icon,
.wishlist-nav i {
  font-size: 20px;
  color: #fff;
}

/* ===== BADGES ===== */
.cart-count,
.wishlist-badge {
  position: absolute;
  top: -6px;
  right: -8px;
  background: red;
  color: #fff;
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 10px;
  font-weight: 600;
}

/* ===== USER BUTTON ===== */
.user-btn,
.dropdown-toggle {
  background: #fff;
  color: #198754;
  border: none;
  padding: 6px 12px;
  border-radius: 6px;
  font-weight: 500;
  cursor: pointer;
  transition: 0.2s;
}



/* ===== DROPDOWN ===== */
.dropdown {
  position: relative;
}

/* dropdown menu */
.dropdown-menu {
  display: none;
  position: absolute;
  top: 42px;
  right: 0;
  background: #fff;
  border-radius: 10px;
  min-width: 150px;
  padding: 8px 0;
  box-shadow: 0 8px 20px rgba(0,0,0,0.15);
  animation: fadeIn 0.2s ease;
}

.dropdown-menu li {
  padding: 8px 15px;
}

.dropdown-menu a {
  text-decoration: none;
  color: #333;
  font-size: 14px;
  display: block;
}

.dropdown-menu li:hover {
  background: #f3f3f3;
}

/* SHOW */
.dropdown:hover .dropdown-menu {
  display: block;
}

/* ===== WISHLIST ANIMATION ===== */
.wishlist-btn i {
  transition: 0.3s;
}

.wishlist-active i {
  color: red;
  transform: scale(1.2);
}
.order-details-container {
  margin-top: 20px;
}
.item-row {
  gap: 15px;
}
/* Variant Images */
.variant-img {
  width: 50px;
  height: 50px;
  object-fit: cover;
  border-radius: 4px;
}

/* Item Details */
.item-details h6 {
  font-weight: 600;
  margin-bottom: 5px;
}

/* General Buttons */
.btn-lg,
.btn-sm,
.invoice-btn,
.return-btn,
.btn-outline-secondary,
.btn-outline-primary {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-weight: 500;
  border-radius: 0.4rem;
  font-size: 0.85rem;
  padding: 0.35rem 0.8rem;
  min-width: auto;
  transition: 0.2s all;
}

/* Large Buttons */
.btn-lg {
  font-size: 1rem;
  padding: 0.6rem 1.2rem;
  border-radius: 0.5rem;
  gap: 5px;
}

/* Return Button */
.return-btn {
  min-width: 100px;
  text-align: center;
}
.return-btn:hover {
  transform: scale(1.05);
}

/* Back Button (Outline) */
.btn-outline-secondary {
  color: #6c757d;
  border-color: #6c757d;
}
.btn-outline-secondary:hover {
  background-color: #e2e6ea;
  color: #343a40;
}
.invoice-btn {
  padding: 0.25rem 0.5rem; /* slightly tighter padding */
  font-size: 0.8rem;       /* small, compact text */
  min-width: auto;          /* remove long default width */
  border-radius: 0.35rem;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  transition: 0.2s all;
}

.invoice-btn i {
  font-size: 0.85rem;       /* icon matches text height */
}

/* Hover effect */
.invoice-btn:hover {
  background-color: #0b5ed7;
  color: white;
  transform: scale(1.05);
}
/* Outline Primary Button */
.btn-outline-primary {
  color: #0d6efd;
  border-color: #0d6efd;
}
.btn-outline-primary:hover {
  background-color: #0d6efd;
  color: white;
}

/* Primary Small Button */
.btn-primary.btn-sm {
  background-color: #0d6efd;
  color: white;
}
.btn-primary.btn-sm:hover {
  background-color: #0b5ed7;
}

/* Icons inside any button */
.btn i {
  font-size: 0.9rem;
}
</style>
<header class="d-flex justify-content-between align-items-center px-4">
  <div class="brand">Stravin</div>
 <nav class="nav-bar">
    <div class="nav-left">

      <a href="/">Home</a>
      <a href="/shop">Shop</a>
    <a href="/cart" class="cart-link">
     <i class="bi bi-cart3 cart-icon"></i>
     <span id="cartCount" class="cart-count">0</span>
      </a>

      <% if (isLoggedIn) { %>

        <div class="dropdown">
          <button class="dropdown-toggle">
            Hi, <%= user.name %>
          </button>

          <ul class="dropdown-menu">
            <li>
              <a href="/logout" class="dropdown-item">Logout</a>
            </li>
          </ul>
        </div>

      <% } else { %>
    <a href="/login">Login</a>
<% } %>
</div></nav>
<script>
  //cart count
async function loadCartCount(){
  try{
    const res = await fetch('/cart/count')
    const data = await res.json()
    const cartEl = document.getElementById('cartCount')
    if(cartEl){
      cartEl.innerText = data.count
    }
  }catch(err){
    console.log("Error fetching cart count",err)
  }
}
document.addEventListener("DOMContentLoaded", loadCartCount)
</script>
</header>

<body>

<div class="container mt-4">
 <div class="container mt-4">
  <h3>Order Details - <%= order.orderId %></h3>
  <p><strong>Order Total:</strong> ₹<%= order.totalAmount %></p>
  <p><strong>Payment Method:</strong> <%= order.paymentMethod %></p>
 <p><strong>Shipping Address:</strong></p>
<p>
  <%= order.address.name %>, <%= order.address.mobile %><br>
  <%= order.address.house %>, <%= order.address.address %>, <%= order.address.area %><br>
  <%= order.address.city %> - <%= order.address.pincode %>, <%= order.address.state %><br>
  <% if(order.address.landmark) { %>
    Landmark: <%= order.address.landmark %>
  <% } %>
</p>

  <hr>

  <h5>Items:</h5>
  <% order.items.forEach(item => { %>
    <div class="card p-3 mb-3 shadow-sm">
      <div class="row align-items-center">
        <!-- Product Image -->
        <div class="col-md-2">
      <img src="<%= order.items[0]?.image || '/images/default.png' %>" 
          style="width:90px; height:90px; object-fit:cover; border-radius:8px;"
        />        </div>

        <!-- Product Info -->
        <div class="col-md-6">
          <h6><%= item.name %> - <%= item.color %></h6>
          <p>Quantity: <%= item.quantity %></p>
          <p>Price: ₹<%= item.price %></p>
        </div>

        <!-- Status & Return -->
        <div class="col-md-4 text-end">
          <p><strong>Status:</strong>
            <% if(item.itemStatus === 'Delivered') { %>
              <span class="text-success"><%= item.itemStatus %></span>
            <% } else if(item.itemStatus === 'Cancelled') { %>
              <span class="text-danger"><%= item.itemStatus %></span>
            <% } else { %>
              <span class="text-primary"><%= item.itemStatus %></span>
            <% } %>
          </p>

          <% if(item.itemStatus === 'Delivered') { %>
            <% if(!item.return.isRequested) { %>
              <button class="btn btn-warning btn-sm" onclick="requestItemReturn('<%= order._id %>','<%= item._id %>')">Request Return</button>
            <% } else { %>
              <p><strong>Return Requested:</strong></p>
              <ul class="list-unstyled">
                <li>Reason: <%= item.return.reason %></li>
                <li>Date: <%= item.return.requestDate ? item.return.requestDate.toLocaleDateString() : '' %></li>
                <li>Status: <%= item.return.status %></li>
              </ul>
            <% } %>
          <% } %>

        </div>
      </div>
    </div>
  <% }) %>
</div>

<script>
async function requestItemReturn(orderId, itemId) {
  const { value: reason } = await Swal.fire({
    title: 'Reason for Return',
    input: 'textarea',
    inputPlaceholder: 'Enter reason...',
    showCancelButton: true,
    confirmButtonText: 'Submit',
    preConfirm: (reason) => {
      if(!reason || reason.trim() === "") Swal.showValidationMessage("Reason is required");
      return reason;
    }
  });

  if(!reason) return;

  try {
    const res = await fetch(`/returnItem/${orderId}/${itemId}`, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ reason })
    });

    const data = await res.json();

    if(data.success){
      Swal.fire('Success', data.message, 'success').then(() => location.reload());
    } else {
      Swal.fire('Error', data.message || 'Something went wrong', 'error');
    }

  } catch (err) {
    console.error(err);
    Swal.fire('Error', 'Server error', 'error');
  }
}
</script>

</body>
</html>