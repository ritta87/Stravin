<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login | Stravin</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <link  href="https://cdn.jsdelivr.net/npm/cropperjs@1.5.13/dist/cropper.min.css" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/cropperjs@1.5.13/dist/cropper.min.js"></script>
  <style>
/* ===== BODY ===== */
body {
  background: linear-gradient(135deg, #0f1115, #1c1f26);
  font-family: 'Segoe UI', sans-serif;
  color: #fff;
}

/* ===== LOGIN CARD ===== */
.container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.container .col-md-4 {
  background: #1e2128 !important;
  border-radius: 16px;
  padding: 30px 25px;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
  border: 1px solid #2c313a;
}

/* ===== TITLE ===== */
h3 {
  color: #fff;
  font-weight: 600;
}

.text-muted {
  color: #9ca3af !important;
}

/* ===== LABEL ===== */
.form-label {
  color: #cbd5e1;
  font-size: 0.9rem;
}

/* ===== INPUT ===== */
.form-control {
  background: #2a2f3a;
  border: 1px solid #3a404c;
  color: #fff;
  border-radius: 10px;
  height: 45px;
  transition: 0.3s;
}

.form-control::placeholder {
  color: #9ca3af;
}

.form-control:focus {
  background: #2a2f3a;
  color: #fff;
  border-color: #4ade80;
  box-shadow: 0 0 0 2px rgba(74, 222, 128, 0.2);
}

/* ===== LOGIN BUTTON ===== */
#loginBtn {
  background: #4ade80;
  border: none;
  border-radius: 10px;
  height: 45px;
  font-weight: 600;
  transition: 0.3s;
}

#loginBtn:hover {
  background: #22c55e;
  transform: translateY(-1px);
}

/* ===== LINKS ===== */
a {
  color: #4ade80;
  font-size: 0.9rem;
}

a:hover {
  text-decoration: underline;
}

/* ===== DIVIDER ===== */
hr {
  border-color: #3a404c;
}

/* ===== GOOGLE BUTTON ===== */
.google-btn {
  display: block;
  width: 100%;
}

.google-btn button {
  width: 100%;
  height: 45px;
  background: #fff;
  color: #333;
  border: none;
  border-radius: 10px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  transition: 0.3s;
  cursor: pointer;
}

/* Google icon */
.google-btn button::before {
  content: "";
  width: 18px;
  height: 18px;
  background: url("https://www.svgrepo.com/show/475656/google-color.svg") no-repeat center;
  background-size: contain;
}

/* Hover */
.google-btn button:hover {
  background: #f1f5f9;
  transform: translateY(-1px);
}

/* ===== ERROR MESSAGE ===== */
p[style*="color:red"] {
  background: #2a1a1a;
  padding: 8px;
  border-radius: 6px;
  text-align: center;
  font-size: 0.85rem;
}

/* ===== SIGNUP TEXT ===== */
.text-center a {
  font-weight: 500;
}

/* ===== MOBILE ===== */
@media (max-width: 500px) {
  .container .col-md-4 {
    padding: 25px 18px;
  }
}
  </style>
</head>

<body>

<div class="container mt-5">
  <div class="col-md-4 mx-auto shadow p-4 rounded bg-white">

    <h3 class="text-center mb-3">Welcome Back</h3>
    <p class="text-center text-muted">Login to continue shopping</p>

    <!-- Email -->
    <div class="mb-3">
      <label class="form-label">Email</label>
      <input type="email" id="email" class="form-control" placeholder="Enter email">
    </div>

    <!-- Password -->
    <div class="mb-3">
      <label class="form-label">Password</label>
      <input type="password" id="password" class="form-control" placeholder="Enter password">
    </div>

    <button id="loginBtn" class="btn btn-primary w-100 mb-3">Login</button>

    <a href="/forgotPassword" class="text-decoration-none">
      <p class="text-center">Forgot Password?</p>
    </a>

    <hr>

    <!-- Google Single Sign In -->
   <a href="/auth/google" class="google-btn">
  <button type="button">Continue With Google</button>
</a>
<% if (error === "access_denied") { %>
  <p style="color:red;">Account is Denied!</p>
<% } %>

    <p class="text-center mt-3">
      Don't have an account? 
      <a href="/signup">Signup</a>
    </p>
  </div>
</div>

<script>
document.getElementById('loginBtn').addEventListener('click', async () => {
    const email = document.getElementById('email').value.trim();
    const password = document.getElementById('password').value.trim();

    // Simple validation
    if (!email || !password) {
        return Swal.fire("Error", "All fields are required!", "error");
    }

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
        return Swal.fire("Error", "Enter a valid email", "error");
    }

    try {
        const res = await fetch('/login', {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email, password })
        });

        const data = await res.json()

        if (res.ok && data.success) {
            Swal.fire({
                icon: "success",
                title: "Logged In",
                timer: 1500,
                showConfirmButton: false
            });

            setTimeout(() => {
                window.location.href = "/";
            }, 1500);
        }
        
        //  Blocked user
  if (data.blocked) {
    Swal.fire({
      icon: 'error',
      title: 'Access Denied',
      text: data.message
    });
    return;
  }

    } catch (err) {
        Swal.fire("Error", "Server error occurred", "error");
        console.error(err);
    }
});

// Google login
document.getElementById('googleLogin').addEventListener('click', () => {
    window.location.href = '/auth/google';
});
</script>




</body>
</html>