<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login | Stravin</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <style>
    .google-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      border: 1px solid #ddd;
      padding: 10px;
      border-radius: 4px;
      background: white;
      font-weight: 500;
      cursor: pointer;
    }
    .google-btn img {
      width: 20px;
    }
  </style>
</head>

<body class="bg-light">

<div class="container mt-5">
  <div class="col-md-4 mx-auto shadow p-4 rounded bg-white">

    <h3 class="text-center mb-3">Welcome Back</h3>
    <p class="text-center text-muted">Login to continue shopping</p>

    <!-- Email -->
    <div class="mb-3">
      <label class="form-label">Email</label>
      <input type="email" id="email" class="form-control" placeholder="Enter email">
    </div>

    <!-- Password -->
    <div class="mb-3">
      <label class="form-label">Password</label>
      <input type="password" id="password" class="form-control" placeholder="Enter password">
    </div>

    <button id="loginBtn" class="btn btn-primary w-100 mb-3">Login</button>

    <a href="/forgotPassword" class="text-decoration-none">
      <p class="text-center">Forgot Password?</p>
    </a>

    <hr>

    <!-- Google Single Sign In -->
    <a href="/auth/google">

      <button type="button">Continue With Google</button>
     
    </a>

    <p class="text-center mt-3">
      Don't have an account? 
      <a href="/signup">Signup</a>
    </p>
  </div>
</div>

<script>
document.getElementById('loginBtn').addEventListener('click', async () => {
    const email = document.getElementById('email').value.trim();
    const password = document.getElementById('password').value.trim();

    // Simple validation
    if (!email || !password) {
        return Swal.fire("Error", "All fields are required!", "error");
    }

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
        return Swal.fire("Error", "Enter a valid email", "error");
    }

    try {
        const res = await fetch('/login', {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email, password })
        });

        const data = await res.json()

        if (res.ok && data.success) {
            Swal.fire({
                icon: "success",
                title: "Logged In",
                timer: 1500,
                showConfirmButton: false
            });

            setTimeout(() => {
                window.location.href = "/";
            }, 1500);
        }
        
        //  Blocked user
  if (data.blocked) {
    Swal.fire({
      icon: 'error',
      title: 'Access Denied',
      text: data.message
    });
    return;
  }

    } catch (err) {
        Swal.fire("Error", "Server error occurred", "error");
        console.error(err);
    }
});

// Google login
document.getElementById('googleLogin').addEventListener('click', () => {
    window.location.href = '/auth/google';
});
</script>




</body>
</html>