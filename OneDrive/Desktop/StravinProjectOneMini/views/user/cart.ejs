<!DOCTYPE html>
<html lang="en">
  <head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<link rel="stylesheet" href="/css/navbar.css">
<link rel="stylesheet" href="/css/pages/footer.css">

<script src="/js/navbar.js"></script>
  <style>
/* CART ICON */
.cart-link {
  position: relative;
  display: inline-flex;
  align-items: center;
}

.cart-link i {
  font-size: 18px;
}

/* CART COUNT BADGE */
.cart-count {
  position: absolute;
  top: -8px;
  right: -10px;
  min-width: 18px;
  height: 18px;
  padding: 0 5px;
  border-radius: 50px;
  background: red;
  color: #fff;
  font-size: 10px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid #198754;
}

/* CHECKOUT BUTTON */
.btn-checkout {
  display: inline-block;
  padding: 12px 22px;
  font-size: 15px;
  font-weight: 600;
  border-radius: 8px;
  text-decoration: none;
  background: linear-gradient(135deg, #198754, #157347);
  color: #fff;
  border: none;
  transition: all 0.25s ease;
  box-shadow: 0 4px 10px rgba(0,0,0,0.15);
}

.btn-checkout:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 16px rgba(0,0,0,0.2);
}

.btn-checkout:active {
  transform: scale(0.97);
}

</style>
<%- include('../partials/navbar') %>
<%-include ('../partials/breadcrumbs')%>
  </head>

<body>
<div class="container mt-5">

  <h2>Your Cart</h2>

  <% if (items && items.length > 0) { %>

    <% let subtotal = 0 %>
    <% let totalSavings = 0 %>

    <% items.forEach(item => { 

      const price = item.price
      const basePrice = item.basePrice
      const qty = item.quantity

      const itemTotal = price * qty
      subtotal += itemTotal

      const saved = (basePrice - price) * qty
      totalSavings += saved

    %>
    <div id="row-<%= item.variant._id %>"
      class="cart-item d-flex align-items-center mb-4 border-bottom pb-3"
      data-price="<%= price %>"
      data-stock="<%= item.stockQuantity %>"
    >

      <!-- IMAGE -->
      <div class="cart-image">
        <img src="<%= item.variant.images[0] %>" width="80">
      </div>

      <!-- DETAILS -->
      <div class="cart-details flex-grow-1 ms-3">

        <h5><%= item.product.productname %></h5>

        <span class="badge bg-success">⭐ 4.5</span>
        <small>(120 reviews)</small>

        <p class="text-muted">
          Color: <%= item.variant.color %>
        </p>

        <p>Qty: <%= item.quantity %> / Stock: <%= item.stockQuantity %></p>

        <p class="<%= item.isOutOfStock ? 'text-danger' : 'text-success' %>">
          <%= item.isOutOfStock ? 'Out of Stock' : 'Available' %>
        </p>

        <!-- PRICE -->
        <p>
          ₹ <strong><%= price %></strong>

          <% if (basePrice > price) { %>
            <span class="text-muted text-decoration-line-through ms-2">
              ₹ <%= basePrice %>
            </span>
          <% } %>
        </p>

        <p class="text-success">🚚 Delivery in 5-7 days</p>

        <!-- QUANTITY -->
        <div class="qty-control mb-2">

          <button class="btn btn-sm btn-outline-secondary"
            onclick="updateQty('<%= item.variant._id %>', -1)">-</button>

         
          <span id="qty-<%= item.variant._id %>" class="mx-2">
            <%= qty %>
          </span>

          <button class="btn btn-sm btn-outline-secondary"
            onclick="updateQty('<%= item.variant._id %>', 1)"
            <%= qty >= item.variant.stockQuantity ? "disabled" : "" %>>
            +
          </button>

        </div>

        <!-- REMOVE -->
        <button class="btn btn-danger btn-sm"
          onclick="removeItem('<%= item.variant._id %>')">
          Remove
        </button>

      </div>

      <!-- ITEM TOTAL -->
      <div class="text-end">
        <p>Subtotal</p>

        <strong id="itemTotal-<%= item.variant._id %>">
          ₹ <%= itemTotal %>
        </strong>
      </div>

    </div>

    <% }) %>

    <hr>

    <!-- TOTAL SECTION -->
    <div class="text-end">

      <% if (totalSavings > 0) { %>
        <p class="text-success">
          You saved ₹ <%= totalSavings %> 🎉
        </p>
      <% } %>

      <h4>Total: ₹ <span id="grandTotal"><%= subtotal %></span></h4>

      <p class="text-muted small">🔒 100% Secure Payments</p>
      <p class="text-muted small">🔄 7-day easy returns</p>

      <a href="/checkout" class="btn btn-primary <%= outOfStockExist ? 'disabled' : '' %>">
        Proceed to Checkout
      </a>

    </div>

  <% } else { %>

    <!-- EMPTY CART -->
    <div class="text-center mt-5">
      <h4>Your cart is empty</h4>
      <a href="/" class="btn btn-dark mt-3">
        Continue Shopping
      </a>
    </div>

  <% } %>

</div>
<%-include('../partials/footer')%>
<script>

async function updateQty(variantId, change){
  const res = await fetch('/cart/update', {
    method:"POST",
    headers:{
      "Content-Type":"application/json"},
    body: JSON.stringify({ variantId,change }),
    credentials:"include"
  })

  const data = await res.json()
  if(!data.success){
    Swal.fire({
      icon:"warning",
      title:"Stock Limit",
      text:data.message
    })
    return
  }

 if(data.removed){
  document.getElementById(`row-${variantId}`)?.reomove();
 }else{
    document.getElementById(`qty-${variantId}`).innerText = data.quantity;
    document.getElementById(`itemTotal-${variantId}`).innerText ="₹ " + data.itemTotal;
    document.getElementById("grandTotal").innerText ="₹ " + data.grandTotal;
 }

}

async function removeItem(variantId){
const confirm = await Swal.fire({
  title:"Are you sure?",
  text:"Item get removed from your cart.",
  icon:"warning",
  showCancelButton:true,
  confirmButtontext:'Yes,Remove it!'
})
if(!confirm.isConfirmed) return

  const res = await fetch('/cart/remove', {
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body: JSON.stringify({variantId }),credentials:"include"
  })
 const data = await res.json()
   if(data.success){
    Swal.fire({
      icon:"success",
      title:"Removed!",
      text:data.message
    })
    document.getElementById(`row-${variantId}`)?.remove();
    document.getElementById("grandTotal").innerText ="₹ " + data.grandTotal;
  }

}

</script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</body>
</html>