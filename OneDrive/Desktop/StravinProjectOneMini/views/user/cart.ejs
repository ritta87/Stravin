<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title></title>

  <!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
 rel="stylesheet"><link rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

  <style>
   /* ===== NAV ALIGNMENT FIX ONLY ===== */
.nav-left {
  display: flex;
  align-items: center;
  gap: 18px; /* spacing between items */
}

.nav-left a,
.nav-left .dropdown {
  display: flex;
  align-items: center;
}
 
  header {
  background-color: #198754;
  padding: 15px 0;
  box-shadow: 0 2px 6px rgba(0,0,0,0.1);
  position: sticky;
  top: 0;
  z-index: 1000;
}

header .brand {
  font-weight: 700;
  font-size: 1.7rem;
  color: #fff;
}
header nav {
  display: flex;
  align-items: center;
  gap: 30px;
}
header nav a {
  color: #fff;
  font-weight: 500;
  transition: color 0.2s;
  margin-left: 0;
}

header nav a:hover {
  color: #e0e0e0;
}

.cart-link,
.wishlist-nav {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: #fff;
}

.cart-link i,
.wishlist-nav i {
  font-size: 18px;
}

.cart-count,
.wishlist-badge {
  position: absolute;
  top: -8px;
  right: -10px;
  min-width: 18px;
  height: 18px;
  padding: 0 5px;
  border-radius: 50px;
  background: red;
  color: #fff;
  font-size: 10px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid #198754;
}
.btn-checkout {
  display: inline-block;
  padding: 12px 22px;

  font-size: 15px;
  font-weight: 600;

  border-radius: 8px;
  text-decoration: none;

  background: linear-gradient(135deg, #198754, #157347);
  color: #fff;

  border: none;
  transition: all 0.25s ease;

  box-shadow: 0 4px 10px rgba(0,0,0,0.15);
}

/* hover effect */
.btn-checkout:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 16px rgba(0,0,0,0.2);
}

/* click feel */
.btn-checkout:active {
  transform: scale(0.97);
}
.user-btn {
  background: #fff;
  color: #198754;
  border: none;
  padding: 8px 14px;
  border-radius: 6px;
  font-size: 14px;
  cursor: pointer;
  font-weight: 600;
}

.user-btn:hover {
  background: #f1f1f1;
}
/* ===== DROPDOWN POSITION FIX ONLY ===== */
/* FIX hover gap issue */
.dropdown {
  position: relative;
}

/* KEEP dropdown attached */
.dropdown-menu {
  position: absolute;
  top: 100%;   /* remove extra gap */
  right: 0;

  display: none;
  z-index: 999;
}

/* IMPORTANT: keep menu visible when hovering menu itself */
.dropdown:hover .dropdown-menu,
.dropdown-menu:hover {
  display: block;
}
/* ===== DROPDOWN ITEM FEEL ONLY ===== */
.dropdown-item {
  display: block;
  padding: 8px 14px;
  transition: 0.2s ease;
}
</style>
</head>

<header class="d-flex justify-content-between align-items-center px-4">
  <div class="brand">Stravin</div>
 <nav class="d-flex align-items-center gap-4">
    <div class="nav-left">

      <a href="/">Home</a>
      <a href="/shop">Shop</a>
    <a href="/cart" class="cart-link">
     <i class="bi bi-cart3 cart-icon"></i>
      <span id="cartCount" class="cart-count">0</span>
      </a>
    <a href="/wishlist" class="nav-link wishlist-nav position-relative">
      <i class="bi bi-heart"></i>
      <span class="ms-1"></span>
    </a>
      <% if (isLoggedIn) { %>

        <div class="dropdown">
          <button class="dropdown-toggle">
            Hi, <%= user.name %>
          </button>

          <ul class="dropdown-menu">
            <li>
              <a href="/profile" class="dropdown-item">Profile</a>
            </li>
             <li>
              <a href="/orders" class="dropdown-item">My Orders</a>
            </li>
             <li>
              <a href="/logout" class="dropdown-item">Logout</a>
            </li>
          </ul>
        </div>

      <% } else { %>
    <a href="/login">Login</a>
<% } %>
</div></nav>
<script>
  //cart count
async function loadCartCount(){
  try{
    const res = await fetch('/cart/count')
    const data = await res.json()
    const cartEl = document.getElementById('cartCount')
    if(cartEl){
      cartEl.innerText = data.count
    }
  }catch(err){
    console.log("Error fetching cart count",err)
  }
}
document.addEventListener("DOMContentLoaded", loadCartCount)
</script>
</header>

<body>
<div class="container mt-5">
<h2>Your Cart</h2>

<% if(cart.items.length > 0){ %>

<% let subtotal = 0 %>

<% cart.items.forEach(item => { 

  const price = item.product.price
  const qty = item.quantity
  const itemTotal = price * qty
  subtotal += itemTotal

%>

<div class="cart-item d-flex align-items-center mb-4">

  <div class="cart-image">
<img src="<%= item.variant.images[0] %>" width="80">  </div>

  <div class="cart-details flex-grow-1 ms-3">

    <h5><%= item.product.productname %></h5>

    <p class="text-muted">
      Color: <%= item.variant.color %>
    </p>

    <p>
      Price: ₹<%= price %>
    </p>

    <p>
     <div class="qty-control">

    <button class="btn btn-sm btn-outline-secondary"
      onclick="updateQty('<%= item.variant._id %>', -1)">-</button>

    <span class="mx-2"><%= item.quantity %></span>
<button 
  onclick="updateQty('<%= item.variant._id %>',1,this)"
  <%= item.quantity >= item.variant.stockQuantity ? "disabled" : "" %> > + </button>  
 </div>
 </p>
<p>
    <button class="btn btn-danger btn-sm mt-2"
 onclick="removeItem('<%= item.variant._id %>')">
 Remove</button></p>
  </div>

  <div class="text-end">

    <p>Subtotal</p>

    <strong>
      ₹<%= itemTotal %>
    </strong>

  </div>

</div>

<% }) %>

<hr>

<div class="text-end">

<h4>
Total: ₹<%= subtotal %>
</h4>
<% if(cart && cart.items.length > 0){ %>
  <a href="/checkout" class="btn-checkout">Proceed to Checkout</a>
<% } else { %>
  <button disabled class="btn-checkout" style="background: gray;">
    Cart is Empty
  </button>
<% } %>

</div>

<% } else { %>

<div class="text-center mt-5">
  <h4>Your cart is empty</h4>
  <a href="/" class="btn btn-dark mt-3">
  Continue Shopping
  </a>
</div>

<% } %>

</div>
<script>

async function updateQty(variantId, change){
  const res = await fetch('/cart/update', {
    method:"POST",
    headers:{
      "Content-Type":"application/json"},
    body: JSON.stringify({ variantId,change }),
    credentials:"include"
  })

  const data = await res.json()
  if(!data.success){
    Swal.fire({
      icon:"warning",
      title:"Stock Limit",
      text:data.message
    })
    return
  }

  location.reload()

}

async function removeItem(variantId){
const confirm = await Swal.fire({
  title:"Are you sure?",
  text:"Item get removed from your cart.",
  icon:"warning",
  showCancelButton:true,
  confirmButtontext:'Yes,Remove it!'
})
if(!confirm.isConfirmed)return;

  const res = await fetch('/cart/remove', {
    method:"POST",
    headers:{
      "Content-Type":"application/json"},
    body: JSON.stringify({variantId }),credentials:"include"
  })
 const data = await res.json()
   if(data.success){
    Swal.fire({
      icon:"success",
      title:"Removed!",
      text:data.message
    }).then(()=>{
      location.reload()
    })
  }

}

</script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</body>
</html>