<% } %>
</div></nav>
<script>
  //cart count
async function loadCartCount(){
  try{
    const res = await fetch('/cart/count')
    const data = await res.json()
    const cartEl = document.getElementById('cartCount')
    if(cartEl){
      cartEl.innerText = data.count
    }
  }catch(err){
    console.log("Error fetching cart count",err)
  }
}
document.addEventListener("DOMContentLoaded", loadCartCount)
</script>
</header>
<%- include('../partials/breadcrumbs') %>

<body>

<div class="container">
  <h3>Edit Address</h3>

<form id="editAddressForm">
  <input type="hidden" id="addressId" value="<%= address._id %>">    
    <input type="text" name="name" id="name" value="<%= address.name %>" placeholder="Full Name" />

    <input type="text" name="mobile" id="mobile" value="<%= address.mobile %>" placeholder="Mobile Number" />
   <input type="text" name="area" id="area" value="<%= address.area %>" placeholder="Area" />
    
    <input type="text" name="city" id="city" value="<%= address.city %>" placeholder="City" />

    <input type="text" name="state" id="state" value="<%= address.state %>" placeholder="State" />
    <input type="text" id="house" name="house" value="<%= address.house %>" placeholder="House" />
<input type="text" id="address" name="address" value="<%= address.address %>" placeholder="Address" />
<input type="text" id="landmark" name="landmark" value="<%= address.landmark %>" placeholder="Landmark" />

    <input type="text" name="pincode" id="pincode" value="<%= address.pincode %>" placeholder="Pincode"  />
  <select name="addressType" id="addressType">
  <option value="Home" <%= address.addressType === "Home" ? "selected" : "" %>>Home</option>
  <option value="Work" <%= address.addressType === "Work" ? "selected" : "" %>>Work</option>
  <option value="Other" <%= address.addressType === "Other" ? "selected" : "" %>>Other</option>
  </select>
    <button type="submit">Update Address</button>
  </form>

  <a href="/profile/address" class="back-link">← Back to Address List</a>
</div>
<script>
  
document.getElementById("editAddressForm").addEventListener("submit", async (e) => {
  e.preventDefault();

  const name = document.getElementById("name").value.trim();
  const mobile = document.getElementById("mobile").value.trim();
  const area = document.getElementById("area").value.trim();
  const house = document.getElementById("house").value.trim();
const address = document.getElementById("address").value.trim();
const landmark = document.getElementById("landmark").value.trim();
  const city = document.getElementById("city").value.trim();
  const state = document.getElementById("state").value.trim();
  const pincode = document.getElementById("pincode").value.trim();
  const addressType = document.getElementById("addressType").value;

  if (!name || !mobile || !city || !area || !state || !pincode) {
    return Swal.fire("Error", "All fields are required", "error");
  }

  if (!/^[0-9]{10}$/.test(mobile)) {
    return Swal.fire("Error", "Enter valid mobile number", "error");
  }

  if (!/^[0-9]{6}$/.test(pincode)) {
    return Swal.fire("Error", "Enter valid pincode", "error");
  }

  const addressId = document.getElementById("addressId").value;

  const res = await fetch(`/profile/address/edit/${addressId}`, {
    method: "PUT",credentials: "include",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
  name,
  mobile,
  area,
  city,
  state,
  pincode,
  house,
  address,
  landmark,
  addressType
  })
  })

  const data = await res.json();

  if (data.success) {
    Swal.fire({
      icon: "success",
      title: data.message,
      timer: 1500,
      showConfirmButton: false
    })
    setTimeout(()=>{
      window.location.href="/profile/address"
    },1500)
  } else {
    Swal.fire({
      icon: "error",
      title: data.message
    });
  }
})
</script>
</body>
