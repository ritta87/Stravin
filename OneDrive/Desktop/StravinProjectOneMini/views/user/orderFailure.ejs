<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Failure</title>
      <!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>


<style>
    .failure-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 80vh;
  padding: 20px;
}

.failure-box {
  max-width: 500px;
  width: 100%;
  text-align: center;
  padding: 40px 30px;
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
}

.failure-img {
  width: 120px;
  margin-bottom: 20px;
}

h1 {
  color: #ff4d4d;
  margin-bottom: 10px;
}

.sub-text {
  color: #666;
  margin-bottom: 20px;
}

.order-id {
  font-size: 14px;
  margin-bottom: 25px;
  color: #333;
}

.btn-group {
  display: flex;
  justify-content: center;
  gap: 15px;
  flex-wrap: wrap;
}

.retry-btn, .details-btn {
  padding: 10px 20px;
  border-radius: 6px;
  text-decoration: none;
  color: white;
  font-weight: 500;
  transition: 0.3s;
}

.retry-btn {
  background: #ff4d4d;
}

.retry-btn:hover {
  background: #e60000;
}

.details-btn {
  background: #333;
}

.details-btn:hover {
  background: #000;
}
</style></head>
<body>
    <div class="failure-container">

  <div class="failure-box">

    <!-- Illustration -->

    <!-- Message -->
    <h1>Payment Failed ❌</h1>
    <p class="sub-text">
      Oops! Your transaction couldn’t be completed.
      Don’t worry — you can try again or check your order details.
    </p>

    <% if (orderId) { %>
      <p class="order-id">
        Order ID: <strong><%= orderId %></strong>
      </p>
    <% } %>

    <div class="btn-group">

<button onclick="retry('<%= orderId %>')" class="retry-btn">
  🔄 Retry Payment
</button>

      <a href="/orders/<%= orderId %>" class="details-btn">
        📄 View Order Details
      </a>

    </div>

  </div>

</div>
<script>
async function retry(orderId) {
  const res = await fetch(`/retryPayment/${orderId}`,
 { method:"POST" })

  const data = await res.json();

  if (!data.success) {
    Swal.fire("Error", "Retry failed","error");
    return;
  }

  const options = {
    key: "<%= razorpayKey %>",
    amount: data.razorpay.amount,
    currency: "INR",
    order_id: data.razorpay.id,
    handler: async function (response) {
      const verifyRes = await fetch("/verifyPayment", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          razorpay_order_id: response.razorpay_order_id,
          razorpay_payment_id: response.razorpay_payment_id,
          razorpay_signature: response.razorpay_signature,
          orderId: orderId
        })
      });

      const verifyData = await verifyRes.json();
      if (verifyData.success) {
        window.location.href = `/orderSuccess/${orderId}`;
      } else {
        window.location.href = `/orderFailure/${orderId}`;
      }
    }
  };

  const rzp = new Razorpay(options);
  rzp.open();
}
</script>
</body>
</html>