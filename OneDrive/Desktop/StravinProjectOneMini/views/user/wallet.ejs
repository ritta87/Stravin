<!DOCTYPE html>
<html lang="en">
  <head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<link rel="stylesheet" href="/css/navbar.css">
<link rel="stylesheet" href="/css/pages/footer.css">

<script src="/js/navbar.js"></script>

<style>
/* ===== Wallet Page Area Only ===== */
.wallet-page {
  max-width: 1100px;
  margin: 35px auto 50px;
  padding: 0 20px;
}

.wallet-card {
  background: #ffffff;
  border-radius: 20px;
  padding: 28px;
  box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
}

/* ===== Breadcrumb inside wallet area ===== */
.wallet-breadcrumb {
  margin-bottom: 18px;
  font-size: 15px;
  color: #64748b;
}

.wallet-breadcrumb a {
  color: #198754;
  text-decoration: none;
  font-weight: 500;
}

.wallet-breadcrumb a:hover {
  text-decoration: underline;
}

/* ===== Title ===== */
.wallet-title {
  font-size: 2rem;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 20px;
}

/* ===== Balance Card ===== */
.wallet-balance-box {
  background: linear-gradient(135deg, #198754, #146c43);
  border-radius: 18px;
  padding: 24px 26px;
  color: #fff;
  margin-bottom: 24px;
  box-shadow: 0 12px 28px rgba(25, 135, 84, 0.2);
}

.wallet-balance-box p {
  margin: 0;
  font-size: 0.95rem;
  opacity: 0.9;
}

.wallet-balance-box h2 {
  margin: 8px 0 0;
  font-size: 2rem;
  font-weight: 700;
  color: #fff;
}

/* ===== Add Money Section ===== */
.wallet-form-box {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 16px;
  padding: 22px;
  margin-bottom: 28px;
}

.wallet-form-box h3 {
  margin: 0 0 16px;
  font-size: 1.2rem;
  color: #1e293b;
  font-weight: 700;
}

.form-group {
  max-width: 420px;
  margin-bottom: 14px;
}

.form-group label {
  display: block;
  margin-bottom: 8px;
  font-size: 0.95rem;
  font-weight: 600;
  color: #334155;
}

#amount {
  width: 100%;
  padding: 13px 14px;
  border: 1px solid #cbd5e1;
  border-radius: 12px;
  font-size: 15px;
  background: #fff;
  transition: all 0.25s ease;
}

#amount:focus {
  border-color: #198754;
  outline: none;
  box-shadow: 0 0 0 4px rgba(25, 135, 84, 0.12);
}

.wallet-btn,
.wallet-form-box button,
button[type="submit"] {
  background: linear-gradient(135deg, #198754, #157347);
  color: #fff;
  border: none;
  border-radius: 12px;
  padding: 12px 22px;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.25s ease;
  box-shadow: 0 8px 18px rgba(25, 135, 84, 0.18);
}

.wallet-btn:hover,
.wallet-form-box button:hover,
button[type="submit"]:hover {
  transform: translateY(-2px);
  box-shadow: 0 14px 26px rgba(25, 135, 84, 0.24);
}

.wallet-btn:active,
.wallet-form-box button:active,
button[type="submit"]:active {
  transform: scale(0.98);
}

/* ===== Error ===== */
.error-msg {
  display: block;
  margin-top: 6px;
  color: #dc2626;
  font-size: 13px;
}

input.error {
  border: 1px solid #dc2626 !important;
  background: #fff7f7;
}

/* ===== Wallet History ===== */
.wallet-history-title {
  font-size: 1.5rem;
  font-weight: 700;
  color: #1e293b;
  margin: 0 0 16px;
}

.wallet-table-wrapper {
  overflow-x: auto;
  border-radius: 16px;
  background: #fff;
  border: 1px solid #e5e7eb;
  box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
}

.wallet-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 700px;
}

.wallet-table th {
  background: #1e293b;
  color: #fff;
  padding: 15px 18px;
  text-align: left;
  font-size: 14px;
  font-weight: 600;
}

.wallet-table td {
  padding: 15px 18px;
  border-bottom: 1px solid #e5e7eb;
  font-size: 14px;
  color: #334155;
}

.wallet-table tr:nth-child(even) {
  background: #f8fafc;
}

.wallet-table tr:hover {
  background: #eefbf3;
  transition: background 0.2s ease;
}

/* ===== Empty row / empty history ===== */
.wallet-empty {
  text-align: center;
  padding: 22px;
  color: #64748b;
  font-size: 15px;
}

/* ===== Status badges ===== */
.status-credit,
.status-added,
.status-success {
  display: inline-block;
  padding: 6px 12px;
  border-radius: 999px;
  background: #dcfce7;
  color: #166534;
  font-size: 12px;
  font-weight: 600;
}

.status-debit,
.status-spent,
.status-failed {
  display: inline-block;
  padding: 6px 12px;
  border-radius: 999px;
  background: #fee2e2;
  color: #991b1b;
  font-size: 12px;
  font-weight: 600;
}

/* ===== Responsive ===== */
@media (max-width: 768px) {
  .wallet-page {
    margin: 24px auto 35px;
    padding: 0 14px;
  }

  .wallet-card {
    padding: 18px;
    border-radius: 16px;
  }

  .wallet-title {
    font-size: 1.6rem;
  }

  .wallet-balance-box {
    padding: 18px;
  }

  .wallet-balance-box h2 {
    font-size: 1.6rem;
  }

  .wallet-form-box {
    padding: 16px;
  }

  .form-group {
    max-width: 100%;
  }

  .wallet-history-title {
    font-size: 1.25rem;
  }

  .wallet-table th,
  .wallet-table td {
    padding: 12px 14px;
    font-size: 13px;
  }
}
</style>
<%- include('../partials/navbar') %>
<%-include ('../partials/breadcrumbs')%></head>
<body>
<div class="wallet-page">
  <div class="wallet-card">
    
    <div class="wallet-balance">
      <p>Current Balance</p>
      <span id="wallet-balance">₹0</span>
    </div>

    <div class="wallet-form-box">
      <h3>Add Money</h3>

      <div class="form-group">
        <p id="msg" class="wallet-msg"></p>

        <input type="number" id="amount" placeholder="Enter amount">
        <small class="error-msg" id="amountError"></small>
      </div>

      <button class="wallet-btn" onclick="addMoney()">Add Money</button>
    </div>

    <h3 class="wallet-history-title">Wallet History</h3>

    <div class="wallet-table-wrapper">
      <table class="wallet-table">
        <thead>
          <tr>
            <th>Amount</th>
            <th>Type</th>
            <th>Reason</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% if (user.walletHistory.length > 0) { %>
            <% user.walletHistory.forEach(item => { %>
              <tr>
                <td>₹<%= item.amount %></td>
                <td>
                  <span class="<%= item.type === 'credit' ? 'status-credit' : 'status-debit' %>">
                    <%= item.type %>
                  </span>
                </td>
                <td><%= item.reason %></td>
                <td><%= item.date.toDateString() %></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="4" class="wallet-empty">No wallet history available yet.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

  </div>
</div>
<%-include('../partials/footer')%>

<script>
function openRazorpay(order, amount) {

  const options = {
    key: "<%= process.env.RAZORPAY_KEY_ID %>",

    amount: order.amount,
    currency: "INR",
    name: "Stravin Wallet",

    order_id: order.id,

    handler: async function (response) {

      await verifyPayment(response, amount);
    }
  };

  const rzp = new Razorpay(options);
  rzp.open()
}


async function addMoney() {
  const error=document.getElementById("amountError")
  error.innerText=""
  document.getElementById("msg").innerText = "";

  if(!validateAmount()) return;
  
  const amount = document.getElementById("amount").value;

  const res = await fetch("/createWalletPayment", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({amount})
  });

  const data = await res.json();
  console.log(data)
  if (data.success) {
    openRazorpay(data.order, amount);
  }
}


async function verifyPayment(response, amount) {

  const res = await fetch("/verifyWalletPayment", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"},
    body: JSON.stringify({
      ...response,
      amount
    })
  })

  const data = await res.json();
  const msg= document.getElementById("msg")
  if (data.success) {
    document.getElementById("wallet-balance").innerText = `₹${data.balance}`;
    msg.style.color="green"
    msg.innerText="Money Added to Wallet Successfully!"
    document.getElementById("wallet-balance").innerText = `₹${data.balance}`;
      await loadWalletHistory();

  } else {
    msg.style.color="red"
    msg.innerText="Failed to add money in wallet"
    
  }
}



function validateAmount() {
  const amountInput = document.getElementById("amount")
  const error = document.getElementById("amountError")

  // reset
  error.textContent = "";
  amountInput.classList.remove("error")

  const amount = Number(amountInput.value)

  if (amountInput.value.trim() === "") {
    error.textContent = "Amount is required";
    amountInput.classList.add("error");
    return false
  }

  if (isNaN(amount) || amount <= 0) {
    error.textContent = "Enter a valid amount";
    amountInput.classList.add("error");
    return false
  }

  if (amount > 100000) {
    error.textContent = "Maximum allowed is ₹1,00,000";
    amountInput.classList.add("error");
    return false
  }

  return true
}


async function loadWalletHistory() {
  const res = await fetch("/wallet/net-balance");
  const data = await res.json();

  if (data.success) {
    const container = document.getElementById("wallet-history");
    container.innerHTML = data.history
      .map(h => `<div>${new Date(h.date).toLocaleString()}: ${h.type === 'credit' ? '+' : '-'}₹${h.amount} (${h.reason})</div>`)
      .join("");
  }
}

//net balance..
async function loadWallet() {
  const res = await fetch("getWalletBalance")
  const data = await res.json();
  if (data.success) {
   document.getElementById("wallet-balance").innerText = `₹${data.balance}`;
   
  }
}
window.onload = loadWallet;

</script>
</body>

</html>