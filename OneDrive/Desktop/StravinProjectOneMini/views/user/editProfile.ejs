<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<link rel="stylesheet" href="/css/navbar.css">
<link rel="stylesheet" href="/css/pages/footer.css">

<script src="/js/navbar.js"></script>

<style>
 .edit-profile-container {
  max-width: 650px;
  margin: 40px auto;
  padding: 30px;
  background: #fff;
  border-radius: 18px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
}

.edit-profile-container h2,
.email-otp-container h3 {
  text-align: center;
  margin-bottom: 22px;
  color: #222;
  font-weight: 700;
}

.edit-profile-container label {
  display: block;
  margin-bottom: 8px;
  font-weight: 600;
  color: #444;
}

.edit-profile-container input[type="text"],
.edit-profile-container input[type="email"],
.edit-profile-container input[type="tel"] {
  width: 100%;
  padding: 12px 14px;
  margin-bottom: 16px;
  border: 1px solid #d8d8d8;
  border-radius: 10px;
  font-size: 14px;
  background: #fafafa;
  box-sizing: border-box;
  transition: 0.25s ease;
}

.edit-profile-container input:focus,
.email-otp-container input:focus {
  outline: none;
  border-color: #198754;
  background: #fff;
  box-shadow: 0 0 0 3px rgba(25, 135, 84, 0.12);
}

.file-input-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
}

.file-input-wrapper input[type="file"] {
  display: none;
}

#preview {
  width: 130px;
  height: 130px;
  object-fit: cover;
  border-radius: 50%;
  border: 3px solid #e5e5e5;
  background: #f8f8f8;
}

.choose-btn,
.remove-btn,
.update-btn,
.email-otp-container button {
  border: none;
  border-radius: 10px;
  padding: 11px 16px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: 0.25s ease;
}

.choose-btn {
  background: #198754;
  color: #fff;
}

.choose-btn:hover {
  background: #157347;
}

.remove-btn {
  background: #dc3545;
  color: #fff;
}

.remove-btn:hover {
  background: #bb2d3b;
}

.update-btn {
  width: 100%;
  margin-top: 10px;
  background: #198754;
  color: #fff;
}

.update-btn:hover {
  background: #157347;
}

.email-otp-container {
  max-width: 650px;
  margin: 25px auto 40px;
  padding: 25px;
  background: #fff;
  border-radius: 18px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
}

.email-otp-container input[type="email"],
.email-otp-container input[type="text"] {
  width: 100%;
  padding: 12px 14px;
  margin-bottom: 14px;
  border: 1px solid #d8d8d8;
  border-radius: 10px;
  font-size: 14px;
  background: #fafafa;
  box-sizing: border-box;
}

.email-otp-container .send-btn {
  background: #0d6efd;
  color: #fff;
}

.email-otp-container .send-btn:hover {
  background: #0b5ed7;
}

.email-otp-container .verify-btn {
  background: #198754;
  color: #fff;
}

.email-otp-container .verify-btn:hover {
  background: #157347;
}

#otpSection {
  display: none;
  margin-top: 15px;
  padding: 15px;
  border-radius: 12px;
  background: #f8f9fa;
}

.info-text {
  font-size: 12px;
  color: #777;
  text-align: center;
}

.error {
  color: red;
  font-size: 13px;
  margin-top: 4px;
  display: block;
}

input.error-input {
  border: 1px solid red;
}

@media (max-width: 768px) {
  .edit-profile-container,
  .email-otp-container {
    margin: 20px 15px;
    padding: 20px;
  }

  #preview {
    width: 110px;
    height: 110px;
  }

  .choose-btn,
  .remove-btn,
  .update-btn,
  .email-otp-container button {
    width: 100%;
  }
}
</style>

 <%- include('../partials/navbar') %>
  <%- include('../partials/breadcrumbs') %>
</head>

<body>
<div class="edit-profile-container">

<h2>Edit Profile</h2>

<!-- Form for basic info & profile pic -->
<form id="editProfileForm" enctype="multipart/form-data">
  <div>
    <label>Name:</label>
    <input type="text" name="name" id="name" value="<%= user.name %>" >
     </div>

  <div>
    <label>Mobile:</label>
    <input type="text" name="mobile" id="mobile" 
    value="<%= user.mobile %>" placeholder="mobile">
  </div>

  <div class="file-input-wrapper">
  <label>Profile Picture:</label>
  
  <img id="preview" src="<%= user.profileImage || '/images/default-profile.png' %>">
  
  <input type="file" id="profileImage" name="profileImage"
   accept="image/*" onchange="previewImage(event)">
   <button type="button" class="choose-btn" onclick=
  "document.getElementById('profileImage').click();">
  Choose File</button>
  <button type="button" class="remove-btn" onclick="removeImage()">Remove</button>
  <input type="hidden" name="removePic" id="removePic" value="">
</div>

<button type="submit" class="update-btn">Update Profile</button>
</form>

<hr>

<!-- Email change with OTP -->
<div class="email-otp-container">

  <h3>Change Email</h3>

  <div class="otp-row">
    <input type="email" id="newEmail" placeholder="Enter new email">
    <button type="button" class="send-btn" onclick="sendOTP()">Send OTP</button>
  </div>

  <div id="otpSection">
    <input type="text" id="emailOTP" placeholder="Enter OTP">
    <button type="button" class="verify-btn" onclick="verifyEmailOTP()">Verify OTP</button>
  </div>

  <div class="info-text">
    Email change requires OTP verification
  </div>

</div>
</div>
</div>
<%-include('../partials/footer')%>
<script>
 document.getElementById("editProfileForm").addEventListener('submit', async (e) => {
  e.preventDefault();

  const name = document.getElementById("name").value.trim();
  const mobile = document.getElementById("mobile").value.trim();
  const file = document.getElementById("profileImage").files[0];

  if (name === "" || name.length < 3) {
    return Swal.fire({
      icon: "error",
      title: "Invalid Name",
      text: "Name must be at least 3 characters"
    });
  }

  const mobileRegex = /^[0-9]{10}$/;
  if (!mobileRegex.test(mobile)) {
    return Swal.fire({
      icon: "error",
      title: "Invalid Mobile",
      text: "Enter 10 digit number"
    });
  }

  if (file) {
    const allowedTypes = ["image/jpeg", "image/png", "image/jpg", "image/webp"];
    const maxSize = 2 * 1024 * 1024;

    if (!allowedTypes.includes(file.type)) {
      return Swal.fire({
        icon: "error",
        title: "Invalid Image",
        text: "Only JPG, PNG, WEBP allowed"
      });
    }

    if (file.size > maxSize) {
      return Swal.fire({
        icon: "error",
        title: "Image Too Large",
        text: "Max size is 2MB"
      });
    }
  }

  const formData = new FormData(e.target);
  try {
    const res = await fetch("/profile/edit", {
      method: "POST",
      body: formData
    });

    const data = await res.json();

    if (data.success) {
      Swal.fire({
        icon: "success",
        title: "Updated!",
        text: "Profile updated successfully",
        timer: 1500,
        showConfirmButton: false
      });

      setTimeout(() => {
        window.location.href = "/profile";
      }, 1500);

    } else {
      Swal.fire("Error", data.message, "error");
    }

  } catch (error) {
    Swal.fire("Error", "Something went wrong", "error");
  }
});
  function previewImage(event) {
  const file = event.target.files[0];
  const preview = document.getElementById("preview");
const originalImage=document.getElementById("preview").src;
  if (!file) return;

  const allowedTypes = ["image/jpeg", "image/png", "image/jpg", "image/webp"];
  const maxSize = 2 * 1024 * 1024; // 2MB

  
  if (!allowedTypes.includes(file.type)) {
    Swal.fire({
      icon: "error",
      title: "Invalid Image",
      text: "Only JPG, PNG, WEBP allowed"
    });

    event.target.value = ""; // reset input
    preview.src = originalImage
    return;
  }

  // large
  if (file.size > maxSize) {
    Swal.fire({
      icon: "error",
      title: "Image Too Large",
      text: "Max size is 2MB"
    });

    event.target.value = "";
    preview.src =originalImage
    return;
  }

  //Show preview
  const reader = new FileReader();
  reader.onload = function(e) {
    preview.src = e.target.result;
  };
  reader.readAsDataURL(file);
}
function removeImage() {
  const preview = document.getElementById('preview');
  preview.src = '/images/default-profile.png'; 
  document.getElementById('profileImage').value = ''; 
  document.getElementById('removePic').value = 'true'; 
}
//otp verification--------------------------------------------
async function sendOTP(){
const email = document.getElementById("newEmail").value.trim()
if(!email){
  return Swal.fire("error","Enter email id","error")
}
const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
if(!emailRegex.test(email)){
 return Swal.fire("error","Invalid email format.","error")
}
try{

  const res=await fetch('/profile/send-email-otp',{
    method:"POST",
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({email})
  })
  const data=await res.json()
  if(data.success){
    Swal.fire("success","OTP sent to your Email!","success")
  }
  document.getElementById("otpSection").style.display = "block";

}

catch(error){
console.log(error)
Swal.fire("error","Errro while sending otp","error")
}
}

async function verifyEmailOTP() {
  const email = document.getElementById('newEmail').value.trim();
  const otp = document.getElementById('emailOTP').value.trim();

  if (!otp) {
    Swal.fire('Validation', 'Enter the OTP', 'error');
    return;
  }

  try {
    const res = await fetch('/profile/verify-email-otp', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, otp })
    })

const data = await res.json();
if (data.success) {
  Swal.fire({
    icon:'success',
    title:'Verified!',
    text: data.message
  })
  .then(() => {
    window.location.href = "/profile";
  })
} else {
      Swal.fire('Oops!',data.message||'OTP verification failed','error')
    }

  } catch (err) {
    console.error(err);
    Swal.fire('Error','Something went wrong','error');
  }
}


</script>
</body>

</html>