<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset Password | Stravin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>
<body class="bg-light">

<div class="container mt-5">
  <div class="col-md-4 mx-auto p-4 shadow bg-white rounded">

    <h3 class="text-center mb-3">Reset Password</h3>
    <p class="text-muted text-center">Enter OTP and set your new password</p>

    <input type="hidden" id="resetEmail" name="resetEmail" value="<%= resetEmail %>">

    <div class="mb-3">
      <label class="form-label">OTP</label>
      <input type="text" id="otp" class="form-control" placeholder="Enter OTP">
    </div>

    <div class="mb-3">
      <label class="form-label">New Password</label>
      <input type="password" name="newPassword" id="newPassword" class="form-control" placeholder="New password">
       <small id="passwordMessage" class="text-danger">
     Password must be at least 6 characters, contain one uppercase letter and one number
     </small>
    </div>

    <div class="mb-3">
      <label class="form-label">Confirm Password</label>
      <input type="password" name="confirmNewPassword" id="confirmNewPassword" class="form-control" placeholder="Confirm password">
    </div>

    <button id="resetBtn" class="btn btn-success w-100">Reset Password</button>

  </div>
</div>
<script>
    document.getElementById('resetBtn').addEventListener('click',async()=>{
        const email=document.getElementById('resetEmail').value
        const otp=document.getElementById('otp').value.trim()
        const newPassword=document.getElementById('newPassword').value.trim()
        const confirmNewPassword=document.getElementById('confirmNewPassword').value.trim()
        if(!otp||!newPassword||!confirmNewPassword){
            return Swal.fire("Error occured","All fields are required!")
        }
        if(!/^(?=.*[A-Za-z])(?=.*\d).{6,}$/.test(newPassword)){
        return Swal.fire("Error","Password must be at least 6 characters and contain one uppercase letter and one number","error")
        }
        if(newPassword!==confirmNewPassword){
        return Swal.fire("Mismatch!","Password must match!","error")
        }
        try {
        const res = await fetch('/resetPassword', {
            method: "POST",
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, otp, newPassword, confirmNewPassword })
        });

        const data = await res.json();

        
        if (data.success) {
            Swal.fire("Success", data.message, "success");
            return setTimeout(() => {
                window.location.href = "/login";
            }, 1200);
        }

        // OTP expired
        if (data.message === 'OTP has expired') {

            return Swal.fire({
                title: "OTP Expired!",
                text: "Your OTP has expired. Do you want to resend a new OTP?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: "Resend OTP",
                cancelButtonText: "Cancel"
            }).then(async (result) => {

                if (result.isConfirmed) {

                    const resendReq = await fetch('/forgotPassword', {
                        method: "POST",
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email })
                    });

                    const resendRes = await resendReq.json();

                    if (resendRes.success) {
                        Swal.fire("New OTP Sent!", "Check your email for the new OTP", "success");

                 // redirect back to reset page with same email
                setTimeout(() => {
                 window.location.href = `/resetPassword?email=${email}`;
                }, 1200);

                    } else {
                        Swal.fire("Error", resendRes.message, "error");
                    }
                }
            });
        }
        Swal.fire("Error", data.message, "error");

    } catch (error) {
        console.log(error);
        Swal.fire("Error", "Something went wrong!", "error");
    }
});
</script>


</body>
</html>