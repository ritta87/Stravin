<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<link rel="stylesheet" href="/css/navbar.css">
<link rel="stylesheet" href="/css/pages/footer.css">

<script src="/js/navbar.js"></script>
<style>
.address-card {
  background: #fff;
  border-radius: 16px;
  padding: 22px;
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
  position: relative;
  transition: all 0.25s ease;
  height: 100%;
  border: 1px solid #ececec;
}

.address-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
}

.address-card.default {
  border: 2px solid #198754;
  background: #f4fff8;
}

.address-actions {
  margin-top: 16px;
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.address-card button,
.address-card a.add-btn,
.address-card a.edit-btn,
.address-card .delete-btn,
.address-card .default-btn {
  padding: 9px 16px;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-size: 14px;
  font-weight: 500;
  transition: all 0.25s ease;
  text-decoration: none;
  display: inline-block;
}

.address-card a.edit-btn {
  background-color: #3498db;
  color: #fff;
}

.address-card a.edit-btn:hover {
  background-color: #2980b9;
}

.address-card .delete-btn {
  background-color: #e74c3c;
  color: #fff;
}

.address-card .delete-btn:hover {
  background-color: #c0392b;
}

.address-card .default-btn {
  background-color: #198754;
  color: #fff;
}

.address-card .default-btn:hover {
  background-color: #157347;
}

.address-card.default .default-btn {
  background-color: #157347;
  cursor: default;
  opacity: 0.95;
}

.add-btn {
  background-color: #f39c12;
  color: #fff;
  padding: 10px 18px;
  border-radius: 8px;
  text-decoration: none;
  display: inline-block;
  font-weight: 500;
  transition: all 0.25s ease;
  margin-bottom: 18px;
}

.add-btn:hover {
  background-color: #d35400;
} 
</style>

 <%- include('../partials/navbar') %>
  <%- include('../partials/breadcrumbs') %>
</head>

<body>

<div class="container address-wrapper">
<h3 class="page-title">Manage Addresses</h3>

<a href="/profile/address/add">Add new Address</a>

<div class="row">

<% if(addresses.length > 0){ %>
<% addresses.forEach(address => { %>
<div class="col-md-6">
<div class="address-card" data-id="<%= address._id %>">



<h6><%= address.addressType %></h6>
<p class="mb-1"><strong><%= address.name %></strong></p>

<p class="mb-1">
<%= address.house %>, <%= address.area %>
</p>

<p class="mb-1">
<%= address.city %>, <%= address.state %>
</p>

<p class="mb-1">
<%= address.pincode %>
</p>

<p>
Phone: <%= address.mobile %>
</p>

<a href="/profile/address/edit/<%=address._id%>" class="edit-btn" 
  data-id="<%=address._id%>">
  Edit</a>

 <button class="delete-btn" data-id="<%=address._id%>">Delete</button> 


<button class="default-btn" data-id="<%=address._id%>">
  <% if(address.isDefault){%>
Set As Default
 <% }else{%>
Default
 <%}%>
</button>
</div></div>
<% }) %>
<% } else { %>
<p>No address added yet.</p>
<% } %>
</div>
<%-include('../partials/footer')%>
<script>
 //delete btn
 document.querySelectorAll('.delete-btn').forEach(btn=>{
  btn.addEventListener('click',async()=>{
    const addressId = btn.dataset.id;

    const result=await Swal.fire({
      title: 'Are you sure?',
      text: "This address will be deleted permanently!",
      icon: 'warning',
      showCancelButton: true,
      confirmButtonText: 'Yes, delete it!'
    })
    if(result.isConfirmed){
   try{
      const res = await fetch(`/profile/address/delete/${addressId}`,{
        method:"DELETE"
      })
      const data=await res.json()

      if(data.success){
      btn.closest('.address-card').remove()
      Swal.fire("Deleted","Address deleted successfully","success")
      }else{
        Swal.fire("error","Cant delete Address","error")
      }


    }catch(error){
      console.log(error)
      res.json({success:false,message:"Error while deleting address"})
    }
  }
  })
 })


document.addEventListener("DOMContentLoaded", () => {
  document.querySelectorAll(".default-btn").forEach(btn => {
    btn.addEventListener("click", async () => {
      const addressId = btn.dataset.id;

      const result = await Swal.fire({
        title: 'Set as default?',
        text: "This address will become your default address!",
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Yes, set default!'
      });

      if (!result.isConfirmed) return;
      try {
        const res = await fetch(`/profile/address/default/${addressId}`, {
          method: "PUT",
          headers: { "Content-Type": "application/json" }
        })
        const data = await res.json()

       if (data.success) {
          // remove default class and reset button text for other address
          document.querySelectorAll(".address-card").forEach(card => {
            card.classList.remove("default");
            const btn = card.querySelector(".default-btn");
            if (btn) btn.innerText = "Set as Default";
          });

         // add default class
          const selectedCard = document.querySelector(`.address-card[data-id='${addressId}']`);
          selectedCard.classList.add("default");
          selectedCard.querySelector(".default-btn").innerText = "Default";

          Swal.fire('Success','Default address updated!','success');
        } else {
          Swal.fire('Error','Failed to set default','error');
        }
      } catch (err) {
        console.log(err);
        Swal.fire('Error','Something went wrong','error');
      }
    });
  });
});



document.addEventListener("DOMContentLoaded",()=>{
  document.querySelectorAll('edit-btn').addEventListener('click',async(e)=>{
    e.preventDefault()
    const addressId=req.dataset.id;
    window.location.href=`/profile/address/edit/${addressId}`,{
    method:"POST",
    "Content-Type":"application/json"
    }
  })
})


</script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>
</html>