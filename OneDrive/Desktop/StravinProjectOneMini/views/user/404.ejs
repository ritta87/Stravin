<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Page Not Found | Stravin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: #f7f7f7;
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100vh;
    }

    .notfound-container {
      text-align: center;
      background: #fff;
      padding: 50px;
      border-radius: 12px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
      max-width: 420px;
      width: 100%;
    }

    h1 {
      font-size: 72px;
      margin: 0;
      color: #000;
    }

    h2 {
      margin: 10px 0;
      font-size: 22px;
    }

    p {
      color: #666;
      margin-bottom: 25px;
    }

    a {
      display: inline-block;
      padding: 12px 22px;
      background: #000;
      color: #fff;
      text-decoration: none;
      border-radius: 6px;
      font-weight: 500;
    }

    a:hover {
      opacity: 0.85;
    }
  </style>
</head>

<body>

  <div class="notfound-container">
    <h1>404</h1>
    <h2>Page Not Found</h2>
    <p>The page you are looking for doesn't exist or was moved.</p>

    <a href="/">Go to Home</a>
  </div>

</body>
</html>
