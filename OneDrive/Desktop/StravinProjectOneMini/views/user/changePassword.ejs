<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Change Password</title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-p3ZAtx2GpVEmc2v2t3qfCQ63Eh0W3hQ9F4UjK0kT8ka8G1eU6Z2V0F5x5txOXVf4" crossorigin="anonymous">

  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

  <!-- SweetAlert -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<style>
 /* ===== HEADER (same feel as cart) ===== */
/* ===== GLOBAL RESET ===== */
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #f5f6f7;
}

/* ===== HEADER ===== */
header {
  background-color: #198754;
  padding: 14px 30px;
  display: flex;
  align-items: center;
  overflow: visible;
  box-shadow: 0 2px 6px rgba(0,0,0,0.1);
}

/* logo */
.brand {
  font-weight: 700;
  font-size: 1.6rem;
  color: #fff;
}

/* move nav to right */
.nav-bar {
  margin-left: auto;
}

/* nav items */
.nav-left {
  display: flex;
  align-items: center;
  gap: 25px;
}

/* links */
.nav-left a {
  color: #fff;
  text-decoration: none;
  font-weight: 500;
  transition: 0.2s;
}

.nav-left a:hover {
  color: #e0e0e0;
}

/* ===== CART ===== */
.cart-link {
  position: relative;
  display: flex;
  align-items: center;
}

.cart-icon {
  font-size: 20px;
  color: #fff;
}

.cart-count {
  position: absolute;
  top: -6px;
  right: -10px;

  min-width: 18px;
  height: 18px;

  background: red;
  color: #fff;

  font-size: 10px;
  font-weight: 600;

  display: flex;
  align-items: center;
  justify-content: center;

  border-radius: 50%;
  border: 2px solid #198754;
}

/* ===== DROPDOWN FIX (FINAL) ===== */
.dropdown {
  position: relative;
}

/* button */
.dropdown-toggle {
  background: none;
  border: none;
  color: #fff;
  font-weight: 500;
  cursor: pointer;
}

/* menu */
.dropdown-menu {
  display: none;
  position: absolute;

  top: 100%;
  left: 0; /* 🔥 change from right:0 → fixes visibility */

  background: #ffffff;
  min-width: 180px;

  padding: 8px 0;
  margin-top: 5px;

  list-style: none;

  border-radius: 8px;
  border: 1px solid #ddd;

  box-shadow: 0 8px 20px rgba(0,0,0,0.2);

  z-index: 99999; /* 🔥 force top layer */
}

/* show */
.dropdown:hover .dropdown-menu {
  display: block;
}

/* items */
.dropdown-menu li {
  width: 100%;
}

.dropdown-item {
  display: block;
  width: 100%;

  padding: 10px 16px;

  color: #222;
  text-decoration: none;
  font-size: 14px;
}

/* hover */
.dropdown-item:hover {
  background: #f1f1f1;
}
/* ===== PASSWORD SECTION ===== */
.change-password-container {
  max-width: 420px;
  margin: 60px auto;
  padding: 30px;

  background: #fff;
  border-radius: 10px;

  box-shadow: 0 4px 20px rgba(0,0,0,0.1);
}

/* heading */
.change-password-container h2 {
  text-align: center;
  margin-bottom: 25px;
}

/* labels */
.form-label {
  font-weight: 500;
  margin-bottom: 5px;
  display: block;
}

/* inputs */
.form-control {
  width: 100%;
  padding: 10px;
  border-radius: 6px;
  border: 1px solid #ccc;
  margin-bottom: 15px;
}

/* button */
.btn-primary {
  background: #198754;
  border: none;
  padding: 10px;
  font-weight: 600;
  border-radius: 6px;
  cursor: pointer;
}

.btn-primary:hover {
  background: #157347;
}
</style>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
<header class="d-flex justify-content-between align-items-center px-4">
  <div class="brand">Stravin</div>
 <nav class="nav-bar">
    <div class="nav-left">

      <a href="/">Home</a>
      <a href="/shop">Shop</a>
    <a href="/cart" class="cart-link">
     <i class="bi bi-cart3 cart-icon"></i>
     <span id="cartCount" class="cart-count">0</span>
      </a>

      <% if (isLoggedIn) { %>

        <div class="dropdown">
          <button class="dropdown-toggle">
            Hi, <%= user.name %>
          </button>
           <ul class="dropdown-menu">
            <li>
              <a href="/profile" class="dropdown-item">Profile</a>
            </li>
             <li>
              <a href="/orders" class="dropdown-item">My Orders</a>
            </li>
             <li>
              <a href="/logout" class="dropdown-item">Logout</a>
            </li>
          </ul>
          </div>

      <% } else { %>
    <a href="/login">Login</a>
<% } %>
</div></nav>
<script>
  //cart count
async function loadCartCount(){
  try{
    const res = await fetch('/cart/count')
    const data = await res.json()
    const cartEl = document.getElementById('cartCount')
    if(cartEl){
      cartEl.innerText = data.count
    }
  }catch(err){
    console.log("Error fetching cart count",err)
  }
}
document.addEventListener("DOMContentLoaded", loadCartCount)
</script>
</header>

<div class="change-password-container">
  <h2>Change Password</h2>

  <form id="changePasswordForm">
    <div class="mb-3">
      <label for="currentPassword" class="form-label">Current Password:</label>
      <input type="password" class="form-control" id="currentPassword" placeholder="Enter current password">
    </div>

    <div class="mb-3">
      <label for="newPassword" class="form-label">New Password:</label>
      <input type="password" class="form-control" id="newPassword" placeholder="Enter new password">
    </div>

    <div class="mb-3">
      <label for="confirmPassword" class="form-label">Confirm New Password:</label>
      <input type="password" class="form-control" id="confirmPassword" placeholder="Confirm new password" >
    </div>

    <button type="submit" class="btn btn-primary w-100">Change Password</button>
  </form>
</div>

<script>
document.getElementById('changePasswordForm')
.addEventListener('submit', async (event) => {
  event.preventDefault();

  const currentPassword = document.getElementById('currentPassword').value.trim();
  const newPassword = document.getElementById('newPassword').value.trim();
  const confirmPassword = document.getElementById('confirmPassword').value.trim();

  if (!currentPassword || !newPassword || !confirmPassword) {
    return Swal.fire('Validation', 'All fields are required', 'error');
  }

  if (newPassword !== confirmPassword) {
    return Swal.fire('Validation', 'New password and confirm password do not match', 'error');
  }

  try {
    const res = await fetch('/profile/changePassword', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ currentPassword, newPassword })
    });

    const data = await res.json();

    if (data.success) {
      Swal.fire('Success', data.message, 'success').then(() => {
        window.location.href = '/profile';
      });
    } else {
      Swal.fire('Error', data.message || 'Failed to update password', 'error');
    }
  } catch (err) {
    console.error(err);
    Swal.fire('Error', 'Something went wrong', 'error');
  }
})
</script>
</body>
</html>