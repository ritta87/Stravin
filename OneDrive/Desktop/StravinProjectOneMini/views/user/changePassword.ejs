/* Wrapper container */
.change-password-container {
  max-width: 450px;
  margin: 60px auto;
  padding: 30px 25px;
  background-color: #fff;
  border-radius: 12px;
  box-shadow: 0 6px 20px rgba(0,0,0,0.08);
  font-family: 'Segoe UI', sans-serif;
}

/* Heading */
.change-password-container h2 {
  text-align: center;
  color: #333;
  font-weight: 600;
  margin-bottom: 30px;
}

/* Form groups */
.change-password-container .form-group {
  margin-bottom: 18px;
}

/* Labels */
.change-password-container label {
  display: block;
  font-weight: 500;
  margin-bottom: 6px;
  color: #555;
}

/* Input fields */
.change-password-container input.form-control {
  width: 100%;
  padding: 12px 14px;
  border-radius: 8px;
  border: 1px solid #ccc;
  transition: border-color 0.3s, box-shadow 0.3s;
}

.change-password-container input.form-control:focus {
  border-color: #4CAF50;
  box-shadow: 0 0 5px rgba(76, 175, 80, 0.3);
  outline: none;
}

/* Buttons */
.change-password-container .btn {
  width: 100%;
  padding: 12px 0;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 500;
  transition: background-color 0.3s, transform 0.2s;
}

.change-password-container .btn-primary {
  background-color: #4CAF50;
  border: none;
  color: #fff;
}

.change-password-container .btn-primary:hover {
  background-color: #45a049;
  transform: translateY(-2px);
}

/* Info / error text */
.change-password-container .info-text {
  font-size: 12px;
  color: #777;
  margin-bottom: 10px;
}
.dropdown {
  position: relative;
}

/* dropdown menu */
.dropdown-menu {
  display: none;
  position: absolute;
  top: 42px;
  right: 0;
  background: #fff;
  border-radius: 10px;
  min-width: 150px;
  padding: 8px 0;
  box-shadow: 0 8px 20px rgba(0,0,0,0.15);
  animation: fadeIn 0.2s ease;
}

.dropdown-menu li {
  padding: 8px 15px;
}

.dropdown-menu a {
  text-decoration: none;
  color: #333;
  font-size: 14px;
  display: block;
}

.dropdown-menu li:hover {
  background: #f3f3f3;
}

/* SHOW */
.dropdown:hover .dropdown-menu {
  display: block;
}
/* Responsive */
@media (max-width: 500px) {
  .change-password-container {
    margin: 30px 15px;
    padding: 20px;
  }
