<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<link rel="stylesheet" href="/css/navbar.css">
<link rel="stylesheet" href="/css/pages/footer.css">

<script src="/js/navbar.js"></script>
<style>

body {
  background-color: #f5f5f5;
  font-family: 'Segoe UI', sans-serif;
  color: #333;
}

a {
  text-decoration: none;
}

/* BACK LINK */
.back-link {
  display: inline-block;
  margin-bottom: 20px;
  font-weight: 500;
  color: #198754;
}

.back-link:hover {
  text-decoration: underline;
}

/* PRODUCT CARD */
.product-card {
  background-color: #fff;
  border-radius: 12px;
  box-shadow: 0 12px 25px rgba(0,0,0,0.08);
  padding: 30px;

  display: flex;
  flex-wrap: wrap;
  gap: 30px;
}

/* IMAGE SECTION */
.product-img-wrapper {
  flex: 1 1 350px;
  text-align: center;
}

.product-img {
  max-width: 100%;
  max-height: 400px;
  object-fit: contain;
  border-radius: 10px;
  background: #f1f1f1;
  padding: 15px;
}

/* INFO SECTION */
.product-info {
  flex: 1 1 400px;
  display: flex;
  flex-direction: column;
}

.product-info h2 {
  font-size: 2rem;
  font-weight: 700;
  margin-bottom: 15px;
}

.price {
  font-size: 1.8rem;
  font-weight: 700;
  color: #198754;
  margin-bottom: 20px;
}

.description {
  font-size: 1rem;
  color: #555;
  margin-bottom: 25px;
}

/* VARIANTS */
.variant-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 4px 8px;
  border-radius: 6px;
}

.variant-item.active {
  border: 2px solid #198754;
  background: #e9f7ef;
}

.variant-btn.active {
  background: black;
  color: white;
  border-color: black;
}

.disabled-variant {
  opacity: 0.5;
  pointer-events: none;
}

/* THUMBNAILS */
.thumbnail-img {
  width: 65px;
  height: 65px;
  object-fit: cover;
  border-radius: 50%;
  cursor: pointer;
  border: 2px solid transparent;
  transition: all 0.25s ease;
  background: #f1f1f1;
}

.thumbnail-img:hover {
  transform: scale(1.05);
}

.active-thumb {
  border-color: #198754;
  box-shadow: 0 0 0 2px rgba(25,135,84,0.25);
}

/* QUANTITY */
.quantity-wrapper {
  display: flex;
  align-items: center;
  border: 1px solid #ddd;
  width: 130px;
  border-radius: 6px;
  overflow: hidden;
}

.qty-btn {
  background: #f8f8f8;
  border: none;
  width: 40px;
  height: 40px;
  font-size: 18px;
  cursor: pointer;
  transition: 0.2s;
}

.qty-btn:hover {
  background: #eaeaea;
}

#qtyInput {
  width: 50px;
  height: 40px;
  border: none;
  text-align: center;
  font-size: 16px;
  outline: none;
}

/* ADD TO CART BUTTON */
.btn-add {
  padding: 12px 30px;
  font-size: 1.1rem;
  font-weight: 600;
}

/* RESPONSIVE */
@media(max-width:768px) {
  .product-card {
    flex-direction: column;
    padding: 20px;
  }

  .product-img-wrapper,
  .product-info {
    flex: 1 1 100%;
  }
}
  </style>
  <%- include('../partials/navbar') %>
  <%- include('../partials/breadcrumbs') %>


</head>

<body>

</header>
<div class="container my-5">

  <a href="/" class="mb-3 d-inline-block">⬅ Back</a>

  <div class="row g-4">

    <!-- IMAGE SECTION -->
    <div class="col-md-5 text-center">

      <img
        id="mainProductImage"
        src="<%= product.images?.[0] || '/images/no-image.png' %>"
        data-default="<%= product.images?.[0] || '/images/no-image.png' %>"
        class="img-fluid mb-3"
      />

      <!-- Thumbnails -->
      <% if (product.images && product.images.length > 1) { %>
      <div id="thumbnailContainer" class="d-flex justify-content-center gap-2 flex-wrap">
            <% product.images.forEach(img => { %>
            <img
              src="<%= img %>"
              class="thumbnail-img"
              style="width:60px; cursor:pointer;"
            />
          <% }) %>
        </div>
      <% } %>

    </div>

   <!-- INFO SECTION -->
<div class="col-md-7">

  <h2><%= product.productname %></h2>
<div class="mb-1">

  <span style="color: gold;">★★★★☆</span>

  <small class="text-muted">(120)</small>

</div>
  <!-- PRICE SECTION -->

<% const v = variants && variants.length ? variants[0] : null; %>

<p class="fs-4">

  <!-- FINAL PRICE -->
  <span id="finalPrice" class="fw-bold text-danger">
    ₹ <%= v ? v.finalPrice.toLocaleString("en-IN") : product.price.toLocaleString("en-IN") %>
  </span>

  <!-- ORIGINAL PRICE -->
  <% if (v && Number(v.finalOffer) > 0) { %>
    <span id="originalPrice" class="text-muted text-decoration-line-through ms-2">
      ₹ <%= v.basePrice.toLocaleString("en-IN") %>
    </span>
  <% } %>

  <!-- OFFER BADGE -->
  <% if (v && Number(v.finalOffer) > 0) { %>
    <span id="offerBadge" class="badge bg-danger ms-2">
      <%= v.finalOffer %>% OFF
    </span>
  <% } %>

</p>
</p>

<p>
<%= totalStock > 0 ? "Available" : "Out Of Stock" %>
</p>
 

  <p class="text-muted"><%= product.description %></p>

  <hr>

  <h5>Available Variants</h5>

  <!-- VARIANTS buttons-->
<div id="variantContainer" class="d-flex gap-2 flex-wrap">

<div class="mb-3">
 <% variants.forEach((v, index) => { %>
<div
 class="variant-btn px-3 py-1 border rounded d-inline-block
   <%= index === 0 ? 'active' : '' %>"
  style="cursor:pointer;"
  data-variant-id="<%= v._id %>"
  data-stock="<%= v.stockQuantity %>"
  data-images='<%- JSON.stringify(v.images && v.images.length ? v.images : product.images) %>'
  data-base="<%= v.basePrice %>"
  data-final="<%= v.finalPrice %>"
>

<strong><%= v.color %></strong>

<p class="mb-0 <%= v.stockQuantity === 0 ? 'text-danger' : 'text-success' %>">
  <%= v.stockQuantity === 0 ? "Out Of Stock" : v.stockQuantity + " available" %>
</p>

</div>
<% }) %>
  </div>
<div class="quantity-wrapper">
<button class="qty-btn" id="minusBtn">-</button>
 <input  type="number"  id="qtyInput" value="1" min="1" />
  <button class="qty-btn" id="plusBtn">+</button>
</div>
  <!-- ADD TO CART -->
  <div class="mt-4">
   <button  class="add-to-cart-btn btn btn-primary">Add to Cart</button>
  </div>


</div></div></div>
 <hr>

<h4>Customer Reviews</h4>

<!-- Overall Rating -->
<div class="mb-3">
  <strong>⭐ <%= staticReviews.rating %> / 5</strong>
  <span class="text-muted">(<%= staticReviews.totalReviews %> reviews)</span>
</div>

<!-- Individual Reviews -->
<div>

  <% staticReviews.reviews.forEach(r => { %>

    <div class="border p-3 mb-2 rounded">

      <strong><%= r.name %></strong>

      <!-- Stars -->
      <div>
        <% for(let i = 1; i <= 5; i++) { %>
          <% if(i <= r.stars) { %>
            <span style="color: gold;">★</span>
          <% } else { %>
            <span style="color: #ccc;">★</span>
          <% } %>
        <% } %>
      </div>

      <p class="mb-0"><%= r.comment %></p>

    </div>

  <% }) %>

</div> 
  <%- include('../partials/footer') %>


<script>
const mainImage = document.getElementById("mainProductImage");
const thumbnailContainer = document.getElementById("thumbnailContainer");
const finalPriceEl = document.getElementById("finalPrice");
const originalPriceEl = document.getElementById("originalPrice");

const variantButtons = document.querySelectorAll(".variant-btn");
const addToCartBtn = document.querySelector('.add-to-cart-btn')

let selectedVariantId = null;
/* default variant */
if (variantButtons.length > 0) {

  const firstVariant = variantButtons[0];
  const firstStock = Number(firstVariant.dataset.stock);

  selectedVariantId = firstVariant.dataset.variantId;
 if (firstStock === 0) {
   addToCartBtn.disabled = true;
    addToCartBtn.innerText = "Out Of Stock";
    addToCartBtn.style.opacity = "0.5";
  } else {
    addToCartBtn.disabled = false;
    addToCartBtn.innerText = "Add To Cart";
    addToCartBtn.style.opacity = "1";
  }
}
/* variant click */
variantButtons.forEach(btn => {

  btn.addEventListener("click", () => {

    const stock = Number(btn.dataset.stock);

    if (stock === 0) {
      addToCartBtn.disabled = true;
      addToCartBtn.innerText = "Out Of Stock";
      addToCartBtn.style.opacity = "0.5";
    } else {
      addToCartBtn.disabled = false;
      addToCartBtn.innerText = "Add To Cart";
      addToCartBtn.style.opacity = "1";
    }

    variantButtons.forEach(b => b.classList.remove("active"));
    btn.classList.add("active");

    selectedVariantId = btn.dataset.variantId;

    const base = Number(btn.dataset.base);
    const final = Number(btn.dataset.final);

    finalPriceEl.innerText = "₹ " + final.toLocaleString("en-IN");

    if (base > final) {
      originalPriceEl.innerText = "₹ " + base.toLocaleString("en-IN");
      originalPriceEl.classList.remove("d-none");
    } else {
      originalPriceEl.classList.add("d-none");
    }

    /* image update */
    const images = JSON.parse(btn.dataset.images || "[]");

    if (images.length > 0) {
      mainImage.src = images[0];
    }

    thumbnailContainer.innerHTML = "";

    images.forEach(img => {
      const thumb = document.createElement("img");
      thumb.src = img;
      thumb.style.width = "60px";
      thumb.style.cursor = "pointer";

      thumb.onclick = () => mainImage.src = img;

      thumbnailContainer.appendChild(thumb);
    });

  });

});
    

/* add to cart */
addToCartBtn.addEventListener("click", async () => {
const qtyInput = document.getElementById('qtyInput')
const quantity = Number(qtyInput.value)
  if (!selectedVariantId) {
    Swal.fire("Please select a variant");
    return;
  }

  const res = await fetch("/addtocart", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      variantId: selectedVariantId,
      quantity:quantity
    })
  });

  const data = await res.json();

  if (data.success) {
    loadCartCount()
    Swal.fire({
      icon: "success",
      title: "Item Added to Cart!",
      text: data.message
    });
  } else {
    if(data.message==='OUT_OF_STOCK'){
      Swal.fire({
      icon: "Error Occured",
      title: "Out Of Stock",
      text: "This Product is currently unavailable."
    })
    }
  else if(data.message==='LOGIN_REQUIRED'){
  Swal.fire({
      icon: "error",
      title: "Login Required",
      text: data.message
    })
    .then(() => {
      window.location.href = "/login";
    });
  }else {
    Swal.fire({
      icon: "error",
      title: "Error",
      text: data.message
    });
    
  }
}

})


//plus - minus button event
const qtyInput = document.getElementById("qtyInput");
const plusBtn = document.getElementById("plusBtn");
const minusBtn = document.getElementById("minusBtn");
plusBtn.addEventListener("click", () => {
qtyInput.value = Number(qtyInput.value) + 1;
});

minusBtn.addEventListener("click", () => {
if (qtyInput.value > 1) {
qtyInput.value = Number(qtyInput.value) - 1;
}
});
</script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>
</html>