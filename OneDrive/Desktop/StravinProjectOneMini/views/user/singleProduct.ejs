<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= product.productname %> | Stravin</title>

  <!-- Bootstrap CSS -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

  <style>
    body {
      background-color: #f5f5f5;
      font-family: 'Segoe UI', sans-serif;
      color: #333;
    }

    a { text-decoration: none; }

    /* HEADER */
    header {
      background-color: #198754;
      padding: 15px 0;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
      position: sticky;
      top: 0;
      z-index: 1000;
    }
    header .brand { font-weight:700; font-size:1.7rem; color:#fff; }
    header nav a { color:#fff; font-weight:500; margin-left:25px; transition:color 0.2s;}
    header nav a:hover { color:#e0e0e0; }

    /* BACK LINK */
    .back-link { display:inline-block; margin-bottom:20px; font-weight:500; color:#198754; }
    .back-link:hover { text-decoration:underline; }
.disabled-variant{
  opacity:0.5;
  pointer-events:none;
}
    /* PRODUCT CARD */
    .product-card {
      background-color:#fff;
      border-radius:12px;
      box-shadow:0 12px 25px rgba(0,0,0,0.08);
      padding:30px;
      display:flex;
      flex-wrap:wrap;
      gap:30px;
    }

    .product-img-wrapper { flex:1 1 350px; text-align:center; }
    .product-img { max-width:100%; max-height:400px; object-fit:contain; border-radius:10px; background:#f1f1f1; padding:15px; }

    .product-info { flex:1 1 400px; display:flex; flex-direction:column; justify-content:flex-start; }
    .product-info h2 { font-size:2rem; font-weight:700; margin-bottom:15px; }
    .price { font-size:1.8rem; font-weight:700; color:#198754; margin-bottom:20px; }
    .description { font-size:1rem; color:#555; margin-bottom:25px; }

    /* VARIANTS */
    .variant-item { display:flex; align-items:center; gap:8px; padding:4px 8px; border-radius:6px; }
    .variant-item.active { border:2px solid #198754; background:#e9f7ef; }
    .variant-btn.active {
      background: black;
      color: white;
      border-color: black;
  }

    /* THUMBNAILS */
    .thumbnail-img { width:65px; height:65px; object-fit:cover; border-radius:50%; cursor:pointer; border:2px solid transparent; transition:all 0.25s ease; background:#f1f1f1; }
    .thumbnail-img:hover { transform:scale(1.05); }
    .active-thumb { border-color:#198754; box-shadow:0 0 0 2px rgba(25,135,84,0.25); }

    /* BUTTONS */
    .btn-add { padding:12px 30px; font-size:1.1rem; font-weight:600; }

    /* FOOTER */
    footer { background-color:#343a40; color:#fff; padding:30px 0; margin-top:50px; }
    footer a { color:#fff; margin:0 10px; transition:color 0.2s; }
    footer a:hover { color:#198754; text-decoration:none; }
.quantity-wrapper{
display:flex;
align-items:center;
border:1px solid #ddd;
width:130px;
border-radius:6px;
overflow:hidden;
}

.qty-btn{
background:#f8f8f8;
border:none;
width:40px;
height:40px;
font-size:18px;
cursor:pointer;
transition:0.2s;
}

.qty-btn:hover{
background:#eaeaea;
}

#qtyInput{
width:50px;
height:40px;
border:none;
text-align:center;
font-size:16px;
outline:none;
}
 .cart-link{
  position: relative;
  display: inline-block;
}
.cart-icon{
  font-size: 22px;
  color: #000;   /* black icon */
}
.cart-count{
  position:absolute;
  top:-6px;
  right:-8px;
  background:#000;
  color:#fff;
  font-size:10px;
  padding:2px 6px;
  border-radius:10px;
  font-weight:600;
}/* USER BUTTON */

.wishlist-nav i {
  font-size: 18px;
}

.wishlist-badge {
  position: absolute;
  top: -4px;
  left: 12px;
  min-width: 18px;
  height: 18px;
  padding: 0 5px;
  border-radius: 50px;
  background: red;
  color: white;
  font-size: 10px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid white;
}
/* ===== NAV ALIGNMENT FIX ONLY ===== */
.nav-left {
  display: flex;
  align-items: center;
  gap: 18px; /* spacing between items */
}

.nav-left a,
.nav-left .dropdown {
  display: flex;
  align-items: center;
}

/* ===== DROPDOWN  ===== */

.dropdown {
  position: relative;
}

/* KEEP dropdown attached */
.dropdown-menu {
  position: absolute;
  top: 100%;   /* remove extra gap */
  right: 0;

  display: none;
  z-index: 999;
}

/* IMPORTANT: keep menu visible when hovering menu itself */
.dropdown:hover .dropdown-menu,
.dropdown-menu:hover {
  display: block;
}
/* ===== DROPDOWN ITEM FEEL ONLY ===== */
.dropdown-item {
  display: block;
  padding: 8px 14px;
  transition: 0.2s ease;
}


@media(max-width:768px) {
      .product-card { flex-direction:column; padding:20px; }
      .product-img-wrapper, .product-info { flex:1 1 100%; }
      header nav a { margin-left:15px; font-size:0.95rem; }
    }
  </style>
</head>

<body>

<header class="d-flex justify-content-between align-items-center px-4">
  <div class="brand">Stravin</div>
 <nav class="nav-bar">
    <div class="nav-left">

      <a href="/">Home</a>
      <a href="/shop">Shop</a>
    <a href="/cart" class="cart-link">
     <i class="bi bi-cart3 cart-icon"></i>
     <span id="cartCount" class="cart-count">0</span>
      </a>
       <a href="/wishlist" class="nav-link wishlist-nav position-relative">
      <i class="bi bi-heart"></i>
      <span class="ms-1"></span>
    </a>

      <% if (isLoggedIn) { %>

        <div class="dropdown">
          <button class="dropdown-toggle">
            Hi, <%= user.name %>
          </button>

          <ul class="dropdown-menu">
            <li>
              <a href="/profile" class="dropdown-item">Profile</a>
            </li>
             <li>
              <a href="/orders" class="dropdown-item">My Orders</a>
            </li>
             <li>
              <a href="/logout" class="dropdown-item">Logout</a>
            </li>
          </ul>
        </div>

      <% } else { %>
    <a href="/login">Login</a>
<% } %>

    </div>
  </nav>
<script>
  //cart count
async function loadCartCount(){
  try{
    const res = await fetch('/cart/count')
    const data = await res.json()
    const cartEl = document.getElementById('cartCount')
    if(cartEl){
      cartEl.innerText = data.count
    }
  }catch(err){
    console.log("Error fetching cart count",err)
  }
}

document.addEventListener("DOMContentLoaded", loadCartCount)
</script>
</header>

<div class="container my-5">

  <a href="/" class="mb-3 d-inline-block">⬅ Back</a>

  <div class="row g-4">

    <!-- IMAGE SECTION -->
    <div class="col-md-5 text-center">

      <img
        id="mainProductImage"
        src="<%= product.images?.[0] || '/images/no-image.png' %>"
        data-default="<%= product.images?.[0] || '/images/no-image.png' %>"
        class="img-fluid mb-3"
      />

      <!-- Thumbnails -->
      <% if (product.images && product.images.length > 1) { %>
      <div id="thumbnailContainer" class="d-flex justify-content-center gap-2 flex-wrap">
            <% product.images.forEach(img => { %>
            <img
              src="<%= img %>"
              class="thumbnail-img"
              style="width:60px; cursor:pointer;"
            />
          <% }) %>
        </div>
      <% } %>

    </div>

   <!-- INFO SECTION -->
<div class="col-md-7">

  <h2><%= product.productname %></h2>

  <!-- PRICE SECTION -->
<p class="fs-4">
<span id="finalPrice" class="fw-bold text-danger">
₹ <%= variants.length ? variants[0].finalPrice.toLocaleString("en-IN") : product.price.toLocaleString("en-IN") %>
</span>

<span id="originalPrice" class="text-muted text-decoration-line-through ms-2">
₹ <%= variants.length ? variants[0].basePrice.toLocaleString("en-IN") : '' %>
</span>
<span class="badge bg-danger">
<%= product.offerPercentage %>% OFF
</span>
  <% if(product.offerPercentage > 0) { %>
    <span class="badge bg-danger ms-2">
      <%= product.offerPercentage %>% OFF
    </span>
  <% } %>

</p>

<p>
<%= totalStock > 0 ? "Available" : "Out Of Stock" %>
</p>
 

  <p class="text-muted"><%= product.description %></p>

  <hr>

  <h5>Available Variants</h5>

  <!-- VARIANTS buttons-->
<div id="variantContainer" class="d-flex gap-2 flex-wrap">

<div class="mb-3">
 <% variants.forEach((v, index) => { %>
<div
 class="variant-btn px-3 py-1 border rounded d-inline-block
   <%= index === 0 ? 'active' : '' %>"
  style="cursor:pointer;"
  data-variant-id="<%= v._id %>"
  data-stock="<%= v.stockQuantity %>"
  data-images='<%- JSON.stringify(v.images && v.images.length ? v.images : product.images) %>'
  data-base="<%= v.basePrice %>"
  data-final="<%= v.finalPrice %>"
>

<strong><%= v.color %></strong>

<p class="mb-0 <%= v.stockQuantity === 0 ? 'text-danger' : 'text-success' %>">
  <%= v.stockQuantity === 0 ? "Out Of Stock" : v.stockQuantity + " available" %>
</p>

</div>
<% }) %>
  </div>
<div class="quantity-wrapper">
<button class="qty-btn" id="minusBtn">-</button>
 <input  type="number"  id="qtyInput" value="1" min="1" />
  <button class="qty-btn" id="plusBtn">+</button>
</div>
  <!-- ADD TO CART -->
  <div class="mt-4">
   <button  class="add-to-cart-btn btn btn-primary">Add to Cart</button>
  </div>


</div></div></div>
  
<footer class="text-center">
  &copy; 2026 Stravin. All Rights Reserved.
</footer>


<script>
const mainImage = document.getElementById("mainProductImage");
const thumbnailContainer = document.getElementById("thumbnailContainer");
const finalPriceEl = document.getElementById("finalPrice");
const originalPriceEl = document.getElementById("originalPrice");

const variantButtons = document.querySelectorAll(".variant-btn");
const addToCartBtn = document.querySelector('.add-to-cart-btn')

let selectedVariantId = null;
/* default variant */
if (variantButtons.length > 0) {

  const firstVariant = variantButtons[0];
  const firstStock = Number(firstVariant.dataset.stock);

  selectedVariantId = firstVariant.dataset.variantId;
 if (firstStock === 0) {
   addToCartBtn.disabled = true;
    addToCartBtn.innerText = "Out Of Stock";
    addToCartBtn.style.opacity = "0.5";
  } else {
    addToCartBtn.disabled = false;
    addToCartBtn.innerText = "Add To Cart";
    addToCartBtn.style.opacity = "1";
  }
}
/* variant click */
variantButtons.forEach(btn => {

  btn.addEventListener("click", () => {

    const stock = Number(btn.dataset.stock);

    if (stock === 0) {
      addToCartBtn.disabled = true;
      addToCartBtn.innerText = "Out Of Stock";
      addToCartBtn.style.opacity = "0.5";
    } else {
      addToCartBtn.disabled = false;
      addToCartBtn.innerText = "Add To Cart";
      addToCartBtn.style.opacity = "1";
    }

    variantButtons.forEach(b => b.classList.remove("active"));
    btn.classList.add("active");

    selectedVariantId = btn.dataset.variantId;

    const base = Number(btn.dataset.base);
    const final = Number(btn.dataset.final);

    finalPriceEl.innerText = "₹ " + final.toLocaleString("en-IN");

    if (base > final) {
      originalPriceEl.innerText = "₹ " + base.toLocaleString("en-IN");
      originalPriceEl.classList.remove("d-none");
    } else {
      originalPriceEl.classList.add("d-none");
    }

    /* image update */
    const images = JSON.parse(btn.dataset.images || "[]");

    if (images.length > 0) {
      mainImage.src = images[0];
    }

    thumbnailContainer.innerHTML = "";

    images.forEach(img => {
      const thumb = document.createElement("img");
      thumb.src = img;
      thumb.style.width = "60px";
      thumb.style.cursor = "pointer";

      thumb.onclick = () => mainImage.src = img;

      thumbnailContainer.appendChild(thumb);
    });

  });

});
    

/* add to cart */
addToCartBtn.addEventListener("click", async () => {
const qtyInput = document.getElementById('qtyInput')
const quantity = Number(qtyInput.value)
  if (!selectedVariantId) {
    Swal.fire("Please select a variant");
    return;
  }

  const res = await fetch("/addtocart", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      variantId: selectedVariantId,
      quantity:quantity
    })
  });

  const data = await res.json();

  if (data.success) {
    loadCartCount()
    Swal.fire({
      icon: "success",
      title: "Item Added to Cart!",
      text: data.message
    });
  } else {
    if(data.message==='OUT_OF_STOCK'){
      Swal.fire({
      icon: "Error Occured",
      title: "Out Of Stock",
      text: "This Product is currently unavailable."
    })
    }
  else if(data.message==='LOGIN_REQUIRED'){
  Swal.fire({
      icon: "error",
      title: "Login Required",
      text: data.message
    })
    .then(() => {
      window.location.href = "/login";
    });
  }else {
    Swal.fire({
      icon: "error",
      title: "Error",
      text: data.message
    });
    
  }
}

})


//plus - minus button event
const qtyInput = document.getElementById("qtyInput");
const plusBtn = document.getElementById("plusBtn");
const minusBtn = document.getElementById("minusBtn");
plusBtn.addEventListener("click", () => {
qtyInput.value = Number(qtyInput.value) + 1;
});

minusBtn.addEventListener("click", () => {
if (qtyInput.value > 1) {
qtyInput.value = Number(qtyInput.value) - 1;
}
});
</script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>
</html>