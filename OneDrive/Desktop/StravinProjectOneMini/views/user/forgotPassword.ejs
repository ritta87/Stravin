<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password | Stravin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
   <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>/* ===== Forgot Password Page ===== */

.forgot-body {
  background: linear-gradient(135deg, #e9eff5, #f7f9fb);
  min-height: 100vh;
  display: flex;
  align-items: center;
}

.forgot-card {
  border-radius: 15px;
  padding: 25px;
  background: #fff;
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
}

.forgot-card h3 {
  font-weight: 600;
  color: #333;
}

.forgot-card p {
  font-size: 14px;
}

.form-control {
  border-radius: 10px;
  padding: 10px;
  font-size: 14px;
}

.form-control:focus {
  box-shadow: 0 0 6px rgba(13, 110, 253, 0.3);
  border-color: #0d6efd;
}

.btn-primary {
  border-radius: 10px;
  padding: 10px;
  font-weight: 500;
  transition: 0.3s;
}

.btn-primary:hover {
  background-color: #0b5ed7;
}</style>
</head>

<body class="forgot-body">

<div class="container">
  <div class="col-md-4 mx-auto forgot-card">

    <h3 class="text-center mb-3">Forgot Password</h3>
    <p class="text-muted text-center">Enter your registered email to receive OTP</p>

    <div class="mb-3">
      <label class="form-label">Email</label>
      <input type="email" id="email" name="email" class="form-control" placeholder="Enter your email">
    </div>

    <button id="sendOtpBtn" class="btn btn-primary w-100">Send OTP</button>

  </div>
</div>

</body>
<script>
   document.getElementById('sendOtpBtn')
   .addEventListener('click',async()=>{
    const email = document.getElementById('email').value.trim()
    if(!email){
        return Swal.fire("Error Occured!","Email Id is required!","error")
    }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){
       return Swal.fire("Invalid","Please Enter a Valid EmailId","error")
    }
    try{
        const res = await fetch('/forgotPassword',{
            method:"POST",
            headers:{'Content-Type':'application/json'},
            body:JSON.stringify({email})
        })
       const data= await res.json()
       if(data.success){
        Swal.fire('OTP Sent Successfully',data.message,'success')
        setTimeout(()=>{
            window.location.href=`/resetPassword?email=${email}`
        },1500)
       }else{
        Swal.fire('Failed!!',data.message,"error")
       }
    }catch(error){
        Swal.fire("Error","Something went wrong!")
    }
})

</script>

</body>
</html>