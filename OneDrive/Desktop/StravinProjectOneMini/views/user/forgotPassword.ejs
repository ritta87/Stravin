<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password | Stravin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
   <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>
<body class="bg-light">

<div class="container mt-5">
  <div class="col-md-4 mx-auto p-4 shadow bg-white rounded">

    <h3 class="text-center mb-3">Forgot Password</h3>
    <p class="text-muted text-center">Enter your registered email to receive OTP</p>

    <div class="mb-3">
      <label class="form-label">Email</label>
      <input type="email" id="email" name="email" class="form-control" placeholder="Enter your email">
    </div>

    <button id="sendOtpBtn" class="btn btn-primary w-100">Send OTP</button>

  </div>
</div>
<script>
   document.getElementById('sendOtpBtn')
   .addEventListener('click',async()=>{
    const email = document.getElementById('email').value.trim()
    if(!email){
        return Swal.fire("Error Occured!","Email Id is required!","error")
    }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){
       return Swal.fire("Invalid","Please Enter a Valid EmailId","error")
    }
    try{
        const res = await fetch('/forgotPassword',{
            method:"POST",
            headers:{'Content-Type':'application/json'},
            body:JSON.stringify({email})
        })
       const data= await res.json()
       if(data.success){
        Swal.fire('OTP Sent Successfully',data.message,'success')
        setTimeout(()=>{
            window.location.href=`/resetPassword?email=${email}`
        },1500)
       }else{
        Swal.fire('Failed!!',data.message,"error")
       }
    }catch(error){
        Swal.fire("Error","Something went wrong!")
    }
})

</script>

</body>
</html>