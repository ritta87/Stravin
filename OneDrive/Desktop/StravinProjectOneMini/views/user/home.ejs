<!DOCTYPE html>
<html lang="en">
  <head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<link rel="stylesheet" href="/css/navbar.css">
<link rel="stylesheet" href="/css/pages/footer.css">

<script src="/js/navbar.js"></script>
<style>
  .top-filter-bar {
  max-width: 1300px;
  margin: 20px auto;
  padding: 10px 20px;

  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20px;
}

/* SEARCH */
.filter-left input {
  width: 260px;
  padding: 10px;
  border: 1px solid #ddd;
  border-radius: 6px;
}

/* RIGHT */
.filter-right select {
  padding: 10px 35px 10px 12px;
  border-radius: 8px;
  border: 1px solid #ddd;
  font-size: 14px;
  background: #fff;
  cursor: pointer;

  appearance: none; /* remove default arrow */
  -webkit-appearance: none;
  -moz-appearance: none;

  transition: 0.2s;
}

/* Hover / Focus */
.filter-right select:hover {
  border-color: #000;
}

.filter-right select:focus {
  outline: none;
  border-color: #000;
}

/* Custom arrow */
.filter-right {
  position: relative;
}

.filter-right::after {
  content: "▾";
  position: absolute;
  right: 10px;
  pointer-events: none;
  font-size: 12px;
  color: #555;
}
.filter-box {
  background: #fff;
  padding: 20px;
  border-radius: 12px;
  box-shadow: 0 4px 14px rgba(0,0,0,0.06);

  display: flex;
  flex-direction: column;
}

/* CATEGORY LIST */
#categories {
  max-height: 260px;
  overflow-y: auto;
  margin-bottom: 15px; /* ⬅️ space before button */
}

/* APPLY BUTTON */
.filter-box .btn {
  margin-top: 10px;   
  padding: 10px;      
  font-weight: 600;
  border-radius: 8px;
  background: #000;
  color: #fff;
  border: none;
  transition: 0.2s;
}

.filter-box .btn:hover {
  background: #333;
}
/* BUTTONS */
.apply-btn {
  background: #000;
  color: #fff;
  padding: 9px 16px;
  border: none;
  border-radius: 6px;
}
.clear-btn {
  margin-top: 10px;
  display: block;
  text-align: center;

  padding: 10px;
  border-radius: 8px;
  border: 1px solid #ddd;

  text-decoration: none;
  font-size: 14px;
  color: #333;
  background: #f9f9f9;

  transition: 0.2s;
}

.clear-btn:hover {
  background: #eee;
  border-color: #bbb;
}
.row {
  display: flex;
  flex-wrap: wrap;
}

/* PRODUCT COLUMN */
.col-md-4 {
  display: flex;
}
.product-card {
  background: #fff;
  border-radius: 12px;
  padding: 14px;
  width: 100%;

  box-shadow: 0 4px 14px rgba(0,0,0,0.08);
  transition: all 0.25s ease;

  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-card:hover {
  transform: translateY(-5px);
}

/* IMAGE */
.product-img {
  width: 100%;
  height: 240px;
  object-fit: cover;
  border-radius: 10px;
  padding: 10px;
  object-fit: contain;   /* instead of cover */
  background: #fff;

}

/* INFO */
.product-info h6 {
  font-weight: 600;
  margin-top: 10px;
}
.product-card:hover .product-img {
  transform: scale(1.05);
}

.product-img {
  transition: 0.3s ease;
}

/* PRICE */
.discount-price {
  font-size: 18px;
  font-weight: 700;
  color: #d32f2f;
}

.original-price {
  font-size: 14px;
  color: #888;
  text-decoration: line-through;
}

/* BADGE */
.badge {
  font-size: 12px;
  padding: 4px 8px;
  border-radius: 6px;
}
.filter-box {
  background: #fff;
  padding: 18px;
  border-radius: 12px;
  box-shadow: 0 4px 14px rgba(0,0,0,0.06);
}

.filter-box h5 {
  font-weight: 600;
  margin-bottom: 10px;
}

#categories {
  max-height: 260px;
  overflow-y: auto;
}

#categories div {
  display: flex;
  gap: 8px;
  margin-bottom: 6px;
}
.pagination-wrapper {
  display: flex;
  justify-content: center;
  margin: 30px 0;
}

.custom-pagination {
  display: flex;
  list-style: none;
  gap: 8px;
  padding: 0;
}

.custom-pagination li a {
  display: block;
  padding: 8px 14px;
  border: 1px solid #ddd;
  border-radius: 6px;
  text-decoration: none;
  color: #333;
}

.custom-pagination li.active a {
  background: #000;
  color: #fff;
  border-color: #000;
}

.custom-pagination li a:hover {
  background: #f5f5f5;
}
</style>
<%- include('../partials/navbar') %>

  <!-- HERO -->
<div id="stravinCarousel" class="carousel slide" data-bs-ride="carousel">

  <!-- Indicators -->
  <div class="carousel-indicators">
    <button type="button" data-bs-target="#stravinCarousel" data-bs-slide-to="0" class="active"></button>
    <button type="button" data-bs-target="#stravinCarousel" data-bs-slide-to="1"></button>
    <button type="button" data-bs-target="#stravinCarousel" data-bs-slide-to="2"></button>
  </div>

  <!-- Images -->
  <div class="carousel-inner">

    <div class="carousel-item active">
      <img src="/images/runmode.jpg" class="d-block w-100" alt="Smartwatch Banner">
      <div class="carousel-caption">
        <h3>Stravin Smartwatch</h3>
        <p>Track your fitness with style</p>
      </div>
    </div>

    <div class="carousel-item">
      <img src="/images/venu.jpg" class="d-block w-100" alt="Garmin Watch">
      <div class="carousel-caption">
        <h3>Premium Sports Watches</h3>
        <p>Performance meets technology</p>
      </div>
    </div>

    <div class="carousel-item">
      <img src="/images/coros.jpg" class="d-block w-100" alt="Coros Watch">
      <div class="carousel-caption">
        <h3>Adventure Ready</h3>
        <p>Explore with confidence</p>
      </div>
    </div>

  </div>

  <!-- Controls -->
  <button class="carousel-control-prev" type="button" data-bs-target="#stravinCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" type="button" data-bs-target="#stravinCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>

</div>
<form method="GET" action="/" class="top-filter-bar">

  <!-- LEFT: SEARCH -->
  <div class="filter-left">
    <input 
      type="text" 
      name="search" 
      placeholder="Search smartwatches..."
      value="<%= search %>">
  </div>

   <div class="filter-right" onchange="this.form.submit()">
    <select name="sort">
      <option value="">Sort</option>
      <option value="priceLow" <%= sort === 'priceLow' ? 'selected' : '' %>>
        Price: Low → High
      </option>
      <option value="priceHigh" <%= sort === 'priceHigh' ? 'selected' : '' %>>
        Price: High → Low
      </option>
      <option value="name" <%= sort === 'name' ? 'selected' : '' %>>
        Name A–Z
      </option>
    </select>
</div>
<input type="hidden" name="category" value="<%= category %>">

</form>

<!-- PRODUCTS -->
<!-- PRODUCTS SECTION -->
<div class="container mt-4">

  <div class="row">

    <!-- LEFT SIDEBAR -->
    <div class="col-md-3">

      <div class="filter-box">

        <h5>Categories</h5>

        <div id="categories"></div>

        <button onclick="applyCategoryfilter()" class="apply-btn">
          Apply
        </button>
<a href="/" class="clear-btn">Clear</a>
      </div>

    </div>


    <!-- RIGHT PRODUCT AREA -->
    <div class="col-md-9">

      <div class="row">

        <% if(products && products.length > 0){ %>

          <% products.forEach(p => { %>

            <div class="col-md-4 mb-4">

              <div class="product-card">

                <a href="/product/<%= p._id %>">
                  <img src="<%= p.images[0] %>" class="product-img">
                </a>           
<div class="product-info">
  <h6><%= p.productname %></h6>
<div class="mb-1">

  <span style="color: gold;">★★★★☆</span>

  <small class="text-muted">(120)</small>

</div>
<button class="wishlist-btn <%= wishlistProducts.includes(p._id.toString()) ? 'wishlist-active' : '' %>"
 onclick="toggleWishlist('<%= p._id %>', this)">
<i class="bi <%= wishlistProducts.includes(p._id.toString()) ? 'bi-heart-fill' : 'bi-heart' %>">
</i></button>

  
</div>
<div class="product-details">

  <% if (p.finalOffer && p.finalOffer > 0) { %>

    <span class="original-price" style="text-decoration: line-through; color: gray;">
      ₹<%= p.price %>
    </span>

    <span class="discount-price" style="color: red; font-weight: bold; margin-left: 5px;">
      ₹<%= p.finalPrice %>
    </span>

    <div>
      <span class="badge bg-success">
        <%= p.finalOffer %>% OFF
      </span>
    </div>

  <% } else { %>

    <span class="discount-price">
      ₹<%= p.price %>
    </span>

  <% } %>

</div>

              </div>

            </div>

          <% }) %>

        <% } else { %>

          <p>No products available</p>

        <% } %>

      </div>

    </div>

  </div>

</div>
      <!-- Products pagination -->
<div class="pagination-wrapper">
  <ul class="custom-pagination">
    <% for (let i = 1; i <= totalPages; i++) { %>
      <li class="<%= i === currentPage ? 'active' : '' %>">
        <a href="/?page=<%= i %>&search=<%= search %>&sort=<%= sort %>">
          <%= i %>
        </a>
      </li>
    <% } %>
  </ul>
</div>

<%-include('../partials/footer')%>

<script>
  function swapImage(productId, thumbEl) {
    const mainImg = document.getElementById(`main-img-${productId}`);
    if (!mainImg) return;

    // Swap src values
    const tempSrc = mainImg.src;
    mainImg.src = thumbEl.src;
    thumbEl.src = tempSrc;
  }
 async function loadCategories() {
  const res = await fetch(`/listedCategories`);
  const data = await res.json();

  const container = document.getElementById('categories');
  container.innerHTML = "";

  //get multiple categories from url
  const params = new URLSearchParams(window.location.search);
  const selectedCategories = params.get('category')
    ? params.get('category').split(',') : [];

  data.categories.forEach(cat => {
    const isChecked =
      selectedCategories.includes(cat._id.toString()) ? "checked" : "";

    container.innerHTML += `
      <div>
        <input type="checkbox"
               value="${cat._id}"
               class="catCheck"
               ${isChecked}>
        ${cat.name}
      </div>`;
  });
}
loadCategories()

function applyCategoryfilter() {
  const selected = [];
  document.querySelectorAll(".catCheck:checked").forEach(cb => {
    selected.push(cb.value);
  })
  const query = new URLSearchParams(window.location.search);
  query.set("category", selected.join(","))
  window.location.href = `/?${query.toString()}`;
}
//wishlist btn

async function toggleWishlist(productId, btn) {
  try {
    const res = await fetch('/addToWishlist', {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ productId })
    });
    const data = await res.json();

    if (!data.success) {
      Swal.fire("Error", data.message, "error");
      return;
    }

    const icon = btn.querySelector("i");
    if (data.added) {
      icon.classList.remove("bi-heart");
      icon.classList.add("bi-heart-fill");
      btn.classList.add("wishlist-active");
    } else {
      icon.classList.remove("bi-heart-fill");
      icon.classList.add("bi-heart");
      btn.classList.remove("wishlist-active");
    }
  } catch (err) {
    console.error(err);
  }
}
</script>

</body>
</html>