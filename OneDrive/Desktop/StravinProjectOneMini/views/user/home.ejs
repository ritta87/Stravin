<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

  <!-- CSS -->
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/navbar.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/pages/home.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
  .pagination-wrapper {
  display: flex;
  justify-content: center;
  margin-top: 30px;
}
 .pagination .page-link {
  border-radius: 6px !important;
  margin: 0 4px !important;
  color: #000 !important;
}

.pagination .active .page-link {
  background: #000 !important;
  border-color: #000 !important;
  color: #fff !important;
}
.pagination .page-link {
  border-radius: 6px !important;
  margin: 0 4px !important;
  padding: 8px 14px !important;
  font-weight: 500;
}
.filter-bar {
  background: #fff;
  padding: 12px 18px;
  border-radius: 10px;
  margin-top: 15px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.filter-right {
  display: flex;
  align-items: center;
  gap: 10px;
}

.filter-bar select {
  padding: 6px 10px;
  border-radius: 6px;
  border: 1px solid #ccc;
}

.filter-bar button {
  padding: 6px 12px;
  border-radius: 6px;
  border: none;
  background: #000;
  color: #fff;
}
.wishlist-btn {
  position: absolute;
  top: 10px;
  right: 10px;

  border: none;
  background: transparent; /* NO white circle */
  padding: 4px;

  font-size: 20px;
  cursor: pointer;

  color: #e63946; /* red outline by default */

  transition: color 0.2s ease;
}

/* Default = outline heart */
.wishlist-btn i {
  color: #e63946;
}

/* Selected = filled heart */
.wishlist-btn.active i {
  color: #e63946;
}

/* Remove ALL annoying effects */
.wishlist-btn:hover {
  color: #e63946;
  background: transparent;
  transform: none;
}
</style>
</head>
<script>
  //cart count
async function loadCartCount(){
  try{
    const res = await fetch('/cart/count')
    const data = await res.json()
    const cartEl = document.getElementById('cartCount')
    if(cartEl){
      cartEl.innerText = data.count
    }
  }catch(err){
    console.log("Error fetching cart count",err)
  }
}

document.addEventListener("DOMContentLoaded", loadCartCount)
</script>
<body>

  <!--  NAVBAR -->
  <%- include('../partials/navbar') %>

  <!--  PAGE CONTENT -->
  <main class="container mt-4">

    <h2>Welcome to Stravin</h2>

    <!--  home page content  -->
  <!-- HERO -->
<div id="stravinCarousel" class="carousel slide" data-bs-ride="carousel">

  <!-- Indicators -->
  <div class="carousel-indicators">
    <button type="button" data-bs-target="#stravinCarousel" data-bs-slide-to="0" class="active"></button>
    <button type="button" data-bs-target="#stravinCarousel" data-bs-slide-to="1"></button>
    <button type="button" data-bs-target="#stravinCarousel" data-bs-slide-to="2"></button>
  </div>

  <!-- Images -->
  <div class="carousel-inner">

    <div class="carousel-item active">
      <img src="/images/runmode.jpg" class="d-block w-100" alt="Smartwatch Banner">
      <div class="carousel-caption">
        <h3>Stravin Smartwatch</h3>
        <p>Track your fitness with style</p>
      </div>
    </div>

    <div class="carousel-item">
      <img src="/images/smartwach-mainpic.jpg" class="d-block w-100" alt="Garmin Watch">
      <div class="carousel-caption">
        <h3>Premium Sports Watches</h3>
        <p>Performance meets technology</p>
      </div>
    </div>

    <div class="carousel-item">
      <img src="/images/coros.jpg" class="d-block w-100" alt="Coros Watch">
      <div class="carousel-caption">
        <h3>Adventure Ready</h3>
        <p>Explore with confidence</p>
      </div>
    </div>

  </div>

  <!-- Controls -->
  <button class="carousel-control-prev" type="button" data-bs-target="#stravinCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" type="button" data-bs-target="#stravinCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>

</div>



<form method="GET" action="/" class="filter-bar d-flex justify-content-between align-items-center flex-wrap">

   <div class="d-flex align-items-center gap-2 mt-2 mt-md-0">
    <select name="sort" class="form-select-sm w-auto">
      <option value="">Sort</option>
      <option value="priceLow" <%= sort === 'priceLow' ? 'selected' : '' %>>
        Price: Low → High
      </option>
      <option value="priceHigh" <%= sort === 'priceHigh' ? 'selected' : '' %>>
        Price: High → Low
      </option>
      <option value="name" <%= sort === 'name' ? 'selected' : '' %>>
        Name A–Z
      </option>
    </select>
<button type="submit" class="btn btn-dark btn-sm">Apply</button>
<a href="/" class="btn btn-light border">Clear</a>
</div>
<input type="hidden" name="search" value="<%= search %>">
</form>



  <div class="row g-3">

    <!-- LEFT SIDEBAR -->
    <div class="col-md-3">

      <div class="filter-box">

        <h5>Categories</h5>

        <div id="categories"></div>

        <button onclick="applyCategoryfilter()" class="btn btn-warning mt-2">
          Apply
        </button>

      </div>

    </div>


    <!-- RIGHT PRODUCT AREA -->
    <div class="col-md-9">

      <div class="row">

        <% if(products && products.length > 0){ %>

          <% products.forEach(p => { %>

            <div class="col-md-4 mb-4">

              <div class="product-card">

                <a href="/product/<%= p._id %>">
                  <img src="<%= p.images[0] %>" class="product-img">
                </a>           
<div class="product-info" class="product-card position-relative">
  <h6><%= p.productname %></h6>

<button class="wishlist-btn <%= wishlistProducts.includes(p._id.toString()) ? 'wishlist-active' : '' %>"
 onclick="toggleWishlist('<%= p._id %>', this)">
<i class="bi <%= wishlistProducts.includes(p._id.toString()) ? 'bi-heart-fill' : 'bi-heart' %>">
</i></button>

  <p>₹<%= p.price %></p>
</div>
                <div class="product-details">
                  <% if(p.offerPercentage > 0){ %>

                    <span class="discount-price">
                      ₹ <%= p.offerPrice %>
                    </span>

                    <span class="original-price">
                      ₹ <%= p.price %>
                    </span>
               
                  <% } else { %>

                    <span class="discount-price">
                      ₹ <%= p.price %>
                    </span>

                  <% } %>

                </div>

              </div>

            </div>

          <% }) %>

        <% } else { %>

          <p>No products available</p>

        <% } %>

      </div>

    </div>

  </div>


      <!-- Products pagination -->
<div class="pagination-wrapper">
  <ul class="pagination">
    <% for (let i = 1; i <= totalPages; i++) { %>
      <li class="page-item <%= i === currentPage ? 'active' : '' %>">
        <a class="page-link"
       href="/?page=<%= i %>&search=<%= search %>&sort=<%= sort %>">
      <%= i %>
        </a>
      </li>
    <% } %>
  </ul>
</div>

  <!-- FOOTER -->
 <%-include('../partials/footer')%>
  </main>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>



<script>
  function swapImage(productId, thumbEl) {
    const mainImg = document.getElementById(`main-img-${productId}`);
    if (!mainImg) return;

    // Swap src values
    const tempSrc = mainImg.src;
    mainImg.src = thumbEl.src;
    thumbEl.src = tempSrc;
  }
 async function loadCategories() {
  const res = await fetch(`/listedCategories`);
  const data = await res.json();

  const container = document.getElementById('categories');
  container.innerHTML = "";

  //get multiple categories from url
  const params = new URLSearchParams(window.location.search);
  const selectedCategories = params.get('category')
    ? params.get('category').split(',') : [];

  data.categories.forEach(cat => {
    const isChecked =
      selectedCategories.includes(cat._id.toString()) ? "checked" : "";

    container.innerHTML += `
      <div>
        <input type="checkbox"
               value="${cat._id}"
               class="catCheck"
               ${isChecked}>
        ${cat.name}
      </div>`;
  });
}
loadCategories()

function applyCategoryfilter(){
const selected = [];
 document.querySelectorAll(".catCheck:checked").forEach(cb => {
    selected.push(cb.value);
  });
 const query = selected.join(",");
 window.location.href = `/?category=${query}`;

}
//wishlist btn

async function toggleWishlist(productId, btn) {
  try {
    const res = await fetch('/addToWishlist', {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ productId })
    });
    const data = await res.json();

    if (!data.success) {
      Swal.fire("Error", data.message, "error");
      return;
    }

    const icon = btn.querySelector("i");
    if (data.added) {
      icon.classList.remove("bi-heart");
      icon.classList.add("bi-heart-fill");
      btn.classList.add("wishlist-active");
    } else {
      icon.classList.remove("bi-heart-fill");
      icon.classList.add("bi-heart");
      btn.classList.remove("wishlist-active");
    }
  } catch (err) {
    console.error(err);
  }
}
</script>

</body>
</html>
