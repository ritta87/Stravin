<!DOCTYPE html>
<html lang="en">
  <head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<link rel="stylesheet" href="/css/home.css">
<style>
  .breadcrumb {
  background: none;
  padding: 10px 0;
  margin: 10px 0 20px;
  font-size: 14px;
}

.breadcrumb-item a {
  text-decoration: none;
  color: #6c757d;
}

.breadcrumb-item.active {
  color: #000;
  font-weight: 500;
}
  .wishlist-nav {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  position: relative;
}

.wishlist-nav i {
  font-size: 18px;
}

.wishlist-badge {
  position: absolute;
  top: -4px;
  left: 12px;
  min-width: 18px;
  height: 18px;
  padding: 0 5px;
  border-radius: 50px;
  background: red;
  color: white;
  font-size: 10px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid white;
}
  .product-card{
  background:#fff;
  border-radius:10px;
  padding:12px;
  box-shadow:0 3px 10px rgba(0,0,0,0.08);
  transition:0.2s;
  height:100%;
}
.product-img{
  width:100%;
  height:200px;
  object-fit:cover;
  border-radius:8px;
}
.logout-btn{
  display:none;
}
.product-details{
  margin-top:10px;
  text-align:center;
}
.product-details span{
  display:block;
}

.discount-price{
  font-size:18px;
  font-weight:700;
  color:#d32f2f;
}
.product-info{
  padding:10px;
  text-align:center;
}

.wishlist-btn{
  background: transparent;
  border: none;
  padding: 0;
  margin: 8px 0;
  cursor: pointer;
  font-size: 22px;
  line-height: 1;
}

.wishlist-btn i {
  transition: color 0.3s ease, transform 0.2s ease;
}

.wishlist-active i {
  color: red;
  transform: scale(1.2);
}
.dropdown {
  position: relative;
  display: inline-block;
}

.dropdown-toggle {
  background: none;
  border: none;
  font-weight: 500;
  cursor: pointer;
}

.dropdown-menu {
  display: none;
  position: absolute;
  background: white;
  list-style: none;
  padding: 10px;
  border: 1px solid #ddd;
  right: 0;
  min-width: 120px;
}

.dropdown-menu li {
  padding: 5px 0;
}

.dropdown-menu a {
  text-decoration: none;
  color: black;
}

.dropdown:hover .dropdown-menu {
  display: block;
}
.original-price{
  font-size:14px;
  color:#777;
  text-decoration:line-through;
}
.cart-link{
  position: relative;
  display: inline-block;
}


.cart-icon{
  font-size: 22px;
  color: #000;   /* black icon */
}
.cart-count{
  position:absolute;
  top:-6px;
  right:-8px;
  background:#000;
  color:#fff;
  font-size:10px;
  padding:2px 6px;
  border-radius:10px;
  font-weight:600;
}
.col-md-4{
  display:flex;
}
.filter-box{
  background:#fff;
  padding:18px;
  border-radius:10px;
  box-shadow:0 3px 10px rgba(0,0,0,0.08);
}
.filter-box h5{
  font-weight:600;
  margin-bottom:12px;
  border-bottom:1px solid #eee;
  padding-bottom:6px;
}
.filter-bar{
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 20px 0;
}

.filter-right{
  display: flex;
  gap: 10px;
  align-items: center;
}#categories{
  max-height:260px;
  overflow-y:auto;
  margin-bottom:12px;
}
#categories div{
  display:flex;
  align-items:center;
  gap:8px;
  padding:4px 0;
  font-size:14px;
}.catCheck{
  width:16px;
  height:16px;
  cursor:pointer;
}.filter-box .btn{
  width:100%;
  background:#ff9800;
  border:none;
  color:white;
  font-weight:600;
  padding:8px;
  border-radius:6px;
}

.filter-box .btn:hover{
  background:#e68900;
}
/* USER BUTTON */
.user-btn{
background:#222;
color:#fff;
border:none;
padding:6px 12px;
border-radius:6px;
font-size:14px;
cursor:pointer;
}

.user-btn:hover{
background:#000;
}

.dropdown-item{
  display: block;
  padding: 8px 16px;
  font-size: 14px;
  color: #d32f2f;
  text-decoration: none;
  border-radius: 6px;
  transition: background 0.2s ease;
}

.dropdown-item:hover{
  background-color: #f8f9fa;
  color: #b71c1c;
}
.carousel-item img{
    height: 450px;
    object-fit: cover;
}

.carousel-caption{
    background: rgba(0,0,0,0.4);
    padding: 15px;
    border-radius: 10px;
}

.carousel-caption h3{
    font-weight: bold;
}

.carousel-caption p{
    font-size: 18px;
}
.carousel-item{
  height: 450px;
}

.carousel-item img{
  width:100%;
  height:500px;
  object-fit:cover;
}
</style>
</head>

<body>

<header class="header">
  <div class="logo">Stravin</div>

  <!-- SEARCH FORM -->
  <form class="navbar-search d-flex" method="GET" action="/">
    <input
      class="form-control me-2"
      type="search"
      name="search"
      placeholder="Search smartwatches..."
      value="<%= typeof search !== 'undefined' ? search : '' %>">
    <button class="btn btn-dark">Search</button>
  </form>

  <nav class="nav-bar">
    <div class="nav-left">

      <a href="/">Home</a>
      <a href="/shop">Shop</a>
    <a href="/cart" class="cart-link">
     <i class="bi bi-cart3 cart-icon"></i>
      <span id="cartCount" class="cart-count">0</span>
      </a>
  
    <a href="/wishlist" class="nav-link wishlist-nav position-relative">
      <i class="bi bi-heart"></i>
      <span class="ms-1"></span>
    </a>
  
      <% if (isLoggedIn) { %>

        <div class="dropdown">
          <button class="dropdown-toggle">
            Hi, <%= user.name %>
          </button>

          <ul class="dropdown-menu">
            <li><a href="/profile" class="dropdown-item>">Profile</a></li>
            <li><a href="/logout" class="dropdown-item">Logout</a></li>
            <li><a href="/orders" class="dropdown-item">My Orders</a></li>
          </ul>
        </div>

      <% } else { %>
        <a href="/login">Login</a>
      <% } %>

    </div>
  </nav>
<script>
  //cart count
async function loadCartCount(){
  try{
    const res = await fetch('/cart/count')
    const data = await res.json()
    const cartEl = document.getElementById('cartCount')
    if(cartEl){
      cartEl.innerText = data.count
    }
  }catch(err){
    console.log("Error fetching cart count",err)
  }
}

document.addEventListener("DOMContentLoaded", loadCartCount)
</script>

</header>
  <%-include ('../partials/breadcrumbs')%>

  <!-- HERO -->
<div id="stravinCarousel" class="carousel slide" data-bs-ride="carousel">

  <!-- Indicators -->
  <div class="carousel-indicators">
    <button type="button" data-bs-target="#stravinCarousel" data-bs-slide-to="0" class="active"></button>
    <button type="button" data-bs-target="#stravinCarousel" data-bs-slide-to="1"></button>
    <button type="button" data-bs-target="#stravinCarousel" data-bs-slide-to="2"></button>
  </div>

  <!-- Images -->
  <div class="carousel-inner">

    <div class="carousel-item active">
      <img src="/images/runmode.jpg" class="d-block w-100" alt="Smartwatch Banner">
      <div class="carousel-caption">
        <h3>Stravin Smartwatch</h3>
        <p>Track your fitness with style</p>
      </div>
    </div>

    <div class="carousel-item">
      <img src="/images/smartwach-mainpic.jpg" class="d-block w-100" alt="Garmin Watch">
      <div class="carousel-caption">
        <h3>Premium Sports Watches</h3>
        <p>Performance meets technology</p>
      </div>
    </div>

    <div class="carousel-item">
      <img src="/images/coros.jpg" class="d-block w-100" alt="Coros Watch">
      <div class="carousel-caption">
        <h3>Adventure Ready</h3>
        <p>Explore with confidence</p>
      </div>
    </div>

  </div>

  <!-- Controls -->
  <button class="carousel-control-prev" type="button" data-bs-target="#stravinCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" type="button" data-bs-target="#stravinCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>

</div>



<form method="GET" action="/" class="filter-bar">

   <div class="filter-right">
    <select name="sort">
      <option value="">Sort</option>
      <option value="priceLow" <%= sort === 'priceLow' ? 'selected' : '' %>>
        Price: Low → High
      </option>
      <option value="priceHigh" <%= sort === 'priceHigh' ? 'selected' : '' %>>
        Price: High → Low
      </option>
      <option value="name" <%= sort === 'name' ? 'selected' : '' %>>
        Name A–Z
      </option>
    </select>
<button type="submit">Apply</button>
<a href="/" class="btn btn-light border">Clear</a>
</div>
<input type="hidden" name="search" value="<%= search %>">
</form>

<!-- PRODUCTS -->
<!-- PRODUCTS SECTION -->
<div class="container mt-4">

  <div class="row">

    <!-- LEFT SIDEBAR -->
    <div class="col-md-3">

      <div class="filter-box">

        <h5>Categories</h5>

        <div id="categories"></div>

        <button onclick="applyCategoryfilter()" class="btn btn-warning mt-2">
          Apply
        </button>

      </div>

    </div>


    <!-- RIGHT PRODUCT AREA -->
    <div class="col-md-9">

      <div class="row">

        <% if(products && products.length > 0){ %>

          <% products.forEach(p => { %>

            <div class="col-md-4 mb-4">

              <div class="product-card">

                <a href="/product/<%= p._id %>">
                  <img src="<%= p.images[0] %>" class="product-img">
                </a>           
<div class="product-info">
  <h6><%= p.productname %></h6>
<div class="mb-1">

  <span style="color: gold;">★★★★☆</span>

  <small class="text-muted">(120)</small>

</div>
<button class="wishlist-btn <%= wishlistProducts.includes(p._id.toString()) ? 'wishlist-active' : '' %>"
 onclick="toggleWishlist('<%= p._id %>', this)">
<i class="bi <%= wishlistProducts.includes(p._id.toString()) ? 'bi-heart-fill' : 'bi-heart' %>">
</i></button>

  
</div>
<div class="product-details">

  <% if (p.finalOffer && p.finalOffer > 0) { %>

    <span class="original-price" style="text-decoration: line-through; color: gray;">
      ₹<%= p.price %>
    </span>

    <span class="discount-price" style="color: red; font-weight: bold; margin-left: 5px;">
      ₹<%= p.finalPrice %>
    </span>

    <div>
      <span class="badge bg-success">
        <%= p.finalOffer %>% OFF
      </span>
    </div>

  <% } else { %>

    <span class="discount-price">
      ₹<%= p.price %>
    </span>

  <% } %>

</div>

              </div>

            </div>

          <% }) %>

        <% } else { %>

          <p>No products available</p>

        <% } %>

      </div>

    </div>

  </div>

</div>
      <!-- Products pagination -->
<div class="pagination-wrapper">
  <ul class="pagination">
    <% for (let i = 1; i <= totalPages; i++) { %>
      <li class="page-item <%= i === currentPage ? 'active' : '' %>">
        <a class="page-link"
       href="/?page=<%= i %>&search=<%= search %>&sort=<%= sort %>">
      <%= i %>
        </a>
      </li>
    <% } %>
  </ul>
</div>




  <!-- FOOTER -->
  <footer class="footer">
    <p>© 2026 Stravin Smartwatch Store</p>
  </footer>

<script>
  function swapImage(productId, thumbEl) {
    const mainImg = document.getElementById(`main-img-${productId}`);
    if (!mainImg) return;

    // Swap src values
    const tempSrc = mainImg.src;
    mainImg.src = thumbEl.src;
    thumbEl.src = tempSrc;
  }
 async function loadCategories() {
  const res = await fetch(`/listedCategories`);
  const data = await res.json();

  const container = document.getElementById('categories');
  container.innerHTML = "";

  //get multiple categories from url
  const params = new URLSearchParams(window.location.search);
  const selectedCategories = params.get('category')
    ? params.get('category').split(',') : [];

  data.categories.forEach(cat => {
    const isChecked =
      selectedCategories.includes(cat._id.toString()) ? "checked" : "";

    container.innerHTML += `
      <div>
        <input type="checkbox"
               value="${cat._id}"
               class="catCheck"
               ${isChecked}>
        ${cat.name}
      </div>`;
  });
}
loadCategories()

function applyCategoryfilter(){
const selected = [];
 document.querySelectorAll(".catCheck:checked").forEach(cb => {
    selected.push(cb.value);
  });
 const query = selected.join(",");
 window.location.href = `/?category=${query}`;

}
//wishlist btn

async function toggleWishlist(productId, btn) {
  try {
    const res = await fetch('/addToWishlist', {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ productId })
    });
    const data = await res.json();

    if (!data.success) {
      Swal.fire("Error", data.message, "error");
      return;
    }

    const icon = btn.querySelector("i");
    if (data.added) {
      icon.classList.remove("bi-heart");
      icon.classList.add("bi-heart-fill");
      btn.classList.add("wishlist-active");
    } else {
      icon.classList.remove("bi-heart-fill");
      icon.classList.add("bi-heart");
      btn.classList.remove("wishlist-active");
    }
  } catch (err) {
    console.error(err);
  }
}
</script>

</body>
</html>