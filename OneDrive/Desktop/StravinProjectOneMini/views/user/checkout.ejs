}
/* ===== NAV ALIGNMENT  ===== */
.nav-left {
  display: flex;
  align-items: center;
  gap: 18px; 
}

.nav-left a,
.nav-left .dropdown {
  display: flex;
  align-items: center;
}

/* ===== DROPDOWN POSITION  ===== */

.dropdown {
  position: relative;
}


.dropdown-menu {
  position: absolute;
  top: 100%;   
  right: 0;

  display: none;
  z-index: 999;
}


.dropdown:hover .dropdown-menu,
.dropdown-menu:hover {
  display: block;
}

.dropdown-item {
  display: block;
  padding: 8px 14px;
  transition: 0.2s ease;
