  }

  /* PRICE BOX */
  .right p {
    display: flex;
    justify-content: space-between;
    margin: 8px 0;
    font-size: 14px;
  }
hr {
  margin: 8px 0;
  border-color: #ddd;
}
  .right h3 {
    margin-top: 0;
  }

  .right hr {
    margin: 10px 0;
  }

  /* TOTAL */
  .total {
    font-size: 18px;
    font-weight: bold;
  }

  /* BUTTON */
  .btn-order {
    width: 100%;
    padding: 12px;
    background: #2c3e50;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 15px;
    cursor: pointer;
    margin-top: 15px;
    transition: 0.3s;
  }

  .btn-order:hover {
    background: #1a252f;
  }

  /* RESPONSIVE */
  @media(max-width: 768px) {
    .container {
      flex-direction: column;
    }

    .left, .right {
      width: 100%;
    }
  }
  .place-order-btn {
