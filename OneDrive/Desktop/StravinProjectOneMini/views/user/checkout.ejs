<script>
  //cart count
async function loadCartCount(){
  try{
    const res = await fetch('/cart/count')
    const data = await res.json()
    const cartEl = document.getElementById('cartCount')
    if(cartEl){
      cartEl.innerText = data.count
    }
  }catch(err){
    console.log("Error fetching cart count",err)
  }
}
document.addEventListener("DOMContentLoaded", loadCartCount)
</script>
</header>
<%- include('../partials/breadcrumbs') %>

<body>
<h2>Checkout</h2>
<a href="/cart" class="go-cart-btn">Go to cart</a>
<div class="container">

  <!-- LEFT SIDE -->
  <div class="left">
    <!-- ADDRESS -->
    <h3>Select Address</h3>

    <% addresses.forEach(addr => { %>
      <div class="address-card <%= addr.isDefault ? 'default' : '' %>">

        <input type="radio" name="address"
          value="<%= addr._id %>"
          <%= addr.isDefault ? "checked" : "" %> />

        <p><strong><%= addr.name %></strong></p>
        <p><%=addr.house%></p>
        <p><%= addr.address %>
             <%= addr.city %></p>
             <p><%=addr.state%></p>
        <p><%=addr.pincode%></p><p><%=addr.landmark%></p>
        <p><%= addr.mobile %></p>

        <a href="/profile/address/edit/<%= addr._id %>" class="edit-btn">Edit</a>
      </div>
    <% }) %>

    <a href="/profile/address/add" class="add-address-btn">+ Add New Address</a>

    <hr>

    <!-- PRODUCTS -->
    <h3>Products</h3>

    <% cart.items.forEach(item => { %>
      <div class="product-row">

        <img src="<%= item.product.images[0] %>" width="60">

        <div>
          <p><%= item.product.productname %></p>
          <p>Color: <%= item.variant.color %></p>
          <p>Qty: <%= item.quantity %></p>
          <p>₹ <%= item.price * item.quantity %></p>
          
        </div>

      </div>
    <% }) %>

  </div>

  <!-- RIGHT SIDE -->
  <div class="right">

    <div class="price-box">
    <h3>Price Details</h3>

    <div class="price-row">
      <span>SubTotal</span>
      <span id="subTotal"> <%= subTotal %></span>
    </div>

<div class="price-row">
    <span>Tax (5%)</span>
    <span class="amount" id="tax"><%= tax %></span>
    </div>
    <p class="tax-note">(Included in total amount.)</p>

    <div class="price-row">
      <span>Shipping</span>
      <span id="shipping"> <%= shipping %></span>
    </div>

<div class="coupon-box">
  <input type="text" id="couponCode" placeholder="Enter coupon code"
    value="<%= appliedCoupon || '' %>">
  <button onclick="applyCoupon()" class="apply-btn">Apply</button>
</div>

<p id="appliedCouponText" style="color:green;">
  <% if (appliedCoupon) { %>
    Coupon <strong><%= appliedCoupon %></strong> applied 🎉  
  <% } %>
</p>

<button id="removeCouponBtn" onclick="removeCoupon()" class="remove-btn"
  <% if (appliedCoupon) { %>
    style="display: inline-block;"
  <% } else { %>
    style="display: none;"
  <% } %>>
  Remove Coupon </button>

<p id="couponError" style="color:red; font-size:14px;"></p>
<div class="price-row">
  <span>Coupon Discount</span>
  <span style="color:green;">- ₹ <span id="discount"><%= discount || 0 %></span></span>
</div>



<hr>
<div class="price-row">
  <span>Total</span>
  <span>₹ <span id="grandTotal"><%= totalAmount %></span></span>
</div>







<div class="price-summary">
  <span>Amount to Pay</span>
  <span>₹ <span id="finalTotalText"><%= finalTotal %></span></span>
</div>


<form id="checkoutForm">
   <h5>Payment Method</h5>
  <div class="form-check">
    <input class="form-check-input" type="radio" name="paymentMethod" id="cod" value="COD" checked>
    <label class="form-check-label" for="cod">Cash on Delivery</label>
  </div>

  <div class="form-check">
    <input class="form-check-input" type="radio" name="paymentMethod" id="wallet" value="WALLET" checked>
    <label class="form-check-label" for="wallet">Wallet Payment</label>
  </div>

  <div class="form-check">
    <input class="form-check-input" type="radio" name="paymentMethod" id="online" value="ONLINE">
    <label class="form-check-label" for="online">Pay Online</label>
  </div>

  <button type="submit" class="btn btn-primary mt-3">Place Order</button>
</form>

  </div>

</div>
<script>
document.addEventListener("DOMContentLoaded", () => {

  const form = document.getElementById("checkoutForm");

  form.addEventListener("submit", async e => {
    e.preventDefault();

const selectedAddressId = document.querySelector('input[name="address"]:checked').value;
    if (!selectedAddressId) {
      return Swal.fire("Error", "Please select an address", "error");
    }

    

    const paymentInput = document.querySelector('input[name="paymentMethod"]:checked');
    if (!paymentInput) {
      return Swal.fire("Error", "Please select payment method", "error");
    }

    const paymentMethod = paymentInput.value;

    try {
      const res = await fetch('/placeOrder', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ addressId:selectedAddressId, paymentMethod }),
        credentials: 'include'
      });

      const data = await res.json();
      console.log("PlaceOrder Response:", data);

      if (!data.success) {
        return Swal.fire("Error", data.message || "Order not placed", "error");
      }

    
      if (data.payment === "COD") {
        window.location.href = `/orderSuccess/${data.orderId}`;
        return;
      }

    
      if (data.payment === "ONLINE") {
        openRazorpayCheckout(data,selectedAddressId);
      }

    } catch (error) {
      console.error("Order creation failed:", error);
      Swal.fire("Error", "Something went wrong", "error");
    }
  });


  function openRazorpayCheckout(data,selectedAddressId) {

    const options = {
      key: "<%= razorpayKey %>",
      amount: data.razorpay.amount,
      currency: "INR",
      order_id: data.razorpay.id,

      handler: async function (response) {

        console.log("Payment Success:", response);

        const verifyRes = await fetch("/verifyPayment", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            ...response,
            cartData: data.cartData,
            addressId: selectedAddressId,
            orderId: data.orderId
          }),
          credentials: 'include'
        });

        const verifyData = await verifyRes.json();

        if (verifyData.success) {
          window.location.href = `/orderSuccess/${verifyData.orderId}`;
        } else {
        window.location.href = `/orderFailure/${data.orderId}`;
        }
      }
    };

  const rzp = new Razorpay(options);
 rzp.on("payment.failed", async function(response) {

  await fetch("/paymentFailed", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      orderId: data.orderId,
      error: response.error
    })
  })

  window.location.href = `/orderFailure/${data.orderId}`;
})

    rzp.open();
  }

})
//apply coupon---------------------

async function applyCoupon() {
  const code = document.getElementById("couponCode").value.trim();
  const errorBox = document.getElementById("couponError");
  const appliedText = document.getElementById("appliedCouponText");

  errorBox.innerText = "";
  appliedText.innerText = "";

  if (!code) {
    errorBox.innerText = "Please enter a coupon code";
    return;
  }

  try {
    const res = await fetch("/applyCoupon", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ couponCode: code })
    });

    const data = await res.json();
 if (data.success) {
    document.getElementById("discount").innerText = data.discount||0;
    document.getElementById("grandTotal").innerText = data.finalTotal;
    document.getElementById("finalTotalText").innerText = data.finalTotal;

    document.getElementById("appliedCouponText").innerText =`Coupon ${data.couponCode} applied`;
    document.getElementById("removeCouponBtn").style.display = "inline-block";
  } else {
    document.getElementById("couponError").innerText = data.message;
  }


  } catch (err) {
    console.error(err);
    errorBox.innerText = "Something went wrong. Try again.";
  }
}
//coupon remove.............
async function removeCoupon() {
  try {
    const res = await fetch("/removeCoupon", {
      method: "POST"
    });

    const data = await res.json();

    if (data.success) {
      document.getElementById("discount").innerText = 0;
      document.getElementById("grandTotal").innerText = data.finalTotal;
      document.getElementById("finalTotalText").innerText = data.finalTotal;

      document.getElementById("appliedCouponText").innerText = "";
      document.getElementById("couponCode").value = "";

      // hide button 
      document.getElementById("removeCouponBtn").style.display = "none";

      Swal.fire("Removed","Coupon removed successfully","success");
    }

  } catch (err) {
    console.error(err);
  }
}


async function loadCartSummary() {
  try {
    const res = await fetch("/cart");
    const data = await res.json();

    document.getElementById("discount").innerText = data.discount || 0;
    document.getElementById("grandTotal").innerText = data.finalTotal;
    document.getElementById("finalTotalText").innerText = data.finalTotal;

    if (data.coupon) {
      document.getElementById("appliedCouponText").innerText =
        `Coupon ${data.coupon} applied`;

      document.getElementById("removeCouponBtn").style.display = "inline-block";
      document.getElementById("couponCode").value = data.coupon;
    } else {
      document.getElementById("removeCouponBtn").style.display = "none";
    }

  } catch (err) {
    console.error("Cart load error:", err);
  }
}
document.addEventListener("DOMContentLoaded", loadCartSummary);
</script>
</body>
</html>