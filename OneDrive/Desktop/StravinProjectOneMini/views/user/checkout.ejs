/* Go to Cart button */
/* spacing fix */
/* Checkout heading */
h2 {
  margin-bottom: 10px;
}

/* Go to Cart button */
.go-cart-btn {
  display: inline-block;

  margin: 10px 0 20px 0;  

  padding: 10px 18px;
  background-color: #198754;
  color: #fff;

  border-radius: 6px;
  text-decoration: none;
}

/* address box */
.address-box {
  margin-top: 10px;
}
/* hover */
.go-cart-btn:hover {
  background-color: #157347;
  color: #fff;
}
/* Coupon Section Container */
.coupon-box {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 15px;
}

/* Input Field */
#couponCode {
  padding: 10px 12px;
  border: 1px solid #ccc;
  border-radius: 6px;
  outline: none;
  width: 200px;
  transition: 0.3s;
  font-size: 14px;
}

#couponCode:focus {
  border-color: #007bff;
  box-shadow: 0 0 4px rgba(0,123,255,0.3);
}

/* Apply Button */
.apply-btn {
  padding: 10px 16px;
  border: none;
  background-color: #28a745;
