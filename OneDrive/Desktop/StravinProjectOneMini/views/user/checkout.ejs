<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<link rel="stylesheet" href="/css/navbar.css">
<link rel="stylesheet" href="/css/pages/footer.css">

<script src="/js/navbar.js"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
/* MAIN LAYOUT */
.container {
  max-width: 1200px;
  margin: 30px auto;
  padding: 0 20px;

  display: flex;
  gap: 30px;
  align-items: flex-start;
}

.left {
  flex: 2;
}

.right {
  flex: 1;
  min-width: 300px;

  position: sticky;
  top: 100px;
}

/* ADDRESS CARD */
.address-card {
  background: #fff;
  border-radius: 10px;
  padding: 15px;
  margin-bottom: 15px;
  border: 1px solid #eee;
  transition: 0.2s;
}

.address-card:hover {
  border-color: #198754;
}

.address-card.default {
  border: 2px solid #198754;
}

/* ADD BUTTON */
.add-address-btn {
  display: inline-block;
  margin: 10px 0 20px;
  padding: 8px 14px;
  background: #198754;
  color: #fff;
  border-radius: 6px;
  text-decoration: none;
}

/* PRODUCT ROW */
.product-row {
  display: flex;
  gap: 15px;
  background: #fff;
  padding: 12px;
  border-radius: 10px;
  margin-bottom: 12px;
  border: 1px solid #eee;
  align-items: center;
}

/* IMAGE */
.product-row img {
  width: 70px;
  height: 70px;
  object-fit: cover;
  border-radius: 8px;
}

/* TEXT */
.product-row p {
  margin: 2px 0;
  font-size: 14px;
}

/* PRICE BOX */
.price-box {
  background: #fff;
  padding: 20px;
  border-radius: 12px;
  border: 1px solid #eee;
  box-shadow: 0 4px 10px rgba(0,0,0,0.05);
}

/* ROWS */
.price-row {
  display: flex;
  justify-content: space-between;
  margin: 10px 0;
  font-size: 14px;
}

/* FINAL TOTAL */
.price-summary {
  display: flex;
  justify-content: space-between;
  font-size: 18px;
  font-weight: 600;
  margin-top: 15px;
}

/* COUPON */
.coupon-box {
  display: flex;
  gap: 10px;
  margin-top: 10px;
}

.coupon-box input {
  flex: 1;
  padding: 8px;
  border: 1px solid #ddd;
  border-radius: 6px;
}

.apply-btn {
  background: #198754;
  color: #fff;
  border: none;
  padding: 8px 14px;
  border-radius: 6px;
  cursor: pointer;
}

.remove-btn {
  background: #dc3545;
  color: #fff;
  border: none;
  padding: 6px 12px;
  border-radius: 6px;
  margin-top: 8px;
}

/* PLACE ORDER */
#checkoutForm button {
  width: 100%;
  padding: 12px;
  margin-top: 15px;
  background: #198754;
  border: none;
  color: #fff;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
}

/* RESPONSIVE */
@media (max-width: 768px) {
  .container {
    flex-direction: column;
  }

  .right {
    position: static;
  }
}
</style>
 <%- include('../partials/navbar') %>
  <%- include('../partials/breadcrumbs') %>
</header>


<body>

<div class="container">
  <!-- LEFT SIDE -->
  <div class="left">

    <!-- ADDRESS -->
    <h3>Select Address</h3>

    <% addresses.forEach(addr => { %>
      <div class="address-card <%= addr.isDefault ? 'default' : '' %>">

        <input type="radio" name="address"
          value="<%= addr._id %>"
          <%= addr.isDefault ? "checked" : "" %> />

        <p><strong><%= addr.name %></strong></p>
        <p><%= addr.house %></p>
        <p><%= addr.address %>, <%= addr.city %></p>
        <p><%= addr.state %></p>
        <p><%= addr.pincode %></p>
        <p><%= addr.landmark %></p>
        <p><%= addr.mobile %></p>

        <a href="/profile/address/edit/<%= addr._id %>" class="edit-btn">Edit</a>
      </div>
    <% }) %>

    <a href="/profile/address/add" class="add-address-btn">+ Add New Address</a>

    <hr>

    <!-- PRODUCTS -->
    <h3>Products</h3>

    <% cartItems.forEach(item => { %>
      <div class="product-row">

        <img src="<%= item.product.images[0] %>">

        <div>
          <p><%= item.product.productname %></p>
          <p>Color: <%= item.variant.color %></p>
          <p>Qty: <%= item.quantity %></p>
          <p>₹ <%= item.price * item.quantity %></p>

          <p class="<%= item.isOutOfStock ? 'text-danger' : 'text-success' %>">
            <%= item.isOutOfStock ? 'Out of Stock' : 'Available' %>
          </p>
        </div>

      </div>
    <% }) %>

  </div> 


  <!-- RIGHT SIDE -->
  <div class="right">

    <div class="price-box">

      <h3>Price Details</h3>

      <div class="price-row">
        <span>SubTotal</span>
        <span><%= subTotal %></span>
      </div>

      <div class="price-row">
        <span>Tax (5%)</span>
        <span><%= tax %></span>
      </div>

      <p class="tax-note">(Included in total amount.)</p>
      <div class="price-row">
        <span>Shipping</span>
        <span><%= shipping %></span>
      </div>

<div class="coupon-box">
    <input type="text" id="couponCode" placeholder="Enter coupon code"
      value="<%= appliedCoupon || '' %>">
      <button onclick="applyCoupon()" class="apply-btn">Apply</button>
  </div>
<div class="coupon-section">
  <p id="appliedCouponText" class="coupon-success">
    <% if (appliedCoupon) { %>
      Coupon <strong><%= appliedCoupon %></strong> applied 🎉
    <% } %>
  </p>

  <button id="removeCouponBtn" onclick="removeCoupon()" class="remove-btn"
    <%= appliedCoupon ? '' : 'style="display:none;"' %>>
    Remove Coupon
  </button>

  <p id="couponError" class="coupon-error"></p>

  <div id="couponDiscountRow" class="price-row coupon-discount-row"
       <%= discount ? '' : 'style="display:none;"' %>>
    <span>Coupon Discount</span>
    <span id="discount" class="discount-amount">- ₹ <%= discount || 0 %></span>
  </div>
</div>
<hr>
<div class="price-row">
  <span>Total</span>
  <span id="grandTotal">₹ <%= totalAmount %></span>
</div>
<div class="price-summary">
  <span>Amount to Pay</span>
  <span id="finalTotalText">₹ <%= finalTotal %></span>
</div>
  <form id="checkoutForm">
        <h5>Payment Method</h5>

        <label><input type="radio" name="paymentMethod" value="COD" checked> COD</label><br>
        <label><input type="radio" name="paymentMethod" value="WALLET"> Wallet</label><br>
        <label><input type="radio" name="paymentMethod" value="ONLINE"> Online</label>

        <button type="submit" <%= outOfStockExists ? 'disabled' : '' %>>
          Place Order
        </button>
      </form>

    </div>

  </div> 

</div> 
<%-include('../partials/footer')%>
<script>
document.addEventListener("DOMContentLoaded", () => {
  const form = document.getElementById("checkoutForm");
  form.addEventListener("submit", async e => {
    e.preventDefault();
const selectedAddress = document.querySelector('input[name="address"]:checked');
    if (!selectedAddress) {
      return Swal.fire("Error","Please select an address","error");
    }
    let selectedAddressId = selectedAddress.value;
    const paymentInput = document.querySelector('input[name="paymentMethod"]:checked');
    if (!paymentInput) {
      return Swal.fire("Error", "Please select payment method", "error");
    }
 const paymentMethod = paymentInput.value;
    try {
      const res = await fetch('/placeOrder', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ addressId:selectedAddressId, paymentMethod}),
        credentials: 'include'
      });

      const data = await res.json();
      

      if (!data.success) {
        return Swal.fire("Error", data.message || "Order not placed", "error");
      }

    
      if (data.payment === "COD") {
        window.location.href = `/orderSuccess/${data.orderId}`;
        return;
      }
      if(data.payment === "WALLET"){
        window.location.href = `/orderSuccess/${data.orderId}`;
        return
      }
    
      if (data.payment === "ONLINE") {
        openRazorpayCheckout(data,selectedAddressId);
      }

    } catch (error) {
      console.error("Order creation failed:", error);
      Swal.fire("Error", "Something went wrong", "error");
    }
  });


  function openRazorpayCheckout(data,selectedAddressId) {

    const options = {
      key: "<%= razorpayKey %>",
      amount: data.razorpay.amount,
      currency: "INR",
      order_id: data.razorpay.id,

      handler: async function (response) {

        console.log("Payment Success:", response);

        const verifyRes = await fetch("/verifyPayment", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            ...response,
            cartData: data.cartData,
            addressId: selectedAddressId,
            orderId: data.orderId
          }),
          credentials: 'include'
        });

        const verifyData = await verifyRes.json();

        if (verifyData.success) {
          window.location.href = `/orderSuccess/${verifyData.orderId}`;
        } else {
        window.location.href = `/orderFailure/${data.orderId}`;
        }
      }
    };

  const rzp = new Razorpay(options);
 rzp.on("payment.failed", async function(response) {

  await fetch("/paymentFailed", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      orderId: data.orderId,
      error: response.error
    })
  })

  window.location.href = `/orderFailure/${data.orderId}`;
})

    rzp.open();
  }

})
//apply coupon---------------------

async function applyCoupon() {
  const couponInput = document.getElementById("couponCode");
  const errorBox = document.getElementById("couponError");
  const appliedText = document.getElementById("appliedCouponText");

if (errorBox) errorBox.innerText = "";
if (appliedText) appliedText.innerText = "";

  const code = couponInput?.value.trim();
  if (!code) {
    if (errorBox) errorBox.innerText = "Please enter a coupon code";
    return;
  }

  try {
    const res = await fetch("/applyCoupon", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ couponCode: code })
    });

    const data = await res.json();
    console.log("coupon response:", data);

    if (data.success) {
      const discountEl = document.getElementById("discount");
      const grandTotalEl = document.getElementById("grandTotal");
      const finalTotalTextEl = document.getElementById("finalTotalText");
      const removeBtn = document.getElementById("removeCouponBtn");

      console.log({
        discountEl,
        grandTotalEl,
        finalTotalTextEl,
        appliedText,
        removeBtn
      });

      if (discountEl) discountEl.innerText = data.discount || 0;
      if (grandTotalEl) grandTotalEl.innerText = data.finalTotal;
      if (finalTotalTextEl) finalTotalTextEl.innerText = data.finalTotal;
      if (appliedText) appliedText.innerText = `Coupon ${data.couponCode} applied`;
      if (removeBtn) removeBtn.style.display = "inline-block";
    } else {
      if (errorBox) errorBox.innerText = data.message || "Invalid Coupon!";
    }

  } catch (err) {
    console.error("applyCoupon error:", err);
    if (errorBox) errorBox.innerText = "Something went wrong. Try again.";
  }
}
//coupon remove.............
async function removeCoupon() {
  try {
    const res = await fetch("/removeCoupon", {
      method: "POST"
    });

    const data = await res.json();

    if (data.success) {
      document.getElementById("discount").innerText = 0;
      document.getElementById("grandTotal").innerText = data.finalTotal;
      document.getElementById("finalTotalText").innerText = data.finalTotal;

      document.getElementById("appliedCouponText").innerText = "";
      document.getElementById("couponCode").value = "";

      // hide button 
      document.getElementById("removeCouponBtn").style.display = "none";

      Swal.fire("Removed","Coupon removed successfully","success");
    }

  } catch (err) {
    console.error(err);
  }
}


async function loadCartSummary() {
  try {
    const res = await fetch("/cart");
    const data = await res.json();

    document.getElementById("discount").innerText = data.discount || 0;
    document.getElementById("grandTotal").innerText = data.finalTotal;
    document.getElementById("finalTotalText").innerText = data.finalTotal;

    if (data.coupon) {
      document.getElementById("appliedCouponText").innerText =
        `Coupon ${data.coupon} applied`;

      document.getElementById("removeCouponBtn").style.display = "inline-block";
      document.getElementById("couponCode").value = data.coupon;
    } else {
      document.getElementById("removeCouponBtn").style.display = "none";
    }

  } catch (err) {
    console.error("Cart load error:", err);
  }
}
document.addEventListener("DOMContentLoaded", loadCartSummary);
</script>

</body>

</html>