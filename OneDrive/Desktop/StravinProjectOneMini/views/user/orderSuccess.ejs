<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title></title>

  <!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
.success-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 80vh;
}

.success-box {
  text-align: center;
  background: #fff;
  padding: 40px;
  border-radius: 12px;
  box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}

.success-box h1 {
  color: #28a745;
  margin-bottom: 10px;
}

.order-id {
  margin: 15px 0;
  font-size: 14px;
  color: #555;
}

.btn-group {
  margin-top: 20px;
}

.btn {
  padding: 10px 20px;
  border-radius: 6px;
  text-decoration: none;
  margin: 0 10px;
  display: inline-block;
}

.view-order {
  background: #007bff;
  color: white;
}

.continue {
  background: #6c757d;
  color: white;
}
</style></head>
<body>
<div class="success-container">

  <div class="success-box">
    
    <h1>🎉 Order Placed Successfully!</h1>
    <p>Thank you for shopping with us 💖</p>

    <p class="order-id">
      Order ID: <strong><%= order.orderId %></strong>
    </p>

    <div class="btn-group">
    <a href="/orders"> View Order
      </a>

      <a href="/" class="btn continue">
        Continue Shopping
      </a>
    </div>

  </div>

</div></body>
</html>