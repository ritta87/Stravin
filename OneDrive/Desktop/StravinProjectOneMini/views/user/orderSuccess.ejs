<!DOCTYPE html>
<html lang="en">
  <head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<link rel="stylesheet" href="/css/navbar.css">
<link rel="stylesheet" href="/css/pages/footer.css">

<script src="/js/navbar.js"></script>
<style>
/* ===== Order Success Page Wrapper ===== */
.order-success-wrapper {
  max-width: 1200px;
  margin: 40px auto;
  padding: 0 20px;
  display: flex;
  gap: 24px;
  align-items: flex-start;
  flex-wrap: wrap;
}

/* ===== Left / Right Sections ===== */
.left-section {
  flex: 2;
  min-width: 320px;
}

.right-section {
  flex: 1;
  min-width: 300px;
  position: sticky;
  top: 100px;
}

/* ===== Common Card Style ===== */
.success-box,
.payment-box,
.price-card {
  background: #ffffff;
  border-radius: 18px;
  padding: 24px;
  margin-bottom: 22px;
  border: 1px solid #ececec;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.06);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.success-box:hover,
.payment-box:hover,
.price-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 14px 34px rgba(0, 0, 0, 0.08);
}

/* ===== Headings ===== */
.success-box h3,
.payment-box h5,
.price-card h5 {
  margin-bottom: 18px;
  color: #1f1f1f;
  font-weight: 700;
  line-height: 1.3;
}

.success-box h3 {
  font-size: 26px;
}

.payment-box h5,
.price-card h5 {
  font-size: 20px;
}

/* ===== Paragraph / Text ===== */
.success-box p,
.payment-box p,
.price-card p,
.note,
.save-msg {
  margin: 10px 0;
  color: #555;
  font-size: 15px;
  line-height: 1.6;
}

.success-box strong,
.payment-box strong,
.price-card strong {
  color: #222;
}

/* ===== Row Layout ===== */
.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  margin: 12px 0;
  font-size: 15px;
  color: #444;
}

.row span:last-child,
.row strong:last-child {
  text-align: right;
}

/* ===== Buttons ===== */
.view-orders-btn {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 20px;
}

.view-orders-btn a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 150px;
  padding: 12px 18px;
  border-radius: 10px;
  text-decoration: none;
  font-size: 14px;
  font-weight: 600;
  transition: all 0.25s ease;
  border: 1px solid transparent;
}

.view-orders-btn a:first-child {
  background: #111;
  color: #fff;
}

.view-orders-btn a:first-child:hover {
  background: #000;
  transform: translateY(-1px);
}

.view-orders-btn .continue {
  background: #f4f4f4;
  color: #222;
  border: 1px solid #ddd;
}

.view-orders-btn .continue:hover {
  background: #eaeaea;
  transform: translateY(-1px);
}

/* ===== Status Badges ===== */
.status {
  display: inline-block;
  padding: 6px 12px;
  border-radius: 30px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.3px;
}

.status.cod {
  background: #fff3cd;
  color: #856404;
}

.status.success {
  background: #d1f3dc;
  color: #198754;
}

.status.pending {
  background: #d9f1ff;
  color: #0c5460;
}

/* ===== Notes ===== */
.note {
  margin-top: 14px;
  padding: 12px 14px;
  border-radius: 10px;
  font-size: 14px;
}

.note.success {
  background: #edf9f1;
  color: #198754;
  border: 1px solid #cfead8;
}

.note.warning {
  background: #fff8e1;
  color: #856404;
  border: 1px solid #f2df9b;
}

/* ===== Price Card ===== */
.price-card {
  background: linear-gradient(180deg, #ffffff 0%, #fcfcfc 100%);
}

.price-card h5 {
  padding-bottom: 12px;
  border-bottom: 1px solid #efefef;
  margin-bottom: 16px;
}

.discount {
  color: #198754;
  font-weight: 600;
}

.divider {
  border-top: 1px dashed #d5d5d5;
  margin: 16px 0;
}

.total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10px;
  font-size: 20px;
  font-weight: 700;
  color: #111;
}

.save-msg {
  margin-top: 14px;
  font-size: 14px;
  color: #198754;
  font-weight: 500;
  background: #eefaf2;
  padding: 10px 12px;
  border-radius: 10px;
  border: 1px solid #d7efdf;
}

/* ===== Responsive ===== */
@media (max-width: 992px) {
  .order-success-wrapper {
    flex-direction: column;
  }

  .left-section,
  .right-section {
    width: 100%;
    min-width: 100%;
  }

  .right-section {
    position: static;
    top: unset;
  }
}

@media (max-width: 768px) {
  .order-success-wrapper {
    padding: 0 14px;
    margin: 24px auto;
    gap: 18px;
  }

  .success-box,
  .payment-box,
  .price-card {
    padding: 18px;
    border-radius: 14px;
  }

  .success-box h3 {
    font-size: 22px;
  }

  .payment-box h5,
  .price-card h5 {
    font-size: 18px;
  }

  .row,
  .total {
    font-size: 15px;
  }
}

@media (max-width: 480px) {
  .order-success-wrapper {
    padding: 0 10px;
  }

  .success-box,
  .payment-box,
  .price-card {
    padding: 16px;
  }

  .row,
  .total {
    flex-direction: column;
    align-items: flex-start;
  }

  .view-orders-btn a {
    width: 100%;
  }

  .success-box h3 {
    font-size: 20px;
  }
}
</style><%- include('../partials/navbar') %>
<%-include ('../partials/breadcrumbs')%>
</head>

<body>
<div class="order-success-wrapper">

  <!-- LEFT -->
  <div class="left-section">
    <!-- success box -->
    <div class="success-box">
      <h1>🎉 Order Placed Successfully!</h1>
      <p>Thank you for shopping with us 💖</p>

      <p class="order-id">
        Order ID: <strong><%= order.orderId %></strong>
      </p>

      <div class="view-orders-btn">
        <a href="/orders">View Orders</a>
        <a href="/" class="continue">Continue Shopping</a>
      </div>
    </div>

    <!-- payment box -->
   <div class="payment-box">
  <h5>Payment Information</h5>

  <p><strong>Method:</strong> 
    <% if(order.paymentMethod === "COD") { %>
      Cash on Delivery
    <% } else if(order.paymentMethod === "WALLET") { %>
      Wallet Payment
    <% } else { %>
      Online Payment
    <% } %>
  </p>

  <p><strong>Status:</strong> 
    <% if(order.paymentMethod === "COD") { %>
      <span class="status cod">Pay on Delivery</span>
    <% } else if(order.paymentStatus === "Paid") { %>
      <span class="status success">Paid</span>
    <% } else { %>
      <span class="status pending">Pending</span>
    <% } %>
  </p>

  <% if(order.paymentMethod === "COD") { %>
    <p class="note warning">
      Pay ₹<%= order.finalTotal %> on delivery
    </p>
  <% } else if(order.paymentMethod === "WALLET" && order.walletInfo) { %>
    <p class="note success">
      Amount ₹<%= order.walletInfo.walletUsed %> paid from wallet.<br>
      Remaining Wallet Balance: ₹<%= order.walletInfo.remainingWallet %>
    </p>
  <% } else if(order.paymentStatus === "Paid") { %>
    <p class="note success">
      Payment received. Order processing 🚀
    </p>
  <% } %>
</div>
  <!-- RIGHT -->
  <div class="right-section">
    <div class="price-card">

      <h5>Price Details</h5>

      <div class="row">
        <span>Subtotal</span>
        <span>₹<%= order.subTotal %></span>
      </div>

      <div class="row">
        <span>Tax</span>
        <span>₹<%= order.tax %></span>
      </div>

      <div class="row">
        <span>Shipping</span>
        <span>₹<%= order.shipping %></span>
      </div>

      <% if(order.coupon && order.coupon.discountAmount > 0) { %>
      <div class="row discount">
        <span>Discount (<%= order.coupon.code %>)</span>
        <span>-₹<%= order.coupon.discountAmount %></span>
      </div>
      <% } %>

      <div class="divider"></div>

      <div class="total">
        <span>Total</span>
        <span>₹<%= order.finalTotal %></span>
      </div>

      <% if(order.coupon && order.coupon.discountAmount > 0) { %>
        <p class="save-msg">
          You saved ₹<%= order.coupon.discountAmount %> 🎉
        </p>
      <% } %>

    </div>
  </div>

</div>
<%-include('../partials/footer')%>
</body>
</html>