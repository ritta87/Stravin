<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title></title>

  <!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
.order-success-wrapper {
  max-width: 1100px;   
  margin: 40px auto;   
  padding: 0 20px;     

  display: flex;
  gap: 30px;
  flex-wrap: wrap;
}
.left-section {
  flex: 2;
  min-width: 300px;
}

.right-section {
  flex: 1;
  min-width: 280px;
}

/* cards */
.success-box,
.payment-box,
.price-card {
  background: #fff;
  padding: 20px;
  border-radius: 12px;
  margin-bottom: 20px;
  box-shadow: 0 4px 15px rgba(0,0,0,0.08);
}

/* buttons */
.view-orders-btn a {
  display: inline-block;
  margin-right: 10px;
  padding: 8px 14px;
  border-radius: 6px;
  text-decoration: none;
  background: #000;
  color: #fff;
}

.view-orders-btn .continue {
  background: #eee;
  color: #333;
}

/* payment status */
.status {
  padding: 4px 10px;
  border-radius: 20px;
  font-size: 12px;
}

.status.cod { background: #fff3cd; }
.status.success { background: #d4edda; color: green; }
.status.pending { background: #d1ecf1; }

/* notes */
.note {
  margin-top: 10px;
  font-size: 14px;
}

.note.success { color: green; }
.note.warning { color: #856404; }

/* price section */
.price-card h5 {
  margin-bottom: 15px;
}

.row {
  display: flex;
  justify-content: space-between;
  margin: 8px 0;
}

.discount {
  color: green;
}

.divider {
  border-top: 1px dashed #ccc;
  margin: 10px 0;
}

.total {
  display: flex;
  justify-content: space-between;
  font-weight: bold;
  font-size: 18px;
}

.save-msg {
  margin-top: 10px;
  color: green;
  font-size: 13px;
}
</style></head>
<body>
<div class="order-success-wrapper">

  <!-- LEFT -->
  <div class="left-section">
    <!-- success box -->
    <div class="success-box">
      <h1>🎉 Order Placed Successfully!</h1>
      <p>Thank you for shopping with us 💖</p>

      <p class="order-id">
        Order ID: <strong><%= order.orderId %></strong>
      </p>

      <div class="view-orders-btn">
        <a href="/orders">View Orders</a>
        <a href="/" class="continue">Continue Shopping</a>
      </div>
    </div>

    <!-- payment box -->
    <div class="payment-box">
      <h5>Payment Information</h5>

      <p><strong>Method:</strong> 
        <%= order.paymentMethod === "COD" ? "Cash on Delivery" : "Online Payment" %>
      </p>

      <p><strong>Status:</strong> 
        <% if(order.paymentMethod === "COD") { %>
          <span class="status cod">Pay on Delivery</span>
        <% } else if(order.paymentStatus === "Paid") { %>
          <span class="status success">Paid</span>
        <% } else { %>
          <span class="status pending">Pending</span>
        <% } %>
      </p>

      <% if(order.paymentMethod === "COD") { %>
        <p class="note warning">
          Pay ₹<%= order.finalTotal %> on delivery
        </p>
      <% } else if(order.paymentStatus === "Paid") { %>
        <p class="note success">
          Payment received. Order processing 🚀
        </p>
      <% } %>
    </div>
  </div>

  <!-- RIGHT -->
  <div class="right-section">
    <div class="price-card">

      <h5>Price Details</h5>

      <div class="row">
        <span>Subtotal</span>
        <span>₹<%= order.subTotal %></span>
      </div>

      <div class="row">
        <span>Tax</span>
        <span>₹<%= order.tax %></span>
      </div>

      <div class="row">
        <span>Shipping</span>
        <span>₹<%= order.shipping %></span>
      </div>

      <% if(order.coupon && order.coupon.discountAmount > 0) { %>
      <div class="row discount">
        <span>Discount (<%= order.coupon.code %>)</span>
        <span>-₹<%= order.coupon.discountAmount %></span>
      </div>
      <% } %>

      <div class="divider"></div>

      <div class="total">
        <span>Total</span>
        <span>₹<%= order.finalTotal %></span>
      </div>

      <% if(order.coupon && order.coupon.discountAmount > 0) { %>
        <p class="save-msg">
          You saved ₹<%= order.coupon.discountAmount %> 🎉
        </p>
      <% } %>

    </div>
  </div>

</div>
</body>
</html>