<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js" integrity="sha384-G/EV+4j2dNv+tEPo3++6LCgdCROaejBqfUeNjuKAiuXbjrxilcCdDz6ZAVfHWe1Y" crossorigin="anonymous"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/adminDashboard.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Variants - <%= product.productname %></title>
  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <style>
    /* ===== Page Layout ===== */

.variant-wrapper{
  padding:20px;
  max-width:1000px;
  margin:auto;
}

/* ===== Product Card ===== */

.product-info-card{
  display:flex;
  align-items:center;
  gap:20px;
  background:#fff;
  padding:15px;
  border-radius:10px;
  box-shadow:0 2px 8px rgba(0,0,0,0.08);
  margin-bottom:25px;
}

.product-thumb{
  width:90px;
  height:90px;
  object-fit:cover;
  border-radius:8px;
}

/* ===== Variant Form ===== */

.variant-form-card{
  background:#fff;
  padding:20px;
  border-radius:10px;
  box-shadow:0 2px 8px rgba(0,0,0,0.08);
  margin-bottom:30px;
}

.form-label{
  font-weight:600;
}

.form-control{
  border-radius:6px;
  border:1px solid #ccc;
  padding:8px;
  width:100%;
}

/* ===== Image Preview ===== */

#variantPreview{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
}

#variantPreview img{
  width:90px;
  height:90px;
  object-fit:cover;
  border-radius:8px;
  border:1px solid #ddd;
}

/* ===== Buttons ===== */

.btn{
  padding:8px 14px;
  border:none;
  border-radius:6px;
  cursor:pointer;
  font-size:14px;
}

.btn-primary{
  background:#2d7ef7;
  color:white;
}

.btn-primary:hover{
  background:#1c63d6;
}

.btn-secondary{
  background:#6c757d;
  color:white;
}

.btn-secondary:hover{
  background:#565e64;
}

.btn-edit{
  background:#ffc107;
  color:#000;
}

.btn-edit:hover{
  background:#e0a800;
}

/* ===== Variant Cards ===== */

.variants-list{
  display:flex;
  flex-direction:column;
  gap:15px;
}

.variant-card{
  display:flex;
  justify-content:space-between;
  align-items:center;
  background:#fff;
  padding:15px;
  border-radius:10px;
  box-shadow:0 2px 8px rgba(0,0,0,0.08);
}

.variant-images{
  display:flex;
  gap:6px;
}

.variant-images img{
  width:60px;
  height:60px;
  object-fit:cover;
  border-radius:6px;
  border:1px solid #ddd;
}

.variant-info p{
  margin:2px 0;
}

.variant-actions{
  display:flex;
  gap:10px;
}

/* ===== Titles ===== */

h3,h4{
  font-weight:600;
  margin-bottom:15px;
}

/* ===== Responsive ===== */

@media(max-width:768px){

  .variant-card{
    flex-direction:column;
    align-items:flex-start;
    gap:10px;
  }

  .product-info-card{
    flex-direction:column;
    align-items:flex-start;
  }

}
  </style>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
<body>
  <div class="dashboard-container">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <h2>Stravin Admin</h2>
      </div>
      <nav class="sidebar-menu">
        <ul>
          <li><a href="/admin/customers">Customers</a></li>
          <li><a href="/admin/products">Products</a></li>
          <li><a href="/admin/categories">Categories</a></li>
          <li><a href="/admin/logout" class="logout">Logout</a></li>
        </ul>
      </nav>
    </aside>

    <main class="main-content">
      <div class="variant-wrapper">

        <!-- Product Info -->
        <div class="product-info-card">
          <div class="product-info-left">
            <img src="<%= product.images[0] %>" class="product-thumb">
          </div>
          <div class="product-info-right">
            <h4><%= product.productname %></h4>
            <p>Category: <%= product.category?.name %></p>
            <p>Base Price: ₹<%= product.price %></p>
          </div>
        </div>

        <!-- Add / Update Variant Form -->
        <h4 class="mt-4" id="variantFormTitle">Add New Variant</h4>
        <div class="variant-form-card">
          <form id="variantForm" action="/admin/products/<%= product._id %>/variants/add" method="POST" enctype="multipart/form-data" novalidate>
            <input type="hidden" id="variantId" name="variantId">

            <div class="mb-3">
              <label class="form-label">Color</label>
              <input type="text" id="color" name="color" class="form-control">
            </div>

            <div class="mb-3">
              <label class="form-label">Additional Price</label>
              <input type="number" id="additionalPrice" name="additionalPrice" min="0" value="0" class="form-control">
            </div>

            <div class="mb-3">
              <label class="form-label">Stock Quantity</label>
              <input type="number" id="stockQuantity" name="stockQuantity" min="0" value="0" class="form-control">
            </div>

            <div class="mb-3">
              <label class="form-label">Variant Images</label>
              <input type="file" id="variantImages" name="images" multiple accept="image/*" class="form-control mt-2">
            </div>

            <div id="variantPreview" class="d-flex flex-wrap gap-2 mt-2"></div>

            <button type="submit" class="btn btn-primary" id="submitBtn">Add Variant</button>
            <button type="button" class="btn btn-secondary" onclick="resetVariantForm()">Cancel</button>
          </form>
        </div>

        <!-- Variant Listing -->
        <h3 class="mb-3">Existing Variants</h3>
        <div class="variants-list">
          <% if (variants && variants.length > 0) { %>
            <% variants.forEach(v => { %>
              <div class="variant-card">
                <div class="variant-images">
                  <% v.images.forEach(img => { %>
                    <img src="<%= img %>" alt="<%= v.color %>" style="width:60px;height:60px;object-fit:cover;margin-right:5px;">
                  <% }) %>
                </div>
                <div class="variant-info">
                  <p><strong>Color:</strong> <%= v.color %></p>
                  <p><strong>Additional Price:</strong> ₹<%= v.additionalPrice %></p>
                  <p><strong>Stock:</strong>
                    <% if(v.stockQuantity === 0){ %>
                      <span class="text-danger">Out Of Stock</span>
                    <% } else { %>
                      <%= v.stockQuantity %>
                    <% } %>
                  </p>
                </div>
                <div class="variant-actions">
                 
                  <button type="button" class="btn btn-edit" onclick="editVariant('<%= encodeURIComponent(JSON.stringify(v)) %>')">Edit</button>
                  <%if(v.isListedVariant){%>
                  <button  class="btn btn-secondary"
                  onclick="unlistVariant('<%= v._id %>')"> Unlist</button>
                 <% }else{%>
                  <button class="btn btn-success" onclick="restoreVariant('<%=v._id%>')">Resore</button>
                  <%}%>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <p>No variants added for this product.</p>
          <% } %>
        </div>

      </div>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>
    document.addEventListener("DOMContentLoaded", () => {

      const variantForm = document.getElementById("variantForm");
      const imageInput = document.getElementById("variantImages");
      const preview = document.getElementById("variantPreview");
      let allFiles = [];

      /* ===== IMAGE PREVIEW & REMOVE ===== */
      imageInput?.addEventListener("change", (e) => {
        const files = Array.from(e.target.files);
        allFiles = [...allFiles, ...files];
        if (allFiles.length > 4) {
          Swal.fire("Image Limit", "Maximum 4 images allowed", "warning");
          allFiles = allFiles.slice(0, 4);
        }
        renderPreview();
      });

      function renderPreview() {
        preview.innerHTML = "";
        allFiles.forEach((file, index) => {
          if (!file.type.startsWith("image/")) return;
          const reader = new FileReader();
          reader.onload = (e) => {
            const wrapper = document.createElement("div");
            wrapper.style.position = "relative";
            const img = document.createElement("img");
            img.src = e.target.result;
            img.style.cssText = "width:90px;height:90px;object-fit:cover;border-radius:8px;border:1px solid #ccc;";
            const removeBtn = document.createElement("span");
            removeBtn.innerHTML = "✖";
            removeBtn.style.cssText = "position:absolute;top:2px;right:4px;color:red;font-weight:bold;cursor:pointer;";
            removeBtn.onclick = () => { allFiles.splice(index, 1); updateInputFiles(); renderPreview(); };
            wrapper.appendChild(img);
            wrapper.appendChild(removeBtn);
            preview.appendChild(wrapper);
          };
          reader.readAsDataURL(file);
        });
        updateInputFiles();
      }

      function updateInputFiles() {
        const dataTransfer = new DataTransfer();
        allFiles.forEach(f => dataTransfer.items.add(f));
        imageInput.files = dataTransfer.files;
      }

      /* ===== FORM SUBMIT ===== */
      variantForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const color = variantForm.color.value.trim();
        const additionalPrice = Number(variantForm.additionalPrice.value);
        const stockQuantity = Number(variantForm.stockQuantity.value);
        const variantId = document.getElementById("variantId").value;

        if (!color) return Swal.fire("Validation Error","Color is required","warning");
        if (isNaN(additionalPrice) || additionalPrice < 0) return Swal.fire("Validation Error","Enter valid additional price","warning");
        if (isNaN(stockQuantity) || stockQuantity < 0) return Swal.fire("Validation Error","Enter valid stock quantity","warning");
        if (!variantId && allFiles.length === 0) return Swal.fire("Validation Error","Upload at least one image","warning");

        const formData = new FormData(variantForm);

        try {
        
          const method = variantId ? "PUT" : "POST";

const res = await fetch(variantForm.action, {
  method: method,
  body: formData,
  credentials: "include"
});

          const data = await res.json();

          if (data.success) {
            Swal.fire("Success", data.message, "success").then(() => location.reload());
          } else {
            Swal.fire("Error", data.message, "error");
          }

        } catch (err) {
          console.error(err);
          Swal.fire("Error","Server error","error");
        }
      });

      /* ===== EDIT VARIANT ===== */
      window.editVariant = function(variant) {
        variant = JSON.parse(decodeURIComponent(variant));
        document.getElementById("variantId").value = variant._id;
        document.getElementById("color").value = variant.color;
        document.getElementById("additionalPrice").value = variant.additionalPrice;
        document.getElementById("stockQuantity").value = variant.stockQuantity;

        variantForm.action = `/admin/variants/update/${variant._id}`;
        preview.innerHTML = "";
        allFiles = [];

        if (variant.images) {
          variant.images.forEach(img => {
            const image = document.createElement("img");
            image.src = img;
            image.style.cssText = "width:90px;height:90px;object-fit:cover;margin-right:5px;";
            preview.appendChild(image);
          });
        }

        document.getElementById("submitBtn").innerText = "Update Variant";
        window.scrollTo({top:0, behavior:"smooth"});
      };

      /* ===== RESET FORM ===== */
      window.resetVariantForm = function() {
        variantForm.reset();
        document.getElementById("variantId").value = "";
        variantForm.action = "/admin/products/<%= product._id %>/variants/add";
        document.getElementById("submitBtn").innerText = "Add Variant";
        preview.innerHTML = "";
        allFiles = [];
      };

    });
async function unlistVariant(variantId){
const result = await Swal.fire({
    title:"Are you sure?",
    text:"This variant will be Unlisted!",
    icon:"warning",
    showCancelButton:true,
    confirmButtonText:"Yes, Unlist it!"
  });

  if(!result.isConfirmed) return;

  try{

    const res = await fetch(`/admin/variants/${variantId}/unlist`,{
      method:"PATCH"
    });

    const data = await res.json();

    if(data.success){
      Swal.fire("Success",data.message,"success")
      .then(()=>location.reload());
    }else{
      Swal.fire("Error",data.message,"error");
    }

  }catch(err){
    Swal.fire("Error","Server error","error");
  }

}


async function restoreVariant(variantId){

  try{

    const res = await fetch(`/admin/variants/${variantId}/restore`,{
      method:"PATCH"
    });

    const data = await res.json();

    if(data.success){
      Swal.fire("Success","Variant Restored!","success")
      .then(()=>location.reload());
    }else{
      Swal.fire("Error",data.message,"error");
    }

  }catch(err){
    Swal.fire("Error","Server error","error");
  }

}
  </script>
</body>
</html>
</body>
</html>