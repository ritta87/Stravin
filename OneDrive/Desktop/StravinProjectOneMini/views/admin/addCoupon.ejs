<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Coupon</title>
  
  <link rel="stylesheet" href="/css/adminDashboard.css">
<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js" integrity="sha384-G/EV+4j2dNv+tEPo3++6LCgdCROaejBqfUeNjuKAiuXbjrxilcCdDz6ZAVfHWe1Y" crossorigin="anonymous"></script>
<link  href="https://cdn.jsdelivr.net/npm/cropperjs@1.5.13/dist/cropper.min.css" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/cropperjs@1.5.13/dist/cropper.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <style>
    /* ===== FORM CONTAINER ===== */
.form-container {
  max-width: 600px;
  margin: 40px auto;
  padding: 25px 30px;
  background: #ffffff;
  border-radius: 12px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.08);
  font-family: 'Segoe UI', sans-serif;
}

/* ===== TITLE ===== */
.form-title {
  text-align: center;
  margin-bottom: 20px;
  font-size: 22px;
  font-weight: 600;
  color: #333;
}

/* ===== FORM GROUP ===== */
.form-group {
  margin-bottom: 18px;
}

.form-group label {
  display: block;
  font-weight: 500;
  margin-bottom: 6px;
  color: #444;
}

/* ===== INPUT FIELDS ===== */
.form-group input,
.form-group select {
  width: 100%;
  padding: 10px 12px;
  border-radius: 8px;
  border: 1px solid #ccc;
  font-size: 14px;
  transition: 0.3s;
}

.form-group input:focus,
.form-group select:focus {
  border-color: #4CAF50;
  outline: none;
  box-shadow: 0 0 5px rgba(76, 175, 80, 0.2);
}

/* ===== ERROR TEXT ===== */
.error {
  color: #e74c3c;
  font-size: 13px;
  margin-top: 4px;
  display: block;
}

/* ===== ERROR INPUT BORDER ===== */
.input-error {
  border-color: #e74c3c !important;
  background-color: #fff5f5;
}

/* ===== BUTTON ===== */
.btn-submit {
  width: 100%;
  padding: 12px;
  border: none;
  background: linear-gradient(135deg, #4CAF50, #2ecc71);
  color: #fff;
  font-size: 15px;
  font-weight: 600;
  border-radius: 8px;
  cursor: pointer;
  transition: 0.3s;
}

/* Hover */
.btn-submit:hover {
  background: linear-gradient(135deg, #43a047, #27ae60);
  transform: translateY(-1px);
}

/* Active click */
.btn-submit:active {
  transform: scale(0.98);
}

/* ===== SMALL SECONDARY BUTTON ===== */
.btn-secondary {
  margin-top: 10px;
  padding: 10px;
  width: 100%;
  border: none;
  background: #ddd;
  color: #333;
  border-radius: 8px;
  cursor: pointer;
}

.btn-secondary:hover {
  background: #ccc;
}
  </style>
</head>
<body>
  <div class="dashboard-container">
    <aside class="sidebar">
      <div class="sidebar-header">
        <h2>Stravin Admin</h2>
      </div>
      <nav class="sidebar-menu">
        <ul>
          <li><a href="/admin/customers">Customers</a></li>
          <li><a href="/admin/products">Products</a></li>
          <li><a href="/admin/categories">Categories</a></li>
          <li><a href="/admin/coupons">Coupons</a></li>
          <li><a href="/admin/banners">Banners</a></li>
          <li><a href="/admin/orders">Orders</a></li>
          <li><a href="#" id="logoutbtn" class="btn btn-danger">
            <i class="fas fa-sign-out-alt"></i> Logout</a></li>
        </ul>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
<div class="form-title">Create Coupon</div>

<div class="form-container">
 <form id="couponForm">
    <div class="form-group">
  <input type="text" name="code" id="code" placeholder="Coupon Code" >
    <span class="error" id="codeError"></span></div>

<div class="form-group">
  <select name="discountType" id="discountType">
    <option value="percentage">Percentage</option>
    <option value="fixed">Fixed</option>
      <span class="error" id="typeError"></span>

  </select></div>
<div class="form-group">
  <input type="number" name="discountValue" id="discountValue"
   min="1"  max="90" id="discountValue" placeholder="Discount Value" >
    <span class="error" id="valueError"></span></div>
<div class="form-group">
  <input type="number" name="minPurchase" id="minPurchase" min="0" placeholder="Min Purchase">
    <span class="error" id="minError"></span></div>

<div class="form-group">
      <input type="number" name="maxDiscount" id="maxDiscount" min="0" placeholder="Max Discount">
    <span class="error" id="maxError"></span></div>

<div class="form-group">
      <input type="date" id="expiryDate" name="expiryDate" >
    <span class="error" id="dateError"></span></div>


  <button type="submit" class="btn-submit">Create Coupon</button>
</form>   
</div>
</main>
  </div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    document.getElementById('logoutbtn').addEventListener('click',async(e)=>{
    e.preventDefault();
     Swal.fire({
      title: "Are you sure?",
      text: "You will be logged out of the admin panel",
      icon: "warning",
      showCancelButton: true,
      
      confirmButtonText: "Yes, logout",
      cancelButtonText: "Cancel"
     }).then((result) => {
      if(result.isConfirmed) {
        window.location.href = "/admin/logout"
      }
    })
  })
  


const form = document.getElementById("couponForm");

form.addEventListener("submit", async (e) => {
  e.preventDefault();

  //reset error
  document.querySelectorAll(".error").forEach(el => el.innerText = "");

  let isValid = true;

  const code = document.getElementById("code").value.trim();
  const discountType = document.getElementById("discountType").value;
  const discountValue = Number(document.getElementById("discountValue").value);
  const minPurchase = Number(document.getElementById("minPurchase").value || 0);
  const maxDiscount = Number(document.getElementById("maxDiscount").value || 0);
  const expiryDate = document.getElementById("expiryDate").value;



  if (!code) {
    document.getElementById("codeError").innerText = "Coupon code required";
    isValid = false;
  }

  if (discountValue <= 0) {
    document.getElementById("discountError").innerText = "Enter valid discount";
    isValid = false;
  }

  if (discountType === "percentage" && discountValue > 90) {
    document.getElementById("discountError").innerText = "Max 90% allowed";
    isValid = false;
  }

  if (minPurchase < 0) {
    document.getElementById("minError").innerText = "Cannot be negative";
    isValid = false;
  }

  if (maxDiscount < 0) {
    document.getElementById("maxError").innerText = "Cannot be negative";
    isValid = false;
  }

  if (!expiryDate) {
    document.getElementById("dateError").innerText = "Select expiry date";
    isValid = false;
  } else if (new Date(expiryDate) < new Date()) {
    document.getElementById("dateError").innerText = "Must be future date";
    isValid = false;
  }

  if (!isValid) return;
  try {
    const res = await fetch("/admin/addCoupon", {
    method: "POST",
      headers: {
    "Content-Type": "application/json"
  },
    body:JSON.stringify({
    code,
    discountType,
    discountValue,
    minPurchase,
    maxDiscount,
    expiryDate
  })
    })

    const data = await res.json();

    if (data.success) {
      Swal.fire("Success", "Coupon created successfully", "success")
        .then(() => location.reload());
    } else {
      Swal.fire("Error", data.message, "error");
    }

  } catch (error) {
    Swal.fire("Error", "Something went wrong", "error");
  }
})
</script>
</body>
</html>