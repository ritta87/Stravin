<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Product | Stravin Admin</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/adminDashboard.css">
  <link  href="https://cdn.jsdelivr.net/npm/cropperjs@1.5.13/dist/cropper.min.css" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/cropperjs@1.5.13/dist/cropper.min.js"></script>

  
<style>
/* ===== GLOBAL ===== */
body {
  margin: 0;
  font-family: system-ui, -apple-system, sans-serif;
  background: #f1f5f9;
}

/* ===== LAYOUT ===== */
.dashboard-container {
  display: flex;
  min-height: 100vh;
}
.product-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15px;
}

.add-product-btn {
  background: #2563eb;
  color: #fff;
  padding: 8px 16px;
  border-radius: 50px;
  text-decoration: none;
  font-weight: 500;
}

.add-product-btn:hover {
  background: #1d4ed8;
}
/* ===== SIDEBAR ===== */
.sidebar {
  width: 240px;
  background: #1e293b;
  color: #fff;
  padding: 20px;
  flex-shrink: 0;
  flex-shrink: 0; 

}

.sidebar h2 {
  font-size: 18px;
  margin-bottom: 20px;
}

.sidebar-menu ul {
  list-style: none;
  padding: 0;
}

.sidebar-menu ul li {
  margin: 12px 0;
}

.sidebar-menu ul li a {
  color: #cbd5e1;
  text-decoration: none;
  padding: 8px 10px;
  display: block;
  border-radius: 6px;
}

.sidebar-menu ul li a:hover {
  background: #334155;
  color: #fff;
}

/* ===== MAIN CONTENT ===== */
.main-content {
  flex: 1;
  padding: 25px;
  margin-left: 0; 
  width: calc(100% - 240px);
}
/* ===== SEARCH CARD ===== */
.card {
  background: #fff;
  border-radius: 12px;
  padding: 18px;
  margin-bottom: 20px;
  box-shadow: 0 4px 15px rgba(0,0,0,0.05);
}

/* Fix search layout */
#searchForm .row {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  align-items: center;
}

/* Inputs */
.form-control,
.form-select {
  padding: 8px 10px;
  border-radius: 8px;
  border: 1px solid #cbd5e1;
  width: 100%;
}

/* ===== BUTTONS ===== */
.search-buttons {
  display: flex;
  gap: 8px;
}

.search-buttons .btn {
  padding: 8px 14px;
  border-radius: 50px;
  border: none;
  color: #fff;
  cursor: pointer;
}

.btn-search { background: #2563eb; }
.btn-search:hover { background: #1d4ed8; }

.btn-clear { background: #64748b; }
.btn-clear:hover { background: #475569; }

.btn-cancel { background: #dc2626; }
.btn-cancel:hover { background: #b91c1c; }

/* ===== TABLE CONTAINER ===== */
.product-container {
  background: #fff;
  border-radius: 12px;
  padding: 15px;
  box-shadow: 0 4px 18px rgba(0,0,0,0.05);
  overflow-x: auto;
}

/* ===== TABLE ===== */
.product-table {
  width: 100%;
  min-width: 1100px;
  border-collapse: collapse;
}

/* Header */
.product-table thead {
  background: #1e293b;
  color: #fff;
}

.product-table th {
  padding: 14px;
  font-size: 13px;
  text-align: center;
}

/* Rows */
.product-table td {
  padding: 12px;
  font-size: 13px;
  text-align: center;
  vertical-align: middle;
  white-space: nowrap;
}

/* Hover */
.product-table tbody tr:hover {
  background: #f8fafc;
}

/* ===== IMAGE ===== */
.product-table img {
  width: 55px;
  height: 55px;
  object-fit: cover;
  border-radius: 8px;
  border: 1px solid #e2e8f0;
}

/* ===== STATUS BADGES ===== */
.badge {
  padding: 4px 10px;
  border-radius: 20px;
  font-size: 12px;
}

.bg-success {
  background: #dcfce7 !important;
  color: #166534 !important;
}

.bg-danger {
  background: #fee2e2 !important;
  color: #991b1b !important;
}

/* ===== ACTION BUTTONS ===== */
.product-table .btn {
  font-size: 12px;
  padding: 5px 8px;
  border-radius: 20px;
}

/* Stack nicely */
.product-table td div {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

/* ===== PAGINATION ===== */
.pagination {
  margin-top: 20px;
  display: flex;
  justify-content: center;
  gap: 6px;
}

.pagination .page-link {
  padding: 6px 12px;
  border-radius: 6px;
  background: #e2e8f0;
  text-decoration: none;
  color: #334155;
}

.pagination .active .page-link {
  background: #2563eb;
  color: #fff;
}

</style>
</head>

<body>
  <div class="dashboard-container">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <h2>Stravin Admin</h2>
      </div>
      <nav class="sidebar-menu">
        <ul>
          <li><a href="/admin/customers">Customers</a></li>
          <li><a href="/admin/products">Products</a></li>
          <li><a href="/admin/categories">Categories</a></li>
          <li><a href="/admin/coupons">Coupons</a></li>
          <li><a href="/admin/banners">Banners</a></li>
          <li><a href="/admin/orders">Orders</a></li>
          <li><a href="/admin/logout" class="logout">Logout</a></li>
        </ul>
      </nav>
    </aside>


<!-- Main Content -->
    <main class="main-content py-4">
      <div class="container mt-4">
<!--search area-->
<div class="product-header">
  <h2>Products</h2>
  <a href="/admin/GetAddProduct" class="add-product-btn">+ Add Product</a>
</div>
<div class="card p-3 mb-4 shadow-sm row gap-2">
<form id="searchForm" method="GET" action="/admin/products">

  <div class="row">
    <div class="col-md-4 col-sm-6 mb-2">
  <input type="text"  name="search"  placeholder="Search by product name" class="form-control"
    value="<%= search || '' %>"
    />
</div>
   <div class="col-md-3 col-sm-6">
    <select name="category" class="form-select">
     <option value="">All Categories</option>
     <% category.forEach(cat => { %>
   <option
    value="<%= cat._id %>"
   <%= selectedCategory && selectedCategory.toString() === cat._id.toString() ? 'selected' : '' %>
    >
   <%= cat.name %>
  </option>
    <% }) %>
  </select>
  </div>

<!--search/cancel/clear buttons...-->
<div class="col-md-5 col-sm-12 search-buttons">
  <button type="submit" class="btn btn-search">Search</button>
  <a href="/admin/products" class="btn btn-clear">Clear</a>
  <a href="/admin/products" class="btn btn-cancel">Cancel</a>
</div>

</form>

</div>
</div>

<div class="product-container">
  <div style="overflow-x:auto;">
    <table class="product-table">

      <thead class="table-dark text-center">
        <tr>
          <th>Image</th>
          <th>Name</th>
          <th>Category</th>
          <th>Category Offer</th>
          <th>Price</th>
          <th>Product Offer</th>
          <th>Stock</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>

      <tbody>
        <% product.forEach(p => { %>
          <tr>

            <!-- IMAGE -->
            <td class="text-center">
              <img 
                id="mainImage-<%= p._id %>"
                src="<%= p.images?.length ? p.images[0] : '/images/no-image.png' %>"
                style="width:60px;height:60px;object-fit:cover;border-radius:6px;"
              >
            </td>

            <!-- NAME -->
            <td><%= p.productname %></td>

            <!-- CATEGORY -->
            <td><%= p.category?.name || "N/A" %></td>

            <!-- CATEGORY OFFER -->
            <td>
              <%= p.category?.catOfferPercentage > 0 
                ? p.category.catOfferPercentage + "%" 
                : "No Offer" %>
            </td>

            <!-- PRICE -->
            <td>₹<%= p.price %></td>

            <!-- PRODUCT OFFER -->
            <td>
              <% if(p.offerPercentage > 0) { %>
                <span class="text-danger"><%= p.offerPercentage %>%</span>
              <% } else { %>
                -
              <% } %>
            </td>

  

            <!-- STOCK -->
            <td>
              <% if(p.variantCount === 0){ %>
                <span class="text-warning">No Variants</span>
              <% } else if(p.totalStock > 0){ %>
                <span class="text-success">Available</span>
              <% } else { %>
                <span class="text-danger">Out</span>
              <% } %>
            </td>

            <!-- STATUS -->
            <td class="text-center">
              <% if(p.isDeleted){ %>
                <span class="badge bg-danger">Unlisted</span>
              <% } else { %>
                <span class="badge bg-success">Listed</span>
              <% } %>
            </td>

            <!-- ACTIONS -->
            <td>
              <div class="d-flex flex-column gap-1">

                <a href="/admin/products/edit/<%= p._id %>" 
                   class="btn btn-sm btn-warning">
                  Edit
                </a>

                <% if(p.isDeleted){ %>
                  <button class="btn btn-sm btn-success"
                    onclick="restoreProduct('<%=p._id%>')">
                    Restore
                  </button>
                <% } else { %>
                  <button class="btn btn-sm btn-danger"
                    onclick="deleteProduct('<%= p._id %>')">
                    Unlist
                  </button>
                <% } %>

                <a href="/admin/products/<%= p._id %>/variants" 
                   class="btn btn-sm btn-secondary">
                  Variants
                </a>

              </div>
            </td>

          </tr>
        <% }) %>
      </tbody>

    </table>
  </div>
  <nav aria-label="Page navigation">
  <ul class="pagination justify-content-center mt-4">
    <% for(let i = 1; i <= totalPages; i++) { %>
    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
    <a class="page-link" href="?page=<%= i %><% if(search) { %>&search=<%=search%><% } %><% if(selectedCategory) { %>&category=<%=selectedCategory%><% } %>"><%= i %></a>
    </li>
    <% } %>
  </ul>
</nav>
</div>
  </main>


<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>



<script>
document.addEventListener("DOMContentLoaded", () => {
  document.querySelectorAll(".thumbnail-container img").forEach(thumbnail => {
    thumbnail.addEventListener("click", () => {
      const productId = thumbnail.dataset.productId;
      const mainImage = document.getElementById(`mainImage-${productId}`);
      if (mainImage) {
        mainImage.src = thumbnail.src;
      }
    });
  });
})


async function deleteProduct(productId){
  try{

    const result = await Swal.fire({
      title: "Are you sure?",
      text: "This will unlist the product!",
      icon: "warning",
      showCancelButton: true,
      confirmButtonText: "Yes, unlist it!"
    });

    if(!result.isConfirmed) return;

    const res = await fetch(`/admin/products/${productId}`,{
      method:"DELETE",
      headers:{'Content-Type':'application/json'}
    });

    const data = await res.json();

    if(res.ok){
      Swal.fire("Success","Product Unlisted Successfully!","success")
      .then(()=>window.location.href="/admin/products");
    } else {
      Swal.fire("Error", data.message || "Something went wrong","error");
    }

  }catch(error){
    console.error(error);
    Swal.fire("Error","Server error","error");
  }
}

async function restoreProduct(productId){
const res = await fetch(`/admin/products/restoreProduct/${productId}`,{
  method:"PUT"
})
const data=await res.json()
if(res.ok){
  Swal.fire("Success","Product Restored!","success").then(()=>window.location.reload())
}else{
  Swal.fire("Error",data.message||"Failed!","error")
}
}
</script>



</body></html>