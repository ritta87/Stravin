<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/css/adminDashboard.css">
   <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
   <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <style>
body {
    background: #f5f7fa;
    font-family: "Poppins", sans-serif;
}

/* TITLES */
.page-title {
    font-weight: 600;
    color: #333;
}

/* CARD WRAPPER */
.admin-card {
    background: #fff;
    border-radius: 10px;
    padding: 20px;
}

/* TABLE */
table {
    border-radius: 10px;
    overflow: hidden;
}

.table thead th {
    background-color: #343a40 !important;
    color: white !important;
}

.table-hover tbody tr:hover {
    background-color: #f0f0f0;
}

/* BUTTONS */
.btn-sm {
    padding: 4px 10px;
    font-size: 13px;
}

.btn-info {
    background-color: #0dcaf0;
    border: none;
}

.btn-warning {
    background-color: #f0ad4e;
    border: none;
}

.btn-success {
    background-color: #28a745;
    border: none;
}

.btn-danger {
    background-color: #dc3545;
    border: none;
}
</style>
</head>
<body>
  <div class="dashboard-container">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <h2>Stravin Admin</h2>
      </div>
      <nav class="sidebar-menu">
        <ul>
          <li><a href="/admin/customers">Customers</a></li>
          <li><a href="/admin/products">Products</a></li>
          <li><a href="/admin/categories">Categories</a></li>
          <li><a href="/admin/coupons">Coupons</a></li>
          <li><a href="/admin/salesReport">sales Report</a></li>
          <li><a href="/admin/orders">Orders</a></li>
          <li><a href="/admin/logout" class="logout">Logout</a></li>
        </ul>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      <header>
        <h1>Welcome, Admin</h1>
      </header>
      <section class="content">
       
      </section>
        <div class="container mt-4">

            <h3 class="mb-4">Customer Management</h3>

            <!-- Search form -->
          <form method="GET" action="/admin/customers" class="d-flex mb-3">
            <input type="text" name="search" class="form-control me-2" placeholder="Search by name or email" value="<%=search||''%>"/>
                 
          
           <div class="col-md-3">
             <select name="status" class="form-select">
                        <option value="all">All Users</option>
                        <option value="active" <%= status==='active' ? 'selected':'' %>>Active Users</option>
                        <option value="blocked" <%= status==='blocked' ? 'selected' :'' %>>Blocked Users</option>
                </select>
                </div>
                <button type="submit" class="btn btn-outline-secondary">Search</button>
         
        <a href="/admin/customers"class="btn btn-outline-secondary">Clear</a>
            </div>
         </form>
            <!-- customer info below -->
<div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Customer Management</h3>
   
  </div>

  <% if (customers.length === 0) { %>
    <div class="alert alert-warning">
      No customers found.
    </div>
  <% } else { %>

  <div class="table-responsive">
    <table class="table table-bordered table-hover align-middle">
      <thead class="table-dark text-center">
        <tr>
          <th></th>
          <th>Name</th>
          <th>Email</th>
          <th>Mobile</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>

      <tbody>
        <% customers.forEach((user, index) => { %>
          <tr class="text-center">
            <td><%= index + 1 %></td>

            <td class="text-start">
              <%= user.name || 'N/A' %>
            </td>

            <td class="text-start">
              <%= user.email %>
            </td>
            <td class="text-start"><%=user.mobile%></td>
            <td>
              <% if (user.isBlocked) { %>
                <span class="badge bg-danger">Blocked</span>
              <% } else { %>
                <span class="badge bg-success">Active</span>
              <% } %>
            </td>

            <td>
              <% if (user.isBlocked) { %>
            <button type="submit"class="btn btn-success btn-sm"
             onclick="changeUserStatus('<%=user._id%>','unblock')" >Unblock</button>
                
                
              <% } else { %>
                <button type="submit" class="btn btn-danger btn-sm"
                onclick="changeUserStatus('<%=user._id%>','block')">Block</button>
                 <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% } %>
</div>



    </main>


  </div>
  <nav>
  <ul class="pagination justify-content-center">

    <% if (currentPage > 1) { %>
      <li class="page-item">
        <a
          class="page-link"
          href="/admin/customers?page=<%= currentPage - 1 %>&search=<%= search || '' %>&status=<%= status || '' %>"
        >
          Prev
        </a>
      </li>
    <% } %>

    <% for (let i = 1; i <= totalPages; i++) { %>
      <li class="page-item <%= currentPage === i ? 'active' : '' %>">
        <a
          class="page-link"
          href="/admin/customers?page=<%= i %>&search=<%= search || '' %>&status=<%= status || '' %>"
        >
          <%= i %>
        </a>
      </li>
    <% } %>

    <% if (currentPage < totalPages) { %>
      <li class="page-item">
        <a
          class="page-link"
          href="/admin/customers?page=<%= currentPage + 1 %>&search=<%= search || '' %>&status=<%= status || '' %>"
        >
          Next
        </a>
      </li>
    <% } %>

  </ul>
</nav>
<script>
     function changeUserStatus(userId,action){
        const actionText = action === 'block' ?'Block':'Unblock'
        swal.fire({
            title:"Are you sure?",
            text:`Do you want to  ${actionText} this customer?`,
            icon:"warning",
            showCancelButton:true,
            confirmButtonText:`Yes,${actionText}!!`
        }).then(async(result)=>{
            if(!result.isConfirmed)return
        try{
            const res = await fetch(`/admin/customers/${action}/${userId}`,{
            method:"POST",
            })
         const data=await res.json() 
         if(data.success) {
            Swal.fire({
                icon:"success",
                title:"Done",
                text:data.message,
                timer:1000,
                showConfirmButton:false
            }).then(()=>location.reload())
         }else{
            Swal.fire('Error',"Action failed!",'error')
         }
        }catch(error){
            Swal.fire("Error","Server failed!","error")
        }
        })
    }
</script>
</body>
</html>
