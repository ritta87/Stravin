<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js" integrity="sha384-G/EV+4j2dNv+tEPo3++6LCgdCROaejBqfUeNjuKAiuXbjrxilcCdDz6ZAVfHWe1Y" crossorigin="anonymous"></script>
  <title>Admin Dashboard - Edit Category</title>
  <link rel="stylesheet" href="/css/adminDashboard.css">
</head>
<style>
 /* ===== FORM GROUP ===== */
.form-group {
  display: flex;
  flex-direction: column;
  margin-bottom: 25px;
}

.form-group label {
  font-weight: 500;
  margin-bottom: 8px;
  font-size: 14px;
  color: #333;
}

.form-group input,
.form-group textarea {
  width: 100%;
  padding: 14px;
  border-radius: 10px;
  border: 1px solid #ddd;
  font-size: 15px;
  transition: all 0.3s ease;
}

.form-group input:focus,
.form-group textarea:focus {
  outline: none;
  border-color: #ff4d4d;
  box-shadow: 0 0 0 3px rgba(255,77,77,0.15);
}

/* Checkbox */
.form-check {
  margin-bottom: 30px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.form-check input {
  width: 18px;
  height: 18px;
}

/* ===== BUTTON GROUP ===== */
.button-group {
  display: flex;
  gap: 15px;
}

/* Save Button */
.btn-save {
  background: linear-gradient(135deg, #111, #333);
  color: #fff;
  padding: 12px 30px;
  border: none;
  border-radius: 10px;
  font-weight: 500;
  cursor: pointer;
  transition: 0.3s ease;
}

.btn-save:hover {
  background: linear-gradient(135deg, #ff4d4d, #ff0000);
  transform: translateY(-2px);
}

/* Cancel Button */
.btn-cancel {
  background: #f1f1f1;
  color: #333;
  padding: 12px 30px;
  border-radius: 10px;
  text-decoration: none;
  font-weight: 500;
  transition: 0.3s ease;
}

.btn-cancel:hover {
  background: #ddd;
}
/* ===== EDIT CARD ENHANCEMENT ===== */
.card {
  border: none;
  border-radius: 18px;
  padding: 50px;
  background: #ffffff;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
  max-width: 850px;
  margin: auto;
  transition: 0.3s ease;
}

.card:hover {
  transform: translateY(-4px);
}

/* Title */
.card-title {
  font-size: 24px;
  font-weight: 600;
  margin-bottom: 35px;
  color: #111;
  position: relative;
}

.card-title::after {
  content: "";
  width: 60px;
  height: 4px;
  background: #ff4d4d;
  display: block;
  margin-top: 10px;
  border-radius: 5px;
}

/* ===== FORM FIELDS ===== */
#editCategoryForm div {
  margin-bottom: 28px;
}

#editCategoryForm label {
  display: block;
  font-size: 14px;
  font-weight: 500;
  margin-bottom: 8px;
  color: #444;
}

#editCategoryForm input,
#editCategoryForm textarea {
  width: 100%;
  padding: 15px;
  border-radius: 12px;
  border: 1px solid #ddd;
  font-size: 15px;
  transition: all 0.3s ease;
  background: #fafafa;
}

#editCategoryForm input:focus,
#editCategoryForm textarea:focus {
  outline: none;
  border-color: #ff4d4d;
  background: #fff;
  box-shadow: 0 0 0 4px rgba(255, 77, 77, 0.15);
}

/* ===== CHECKBOX ===== */
#editCategoryForm input[type="checkbox"] {
  width: 18px;
  height: 18px;
  accent-color: #ff4d4d;
  cursor: pointer;
}

/* ===== BUTTONS ===== */

/* ===== BUTTON GROUP ALIGNMENT ===== */
.button-group {
  display: flex;
  justify-content: flex-end;  /* align to right */
  gap: 15px;
  margin-top: 35px;
}

/* ===== SAVE BUTTON (Primary Action) ===== */
.btn-save {
  padding: 13px 35px;
  border-radius: 30px;
  border: none;
  font-weight: 600;
  font-size: 14px;
  letter-spacing: 0.5px;
  cursor: pointer;
  color: #fff;
  background: linear-gradient(135deg, #ff4d4d, #ff0000);
  box-shadow: 0 8px 20px rgba(255, 77, 77, 0.35);
  transition: all 0.3s ease;
}

.btn-save:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 25px rgba(255, 0, 0, 0.4);
}

/* ===== CANCEL BUTTON (Secondary Action) ===== */
.btn-cancel {
  padding: 13px 30px;
  border-radius: 30px;
  text-decoration: none;
  font-weight: 500;
  font-size: 14px;
  background: transparent;
  border: 2px solid #ddd;
  color: #555;
  transition: all 0.3s ease;
}

.btn-cancel:hover {
  border-color: #111;
  color: #111;
}

</style>
<body>
  <div class="dashboard-container">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <h2>Stravin Admin</h2>
      </div>
      <nav class="sidebar-menu">
        <ul>
          <li><a href="/admin/customers">Customers</a></li>
          <li><a href="/admin/products">Products</a></li>
          <li><a href="/admin/categories">Categories</a></li>
          <li><a href="/admin/coupons">Coupons</a></li>
          <li><a href="/admin/banners">Banners</a></li>
          <li><a href="/admin/orders">Orders</a></li>
          <li><a href="/admin/logout" class="logout">Logout</a></li>
        </ul>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
       <!-- edit category form-->
      <div class="card shadow p-3 mb-4">
        <h5 class="card-title">Edit Category</h5>
<form id="editCategoryForm" data-id="<%= category._id %>">

  <div class="mb-3">
    <label class="form-label">Category Name</label>
    <input type="text" name="name" value="<%= category.name %>"
    >
  </div>

  <div class="mb-3">
    <label class="form-label">Description</label>
    <textarea name="description"  rows="4">
      <%= category.description %></textarea>
  </div>

  <div class="mb-3">
    <label class="form-label">Category Offer %</label>
    <input type="number" name="catOfferPercentage" value="<%= category.catOfferPercentage %>"
    >
  </div>

<div class="button-group">
  <button type="submit" class="btn-save"> Save Changes
  </button>

  <a href="/admin/categories" class="btn-cancel">
    Cancel
  </a>
</div>


</form>
 </div>
    </main>
  </div>


  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  const form = document.getElementById("editCategoryForm");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const categoryId = form.dataset.id;
    const formData = new FormData(form);

    const data = {
      name: formData.get("name"),
      description: formData.get("description"),
      catOfferPercentage : formData.get("catOfferPercentage"),
      isListed: formData.get("isListed") === "true"
    }

    try {
      const res = await fetch(`/admin/categories/${categoryId}/edit`, {
        method: "PUT",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify(data)
      });

      const result = await res.json();

      if (!res.ok) {
        Swal.fire({
          icon: "error",
          title: "Update failed",
          text: result.message || "Something went wrong"
        });
        return;
      }
      Swal.fire({
        icon: "success",
        title: "Category Updated",
        text: "Changes saved successfully",
        timer: 1500,
        showConfirmButton: false
      }).then(() => {
        window.location.href = "/admin/categories"
      })

    } catch (error) {
      Swal.fire({
        icon: "error",
        title: "Server Error",
        text: "Please try again later"
      })
    }
  })
</script>
  

</body>
</html>
