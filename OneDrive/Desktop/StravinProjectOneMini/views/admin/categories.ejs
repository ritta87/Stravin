<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js" integrity="sha384-G/EV+4j2dNv+tEPo3++6LCgdCROaejBqfUeNjuKAiuXbjrxilcCdDz6ZAVfHWe1Y" crossorigin="anonymous"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
 
<title>Admin Dashboard - Categories</title>
  <link rel="stylesheet" href="/css/adminDashboard.css">
</head>

<style>
  
.dashboard-container {
  display: flex;
  min-height: 100vh;
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  background-color: #f8f9fa;
}


.sidebar {
  width: 220px;
  background-color: #343a40;
  color: #fff;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
}

.sidebar-header {
  padding: 1.5rem;
  text-align: center;
  background-color: #23272b;
  font-size: 1.25rem;
  font-weight: bold;
}

.sidebar-menu ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.sidebar-menu li {
  border-bottom: 1px solid #495057;
}

.sidebar-menu li a {
  display: block;
  padding: 12px 20px;
  color: #adb5bd;
  text-decoration: none;
  transition: 0.3s;
}

.sidebar-menu li a:hover,
.sidebar-menu li a.active {
  background-color: #495057;
  color: #fff;
}

.sidebar-menu li a.logout {
  color: #e74c3c;
  margin-top: auto;
}


.main-content {
  flex-grow: 1;
  padding: 2rem;
  background-color: #f8f9fa;
}


.card {
  background-color: #fff;
  border-radius: 8px;
  padding: 1.5rem;
  margin-bottom: 1.5rem;
  box-shadow: 0 2px 6px rgba(0,0,0,0.1);
}


.form-label {
  font-weight: 500;
}

input.form-control, textarea.form-control {
  border-radius: 6px;
  border: 1px solid #ced4da;
  padding: 0.5rem 0.75rem;
}

button.btn {
  border-radius: 6px;
}
/* Search bar container */
.search-bar {
  background: #f8f9fa;
  padding: 10px 12px;
  border-radius: 10px;
}

/* Input */
.search-input input {
  width: 260px;
  border-radius: 8px;
}

/* Search button */
.btn-search {
  background-color: #0d6efd;
  color: #fff;
  border-radius: 8px;
  padding: 6px 14px;
}

.btn-search:hover {
  background-color: #0b5ed7;
}

/* Clear button */
.btn-clear {
  background-color: #e9ecef;
  color: #495057;
  border-radius: 8px;
  padding: 6px 14px;
}

.btn-clear:hover {
  background-color: #dee2e6;
}

/* Cancel button */
.btn-cancel {
  background-color: transparent;
  color: #dc3545;
  border: 1px solid #dc3545;
  border-radius: 8px;
  padding: 6px 14px;
}

.btn-cancel:hover {
  background-color: #dc3545;
  color: #fff;
}



table.table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
}

table.table th, table.table td {
  vertical-align: middle !important;
  padding: 0.75rem 1rem;
}

table.table thead {
  background-color: #e9ecef;
  font-weight: 600;
}

table.table tbody tr:nth-child(even) {
  background-color: #f8f9fa;
}

table.table td form {
  display: inline-block;
  margin: 0;
}


.pagination {
  justify-content: center;
  margin-top: 1rem;
}

.pagination .page-item .page-link {
  border-radius: 6px;
  margin: 0 3px;
}

.pagination .page-item.active .page-link {
  background-color: #0d6efd;
  border-color: #0d6efd;
  color: #fff;
}

/* ===== Image Preview (if needed) ===== */
#preview img {
  width: 80px;
  height: 80px;
  object-fit: cover;
  margin-right: 10px;
  margin-bottom: 10px;
  border-radius: 6px;
  border: 1px solid #ced4da;
}
select {
  height: auto;
}


</style>
<body>
  <div class="dashboard-container">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <h2>Stravin Admin</h2>
      </div>
      <nav class="sidebar-menu">
        <ul>
          <li><a href="/admin/customers">Customers</a></li>
          <li><a href="/admin/products">Products</a></li>
          <li><a href="/admin/categories">Categories</a></li>
          <li><a href="/admin/coupons">Coupons</a></li>
          <li><a href="/admin/banners">Banners</a></li>
          <li><a href="/admin/orders">Orders</a></li>
          <li><a href="/admin/logout" class="logout">Logout</a></li>
        </ul>
      </nav>
    </aside>

<main class="main-content">
      <!-- Add category form-->
      <div class="card shadow p-3 mb-4">
        <h5 class="card-title">Add New Category</h5>

        <form id="categoryForm">
  <input
    type="text"
    name="name"
    class="form-control mb-2"
    placeholder="Category name">

  <textarea
    name="description"
    class="form-control mb-2"
    placeholder="Description"
  ></textarea>

<input type="number" name="catOfferPercentage" placeholder="Offer %" 
min="0" max="90">
<button type="submit" class="btn btn-primary">
 Add Category
</button>
</form>
</div>

<div>


  <!-- searc/clear/cancel-->
<form method="GET" action="/admin/categories" class="d-flex align-items-center gap-2 mb-3">
 <input type="text"name="search" id="searchbtn" placeholder="Search category"
 value="<%= typeof search !=='undefined' ? search :'' %>"  class="form-control">
<button type="submit" class="btn btn-primary">Search</button>

<a href="/admin/categories" class="btn btn-warning">Clear</a>
<a href="/admin/categories" class="btn btn-danger">Cancel</a>
</form>


 <!--show categories-->
      <div class="card shadow p-3">
        <h5 class="card-title">All Categories</h5>
        <table class="table table-bordered table-hover align-middle">
              <thead class="table-light">

            <tr>
              <th style="width: 20%;">Name</th>
              <th style="width: 35%;">Description</th>
              <th style="width: 35%;">Offer %</th>

              <th style="width: 15%;">Created At</th>
              <th style="width: 10%;"></th>
              <th></th>
              
              
            </tr>
          </thead>
          <tbody>
            <% if (category.length > 0) { %>
              <% category.forEach(cat => { %>
                <tr>
                  <td><%= cat.name %></td>
                  <td><%= cat.description || '-' %></td>
                  <td><%= cat.catOfferPercentage %></td>
                  <td><%= cat.createdAt.toDateString() %></td>
                
                  <td>
                    <a href="/admin/categories/<%= cat._id %>/edit" 
                      class="btn btn-sm btn-warning">Edit</a>
                    </td>
              <td>
                <%if(cat.isListed){%>
         <button type="button" class="btn btn-sm btn-danger"onclick="deleteCategory('<%=cat._id%>')">Unlist
        </button>
        <%}else{%>
        <button type="button"   class="btn btn-success" onclick="restoreCategory('<%=cat._id%>')">Restore
        </button>
        <%}%>
          </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="4" class="text-center">No categories added !!</td></tr>
            <% } %>
          </tbody>
        </table>
        
        <nav aria-label="Page navigation">
  <ul class="pagination">
    <% if (currentPage > 1) { %>
      <li class="page-item">
        <a class="page-link" href="?page=<%= currentPage - 1 %>&search=<%= search %>">Previous</a>
      </li>
    <% } %>

    <% for (let i = 1; i <= totalPages; i++) { %>
      <li class="page-item <%= currentPage === i ? 'active' : '' %>">
        <a class="page-link" href="?page=<%= i %>&search=<%= search %>"><%= i %></a>
      </li>
    <% } %>

    <% if (currentPage < totalPages) { %>
      <li class="page-item">
        <a class="page-link" href="?page=<%= currentPage + 1 %>&search=<%= search %>">Next</a>
      </li>
    <% } %>
      </div>
    </div>
  </div>
<div>


</main>
</div>
<script>
 const categoryForm= document.getElementById('categoryForm')
 categoryForm.addEventListener("submit", async (e) => {
    e.preventDefault()
const name=categoryForm.name.value.trim()
const description=categoryForm.description.value.trim()
const catOfferPercentage = document.querySelector('[name="catOfferPercentage"]').value;
   
if(!name){
  Swal.fire('warning',"Name is required!","warning")
  return
}if(!description){
  Swal.fire('warning',"Description is required!","warning")
  return
}


 try{
     const res = await fetch("/admin/categories/add", {
      method: "POST",
      headers:{
        'Content-Type':'application/json'
      },
      body:JSON.stringify({name,description,catOfferPercentage})
      
    });

    const data = await res.json();

    if (data.success) {
      Swal.fire("Success", data.message, "success")
        .then(() => location.reload());
    } else {
      Swal.fire("Error", data.message||"Something went wrong!");
    }
  }catch(error){
    console.log(error)
    Swal.fire('error!',"Server issue while adding category!","error")
  }

  });
async function deleteCategory(categoryId){
  const result=await Swal.fire({
    title:"Are you sure?",
    text:"This category will be Unlisted!",
    icon:"warning",
    showcancelButton:true,
    confirmButtonText:"Yes.Unlists It!"

  })
  if(!result.isConfirmed) return;
  try{
    const res=await fetch(`/admin/categories/${categoryId}`,{
      method:"DELETE"
    })
    const data=await res.json();
    if(data.success){
      Swal.fire("Deleted!",data.message,"success").then(()=>location.reload())
    }else{
      Swal.fire("Error",data.message,"error")
    }

  }catch(error){
    Swal.fire("Error","Server crashed!","error")
  }
}
async function restoreCategory(categoryId) {
  
  const res = await fetch(`/admin/categories/restoreCategory/${categoryId}`,
  {method:"PUT"}

  );
  const data=await res.json()
  if(res.ok){
    Swal.fire("Success","Category Restored !","success").then(()=>window.location.reload())
  }else{
    Swal.fire("Error",data.message||'Failed!',"error")
  }

  }

async function unlistVariant(variantId){

  const result = await Swal.fire({
    title:"Are you sure?",
    text:"This variant will be Unlisted!",
    icon:"warning",
    showCancelButton:true,
    confirmButtonText:"Yes, Unlist it!"
  });

  if(!result.isConfirmed) return;

  try{

    const res = await fetch(`/admin/variants/${variantId}/unlist`,{
      method:"PATCH"
    });

    const data = await res.json();

    if(data.success){
      Swal.fire("Success",data.message,"success")
      .then(()=>location.reload());
    }else{
      Swal.fire("Error",data.message,"error");
    }

  }catch(err){
    Swal.fire("Error","Server error","error");
  }

}


async function restoreVariant(variantId){

  try{

    const res = await fetch(`/admin/variants/${variantId}/restore`,{
      method:"PATCH"
    });

    const data = await res.json();

    if(data.success){
      Swal.fire("Success","Variant Restored!","success")
      .then(()=>location.reload());
    }else{
      Swal.fire("Error",data.message,"error");
    }

  }catch(err){
    Swal.fire("Error","Server error","error");
  }

}
</script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</body>
</html>



