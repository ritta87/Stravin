<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/css/adminDashboard.css">
  <style>
    /* ===== Sales Report Page ===== */
.sales-report-page {
  max-width: 1200px;
  margin: 30px auto;
  padding: 0 20px 30px;
}

.report-title {
  font-size: 2rem;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 20px;
}

/* ===== Filter Form ===== */
.report-filter-form {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
  background: #ffffff;
  padding: 18px;
  border-radius: 14px;
  box-shadow: 0 6px 22px rgba(15, 23, 42, 0.06);
  margin-bottom: 24px;
  border: 1px solid #eef2f7;
}

.custom-date-box {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.report-input {
  min-width: 180px;
  height: 44px;
  padding: 0 14px;
  border: 1px solid #d7deea;
  border-radius: 10px;
  background: #fff;
  color: #1f2937;
  font-size: 0.95rem;
  outline: none;
  transition: 0.25s ease;
}

.report-input:focus {
  border-color: #198754;
  box-shadow: 0 0 0 3px rgba(25, 135, 84, 0.12);
}

.report-btn {
  height: 44px;
  padding: 0 20px;
  border: none;
  border-radius: 10px;
  background: #198754;
  color: #fff;
  font-weight: 600;
  cursor: pointer;
  transition: 0.25s ease;
}

.report-btn:hover {
  background: #157347;
  transform: translateY(-1px);
}

/* ===== Summary Cards ===== */
.summary-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  gap: 18px;
  margin-bottom: 26px;
}

.summary-card {
  background: #ffffff;
  border-radius: 16px;
  padding: 18px 20px;
  box-shadow: 0 6px 22px rgba(15, 23, 42, 0.06);
  border: 1px solid #edf1f7;
  transition: 0.25s ease;
}

.summary-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 10px 28px rgba(15, 23, 42, 0.09);
}

.summary-card p {
  margin: 0 0 8px;
  font-size: 0.95rem;
  color: #6b7280;
  font-weight: 500;
}

.summary-card h4 {
  margin: 0;
  font-size: 1.5rem;
  color: #111827;
  font-weight: 700;
}

/* ===== Table Card ===== */
.report-table-card {
  background: #ffffff;
  border-radius: 16px;
  box-shadow: 0 6px 22px rgba(15, 23, 42, 0.06);
  border: 1px solid #edf1f7;
  overflow: hidden;
}

.table-header {
  padding: 18px 20px;
  border-bottom: 1px solid #edf1f7;
}

.table-header h3 {
  margin: 0;
  font-size: 1.1rem;
  color: #1f2937;
  font-weight: 700;
}

.table-responsive {
  width: 100%;
  overflow-x: auto;
}

/* ===== Table ===== */
.sales-report-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 900px;
}

.sales-report-table thead {
  background: #f8fafc;
}

.sales-report-table th {
  padding: 14px 16px;
  text-align: left;
  font-size: 0.92rem;
  font-weight: 700;
  color: #374151;
  border-bottom: 1px solid #e5e7eb;
  white-space: nowrap;
}

.sales-report-table td {
  padding: 14px 16px;
  font-size: 0.94rem;
  color: #4b5563;
  border-bottom: 1px solid #f1f5f9;
  vertical-align: middle;
}

.sales-report-table tbody tr:hover {
  background: #fafdfb;
}

/* ===== Status Badge ===== */
.status-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 95px;
  padding: 6px 10px;
  border-radius: 999px;
  font-size: 0.82rem;
  font-weight: 600;
  text-transform: capitalize;
}

.status-delivered {
  background: #e8f8ee;
  color: #198754;
}

.status-placed,
.status-paid,
.status-shipped,
.status-out-for-delivery {
  background: #eaf3ff;
  color: #0d6efd;
}

.status-pending {
  background: #fff8e1;
  color: #b78103;
}

.status-cancelled,
.status-returned,
.status-partially-returned {
  background: #fdecec;
  color: #dc3545;
}

/* ===== Empty State ===== */
.empty-report-state {
  padding: 40px 20px;
  text-align: center;
  color: #6b7280;
  font-size: 1rem;
}

/* ===== Responsive ===== */
@media (max-width: 768px) {
  .sales-report-page {
    padding: 0 14px 24px;
  }

  .report-title {
    font-size: 1.6rem;
  }

  .report-filter-form {
    align-items: stretch;
  }

  .report-input,
  .report-btn {
    width: 100%;
  }

  .custom-date-box {
    width: 100%;
    flex-direction: column;
  }

  .summary-card h4 {
    font-size: 1.25rem;
  }
}
  </style>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>
<body>
  <div class="dashboard-container">
    <aside class="sidebar">
      <div class="sidebar-header">
        <h2>Stravin Admin</h2>
      </div>
      <nav class="sidebar-menu">
        <ul>
          <li><a href="/admin/customers">Customers</a></li>
          <li><a href="/admin/products">Products</a></li>
          <li><a href="/admin/categories">Categories</a></li>
          <li><a href="/admin/coupons">Coupons</a></li>
          <li><a href="/admin/banners">Banners</a></li>
          <li><a href="/admin/orders">Orders</a></li>
          <li><a href="#" id="logoutbtn" class="btn btn-danger">
            <i class="fas fa-sign-out-alt"></i> Logout</a></li>
        </ul>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      <header>
        <h1>Welcome, Admin</h1>
      </header>
      <section class="content">
        <p>This is your Sales Report.Select date to see different sections.</p>
      </section>

<div class="sales-report-page">
  <h2 class="report-title">Sales Report</h2>

  <form method="GET" action="/admin/salesReport" class="report-filter-form">
    <select name="filter" id="filter" onchange="toggleCustomDate()" class="report-input">
      <option value="daily" <%= filter === "daily" ? "selected" : "" %>>Daily</option>
      <option value="weekly" <%= filter === "weekly" ? "selected" : "" %>>Weekly</option>
      <option value="monthly" <%= filter === "monthly" ? "selected" : "" %>>Monthly</option>
      <option value="yearly" <%= filter === "yearly" ? "selected" : "" %>>Yearly</option>
      <option value="custom" <%= filter === "custom" ? "selected" : "" %>>Custom</option>
    </select>

    <span id="customDateBox" class="custom-date-box" style="display:<%= filter === 'custom' ? 'flex' : 'none' %>;">
      <input type="date" name="startDate" value="<%= startDate %>" class="report-input">
      <input type="date" name="endDate" value="<%= endDate %>" class="report-input">
    </span>

    <button type="submit" class="report-btn">Apply</button>
  </form>

  <div class="summary-grid">
    <div class="summary-card">
      <p>Total Orders</p>
      <h4><%= totalOrders %></h4>
    </div>

    <div class="summary-card">
      <p>Total Sales</p>
      <h4>₹<%= overallOrderAmount %></h4>
    </div>

    <div class="summary-card">
      <p>Discount</p>
      <h4>₹<%= overallDiscount %></h4>
    </div>

    <div class="summary-card">
      <p>Coupon</p>
      <h4>₹<%= overallCouponDiscount %></h4>
    </div>

    <div class="summary-card">
      <p>Net Sales</p>
      <h4>₹<%= netSales %></h4>
    </div>
  </div>

  <div class="report-table-card">
    <div class="table-header">
      <h3>Orders</h3>
    </div>

    <% if (orders.length > 0) { %>
      <div class="table-responsive">
        <table class="sales-report-table">
          <thead>
            <tr>
              <th>Order ID</th>
              <th>Date</th>
              <th>User</th>
              <th>Total</th>
              <th>Discount</th>
              <th>Coupon</th>
              <th>Final</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach(order => { %>
              <tr>
                <td><%= order.orderId %></td>
                <td><%= new Date(order.createdAt).toLocaleDateString() %></td>
                <td><%= order.userId?.name || "N/A" %></td>
                <td>₹<%= order.totalAmount || 0 %></td>
                <td>₹<%= order.discount || 0 %></td>
                <td>₹<%= order.coupon?.discountAmount || 0 %></td>
                <td>₹<%= order.finalTotal || 0 %></td>
                <td>
                  <span class="status-badge status-<%= (order.status || '').toLowerCase().replace(/\s+/g, '-') %>">
                    <%= order.status %>
                  </span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty-report-state">
        <p>No orders found for this filter</p>
      </div>
    <% } %>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
function toggleCustomDate() {
  const filter = document.getElementById("filter").value;
  const box = document.getElementById("customDateBox");

  if (filter === "custom") {
    box.style.display = "inline";
  } else {
    box.style.display = "none";
  }
}
</script>
  <script>
    document.getElementById('logoutbtn').addEventListener('click',async(e)=>{
    e.preventDefault();
     Swal.fire({
      title: "Are you sure?",
      text: "You will be logged out of the admin panel",
      icon: "warning",
      showCancelButton: true,
      
      confirmButtonText: "Yes, logout",
      cancelButtonText: "Cancel"
     }).then((result) => {
      if(result.isConfirmed) {
        window.location.href = "/admin/logout"
      }
    })
  })
  </script>
</body>
</html>
