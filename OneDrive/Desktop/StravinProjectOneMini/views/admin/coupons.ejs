<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Coupon</title>
  
  <link rel="stylesheet" href="/css/adminDashboard.css">
<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js" integrity="sha384-G/EV+4j2dNv+tEPo3++6LCgdCROaejBqfUeNjuKAiuXbjrxilcCdDz6ZAVfHWe1Y" crossorigin="anonymous"></script>
<link  href="https://cdn.jsdelivr.net/npm/cropperjs@1.5.13/dist/cropper.min.css" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/cropperjs@1.5.13/dist/cropper.min.js"></script>
  <style>
    .table-container {
  background: #fff;
  padding: 20px;
  border-radius: 10px;
  box-shadow: 0 5px 15px rgba(0,0,0,0.05);
}

.coupon-table {
  width: 100%;
  border-collapse: collapse;
}

.coupon-table th {
  background: #f4f6f9;
  padding: 12px;
  text-align: left;
  font-weight: 600;
}

.coupon-table td {
  padding: 12px;
  border-top: 1px solid #eee;
}

.coupon-table tr:hover {
  background: #f9f9f9;
}

/* Buttons */
.btn-edit {
  background: #ffc107;
  border: none;
  padding: 6px 10px;
  border-radius: 6px;
  cursor: pointer;
}

.btn-delete {
  background: #dc3545;
  border: none;
  padding: 6px 10px;
  border-radius: 6px;
  color: white;
  cursor: pointer;
}

.btn-edit:hover {
  background: #e0a800;
}

.btn-delete:hover {
  background: #c82333;
}
.header {
  display: flex;
  justify-content: space-between; 
  align-items: center;
  margin-bottom: 20px;
}
    .btn-add-coupon {
  display: inline-block;
  padding: 10px 16px;
   margin-left: auto; 
  background: linear-gradient(135deg, #28a745, #20c997);
  color: white;
  font-weight: 600;
  border-radius: 8px;
  text-decoration: none;
  transition: 0.3s;
}

.btn-add-coupon:hover {
  background: linear-gradient(135deg, #218838, #17a589);
  transform: translateY(-1px);
}
  </style>
</head>
<body>
  <div class="dashboard-container">
    <aside class="sidebar">
      <div class="sidebar-header">
        <h2>Stravin Admin</h2>
      </div>
      <nav class="sidebar-menu">
        <ul>
          <li><a href="/admin/customers">Customers</a></li>
          <li><a href="/admin/products">Products</a></li>
          <li><a href="/admin/categories">Categories</a></li>
          <li><a href="/admin/coupons">Coupons</a></li>
          <li><a href="/admin/banners">Banners</a></li>
          <li><a href="/admin/orders">Orders</a></li>
          <li><a href="#" id="logoutbtn" class="btn btn-danger">
            <i class="fas fa-sign-out-alt"></i> Logout</a></li>
        </ul>
      </nav>
    </aside>

    <!-- Main Content -->
   
 

<div class="main-content">

  <div class="header">
    <h2>Coupons</h2>
    <a href="/admin/addCoupon" class="btn-add-coupon">+ Add Coupon</a>
  </div>

  <div class="table-container">
    <table class="coupon-table">

      <thead>
        <tr>
          <th>Code</th>
          <th>Type</th>
          <th>Discount</th>
          <th>Min Purchase</th>
          <th>Max Discount</th>
          <th>Expiry</th>
          <th>Actions</th>
        </tr>
      </thead>

      <tbody>
        <% if (coupons.length > 0) { %>
          <% coupons.forEach(coupon => { %>
            <tr>
              <td><%= coupon.code %></td>
              <td><%= coupon.discountType %></td>
              <td><%= coupon.discountValue %></td>
              <td><%= coupon.minPurchase %></td>
              <td><%= coupon.maxDiscount %></td>
              <td>
                <%= new Date(coupon.expiryDate).toLocaleDateString() %>
              </td>

              <td>
                <button class="btn-edit">Edit</button>
                <button class="btn-delete">Delete</button>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="7" style="text-align:center;">No coupons found</td>
          </tr>
        <% } %>
      </tbody>

    </table>
  </div>

</div>
</main>
  </div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    document.getElementById('logoutbtn').addEventListener('click',async(e)=>{
    e.preventDefault();
     Swal.fire({
      title: "Are you sure?",
      text: "You will be logged out of the admin panel",
      icon: "warning",
      showCancelButton: true,
      
      confirmButtonText: "Yes, logout",
      cancelButtonText: "Cancel"
     }).then((result) => {
      if(result.isConfirmed) {
        window.location.href = "/admin/logout"
      }
    })
  })
  </script>
</body>
</html>


















    
    




